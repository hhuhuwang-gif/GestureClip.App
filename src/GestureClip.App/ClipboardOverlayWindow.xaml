<Window x:Class="GestureClip.App.ClipboardOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="剪贴板历史"
        Width="680"
        Height="620"
        MinWidth="420"
        MinHeight="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">
    <Border Style="{StaticResource GlassPanelStyle}"
            Margin="18"
            Padding="24"
            Background="{DynamicResource BrushGlassStrong}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Margin="2,0,2,16">
                <TextBlock DockPanel.Dock="Right"
                           Text="Ctrl + Alt + V"
                           Foreground="{DynamicResource BrushPrimaryBright}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center" />
                <StackPanel>
                    <TextBlock Text="剪贴板历史"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Text="搜索、回车粘贴，数字键快速选择"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>

            <DockPanel Grid.Row="1" LastChildFill="True">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <TextBlock Text="Enter"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="12"
                               Margin="0,0,8,0" />
                    <TextBlock Text="1-9"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="12" />
                </StackPanel>
                <TextBox x:Name="SearchBox"
                         Height="52"
                         FontSize="18"
                         Padding="16,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>

            <ListBox x:Name="HistoryList"
                     Grid.Row="2"
                     Margin="0,18,0,14"
                     AlternationCount="9"
                     ItemsSource="{Binding Items}"
                     SelectedItem="{Binding SelectedItem}"
                     MouseDoubleClick="HistoryList_MouseDoubleClick">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border Background="#223D526B"
                                BorderBrush="#33768AA8"
                                BorderThickness="1"
                                CornerRadius="16"
                                Padding="14">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="42" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="30"
                                        Height="30"
                                        CornerRadius="10"
                                        Background="{DynamicResource BrushPrimarySoft}"
                                        BorderBrush="#445B8CFF"
                                        BorderThickness="1"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource ShortcutNumberConverter}}"
                                               Foreground="{DynamicResource BrushTextPrimary}"
                                               FontSize="14"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <StackPanel Grid.Column="1">
                                    <TextBlock Text="{Binding PreviewText}"
                                               Foreground="{DynamicResource BrushTextPrimary}"
                                               FontSize="15"
                                               LineHeight="21"
                                               FontWeight="SemiBold"
                                               TextWrapping="Wrap"
                                               TextTrimming="CharacterEllipsis"
                                               MaxHeight="44" />
                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,8,0,0">
                                        <TextBlock Text="{Binding SourceProcess}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   FontSize="12" />
                                        <TextBlock Text="  ·  "
                                                   Style="{StaticResource MutedTextStyle}"
                                                   FontSize="12" />
                                        <TextBlock Text="{Binding CreatedAt, StringFormat={}{0:MM-dd HH:mm}}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   FontSize="12" />
                                        <TextBlock Text="  固定"
                                                   Foreground="{DynamicResource BrushPrimaryBright}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="  敏感"
                                                   Foreground="{DynamicResource BrushDanger}"
                                                   FontSize="12"
                                                   FontWeight="SemiBold">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSensitive}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </StackPanel>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <TextBlock Grid.Row="3"
                       Text="{Binding EmptyStateText}"
                       Style="{StaticResource MutedTextStyle}"
                       HorizontalAlignment="Center" />
        </Grid>
    </Border>
</Window>
