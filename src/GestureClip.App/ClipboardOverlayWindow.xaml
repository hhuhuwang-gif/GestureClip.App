<Window x:Class="GestureClip.App.ClipboardOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="剪贴板历史"
        Width="860"
        Height="760"
        MinWidth="420"
        MinHeight="380"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Deactivated="Window_Deactivated">
    <Border CornerRadius="20"
            Margin="16"
            Padding="20"
            Background="{DynamicResource BrushOverlayPanel}"
            BorderBrush="#14000000"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="6" Opacity="0.14" Direction="270" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Margin="2,0,2,12">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <Button x:Name="AlwaysVisibleButton"
                            Content="常显"
                            Width="58"
                            Height="30"
                            MinWidth="0"
                            Padding="0"
                            FontSize="12"
                            Margin="0,0,10,0"
                            Click="AlwaysVisibleButton_Click" />
                    <Border Style="{StaticResource AccentChipStyle}">
                        <TextBlock Text="Ctrl + `"
                                   Foreground="{DynamicResource BrushPrimaryBright}"
                                   FontWeight="SemiBold" />
                    </Border>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="剪贴板历史"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Text="双击复制并关闭 · Enter/粘贴会粘贴并关闭 · 复制按钮只复制不关闭"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>

            <DockPanel Grid.Row="1" LastChildFill="True">
                <StackPanel DockPanel.Dock="Right"
                            Orientation="Horizontal"
                            VerticalAlignment="Center"
                            Margin="12,0,0,0">
                    <Button x:Name="ClearSearchButton"
                            Content="清空"
                            Width="54"
                            Height="30"
                            MinWidth="0"
                            Padding="0"
                            FontSize="12"
                            Margin="0,0,10,0"
                            Click="ClearSearchButton_Click" />
                    <TextBlock Text="Enter"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="12"
                               Margin="0,0,8,0" />
                    <TextBlock Text="1-0"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="12" />
                </StackPanel>
                <TextBox x:Name="SearchBox"
                         Height="46"
                         FontSize="16"
                         Padding="16,0"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />
            </DockPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        Margin="0,12,0,0">
                <RadioButton x:Name="AllFilterButton"
                             Content="全部"
                             Tag="All"
                             IsChecked="True"
                             Checked="FilterRadioButton_Checked"
                             Margin="0,0,8,0" />
                <RadioButton x:Name="PinnedFilterButton"
                             Content="固定"
                             Tag="Pinned"
                             Checked="FilterRadioButton_Checked"
                             Margin="0,0,8,0" />
                <RadioButton x:Name="FavoritesFilterButton"
                             Content="片段"
                             Tag="Favorites"
                             Checked="FilterRadioButton_Checked"
                             Margin="0,0,8,0" />
                <RadioButton x:Name="TextFilterButton"
                             Content="文本"
                             Tag="Text"
                             Checked="FilterRadioButton_Checked"
                             Margin="0,0,8,0" />
                <RadioButton x:Name="ImagesFilterButton"
                             Content="图片"
                             Tag="Images"
                             Checked="FilterRadioButton_Checked" />
            </StackPanel>

            <Grid Grid.Row="3"
                  Margin="0,14,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="0" />
                </Grid.ColumnDefinitions>

            <ListBox x:Name="HistoryList"
                     Grid.Column="0"
                     Margin="0,0,0,48"
                     AlternationCount="9"
                     SelectionMode="Extended"
                     ScrollViewer.CanContentScroll="True"
                     ScrollViewer.IsDeferredScrollingEnabled="True"
                     VirtualizingPanel.IsVirtualizing="True"
                     VirtualizingPanel.VirtualizationMode="Recycling"
                     VirtualizingPanel.ScrollUnit="Pixel"
                     ItemsSource="{Binding Items}"
                     SelectedItem="{Binding SelectedItem}"
                     SelectionChanged="HistoryList_SelectionChanged"
                     ScrollViewer.ScrollChanged="HistoryList_ScrollChanged"
                     PreviewMouseRightButtonDown="HistoryList_PreviewMouseRightButtonDown"
                     MouseDoubleClick="HistoryList_MouseDoubleClick">
                <ListBox.ContextMenu>
                    <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}"
                                 Opened="ContextMenu_Opened"
                                 Closed="ContextMenu_Closed">
                        <MenuItem Header="复制选中" Click="CopySelectedMenuItem_Click" />
                        <MenuItem Header="粘贴选中" Click="PasteSelectedMenuItem_Click" />
                        <Separator />
                        <MenuItem Header="{Binding SelectedPinActionText}" Click="TogglePinnedMenuItem_Click" />
                        <MenuItem Header="{Binding SelectedFavoriteActionText}" Click="ToggleFavoriteMenuItem_Click" />
                        <MenuItem Header="删除选中" Click="DeleteSelectedMenuItem_Click" />
                    </ContextMenu>
                </ListBox.ContextMenu>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <VirtualizingStackPanel />
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="ItemCard"
                                Background="#F7F8FB"
                                BorderBrush="#14111827"
                                BorderThickness="1"
                                CornerRadius="12"
                                Padding="8"
                                MinHeight="52">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="32" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <Border Width="24"
                                        Height="24"
                                        CornerRadius="8"
                                        Background="#111111"
                                        BorderBrush="#22000000"
                                        BorderThickness="1"
                                        VerticalAlignment="Top">
                                    <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=(ItemsControl.AlternationIndex), Converter={StaticResource ShortcutNumberConverter}}"
                                               Foreground="White"
                                               FontSize="12"
                                               FontWeight="SemiBold"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center" />
                                </Border>
                                <Grid Grid.Column="1">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <Border Width="64"
                                            Height="42"
                                            CornerRadius="10"
                                            BorderBrush="#55111827"
                                            BorderThickness="1.5"
                                            Margin="0,0,10,0"
                                            ClipToBounds="True">
                                        <Border.Background>
                                            <DrawingBrush TileMode="Tile"
                                                          Viewport="0,0,12,12"
                                                          ViewportUnits="Absolute">
                                                <DrawingBrush.Drawing>
                                                    <DrawingGroup>
                                                        <GeometryDrawing Brush="#FFFFFFFF">
                                                            <GeometryDrawing.Geometry>
                                                                <RectangleGeometry Rect="0,0,12,12" />
                                                            </GeometryDrawing.Geometry>
                                                        </GeometryDrawing>
                                                        <GeometryDrawing Brush="#FFE8ECF3">
                                                            <GeometryDrawing.Geometry>
                                                                <GeometryGroup>
                                                                    <RectangleGeometry Rect="0,0,6,6" />
                                                                    <RectangleGeometry Rect="6,6,6,6" />
                                                                </GeometryGroup>
                                                            </GeometryDrawing.Geometry>
                                                        </GeometryDrawing>
                                                    </DrawingGroup>
                                                </DrawingBrush.Drawing>
                                            </DrawingBrush>
                                        </Border.Background>
                                        <Grid>
                                            <TextBlock Text="图片缩略图"
                                                       Foreground="#7C8596"
                                                       FontSize="12"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center" />
                                            <Image Source="{Binding ThumbnailContent, IsAsync=True, Converter={StaticResource ImageBase64ToSourceConverter}, ConverterParameter=72}"
                                                   Stretch="Uniform"
                                                   RenderOptions.BitmapScalingMode="LowQuality" />
                                        </Grid>
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                    </Border>
                                    <StackPanel Grid.Column="1"
                                                VerticalAlignment="Center">
                                        <TextBlock x:Name="PreviewTextBlock"
                                                   Text="{Binding PreviewText}"
                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                   FontSize="13"
                                                   LineHeight="17"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap"
                                                   TextTrimming="CharacterEllipsis"
                                                   MaxHeight="34">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock x:Name="ImageItemPreviewTextBlock"
                                                   Text="图片记录 · 双击复制并关闭，可放回系统剪贴板"
                                                   Foreground="{DynamicResource BrushTextPrimary}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsImage}" Value="True">
                                                            <Setter Property="Visibility" Value="Visible" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <StackPanel Orientation="Horizontal"
                                                    Margin="0,4,0,0">
                                            <TextBlock x:Name="SourceProcessBlock"
                                                       Text="{Binding SourceProcess}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       FontSize="12" />
                                            <TextBlock x:Name="DotBlock"
                                                       Text="  ·  "
                                                       Style="{StaticResource MutedTextStyle}"
                                                       FontSize="12" />
                                            <TextBlock x:Name="CreatedAtBlock"
                                                       Text="{Binding CreatedAt, StringFormat={}{0:MM-dd HH:mm}}"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       FontSize="12" />
                                            <TextBlock Text="  固定"
                                                       Foreground="{DynamicResource BrushPrimaryBright}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsPinned}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="  敏感"
                                                       Foreground="{DynamicResource BrushDanger}"
                                                       FontSize="12"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsSensitive}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="  片段"
                                                       Foreground="#2563EB"
                                                       FontSize="12"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsFavorite}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </StackPanel>
                                        <WrapPanel Margin="0,4,0,0">
                                            <Button x:Name="ItemQuickCopyButton"
                                                    Content="复制"
                                                    Width="38"
                                                    Height="22"
                                                    MinWidth="0"
                                                    Padding="0"
                                                    FontSize="11"
                                                    Margin="0,0,6,0"
                                                    Click="QuickCopyItemButton_Click" />
                                            <Button x:Name="ItemQuickPasteButton"
                                                    Content="粘贴"
                                                    Width="38"
                                                    Height="22"
                                                    MinWidth="0"
                                                    Padding="0"
                                                    FontSize="11"
                                                    Margin="0,0,6,0"
                                                    Click="QuickPasteItemButton_Click" />
                                            <Button x:Name="ItemQuickPinButton"
                                                    Content="置顶"
                                                    Width="38"
                                                    Height="22"
                                                    MinWidth="0"
                                                    Padding="0"
                                                    FontSize="11"
                                                    Margin="0,0,6,0"
                                                    Click="QuickPinItemButton_Click" />
                                            <Button x:Name="ItemQuickDeleteButton"
                                                    Content="删除"
                                                    Width="38"
                                                    Height="22"
                                                    MinWidth="0"
                                                    Padding="0"
                                                    FontSize="11"
                                                    Style="{StaticResource DangerButtonStyle}"
                                                    Click="QuickDeleteItemButton_Click" />
                                        </WrapPanel>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                        <DataTemplate.Triggers>
                            <DataTrigger Binding="{Binding UseCount}" Value="0">
                                <Setter TargetName="ItemCard" Property="Background" Value="#FFFFFFFF" />
                                <Setter TargetName="ItemCard" Property="BorderBrush" Value="#17111827" />
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsSelected, RelativeSource={RelativeSource AncestorType=ListBoxItem}}" Value="True">
                                <Setter TargetName="ItemCard" Property="Background" Value="#EAF3FF" />
                                <Setter TargetName="ItemCard" Property="BorderBrush" Value="{DynamicResource BrushPrimaryBright}" />
                                <Setter TargetName="PreviewTextBlock" Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
                                <Setter TargetName="SourceProcessBlock" Property="Foreground" Value="{DynamicResource BrushTextSecondary}" />
                                <Setter TargetName="DotBlock" Property="Foreground" Value="{DynamicResource BrushTextMuted}" />
                                <Setter TargetName="CreatedAtBlock" Property="Foreground" Value="{DynamicResource BrushTextSecondary}" />
                            </DataTrigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

                  <Border Grid.Column="1"
                        Visibility="Collapsed"
                        Background="#F7F8FB"
                        BorderBrush="#17111827"
                        BorderThickness="1"
                        CornerRadius="20"
                        Padding="14">
                    <Grid>
                        <TextBlock Text="选中一条记录后，这里会显示大预览。"
                                   TextWrapping="Wrap"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource MutedTextStyle}">
                                    <Setter Property="Visibility" Value="Visible" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelectedItem}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>

                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasSelectedItem}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>

                            <DockPanel Margin="0,0,0,12">
                                <Border DockPanel.Dock="Right"
                                        CornerRadius="11"
                                        Background="#E8EEF8"
                                        Padding="10,5">
                                    <TextBlock Text="{Binding SelectedContentTypeText}"
                                               Foreground="{DynamicResource BrushTextPrimary}"
                                               FontSize="12"
                                               FontWeight="SemiBold" />
                                </Border>
                                <StackPanel>
                                    <TextBlock Text="详情预览"
                                               FontSize="17"
                                               FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SelectedSourceText}"
                                               Style="{StaticResource MutedTextStyle}"
                                               Margin="0,4,0,0" />
                                </StackPanel>
                            </DockPanel>

                            <Border x:Name="SelectedImagePreviewPanel"
                                    Height="260"
                                    CornerRadius="16"
                                    BorderBrush="#33111827"
                                    BorderThickness="1"
                                    ClipToBounds="True">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelectedImage}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Border.Background>
                                    <DrawingBrush TileMode="Tile"
                                                  Viewport="0,0,14,14"
                                                  ViewportUnits="Absolute">
                                        <DrawingBrush.Drawing>
                                            <DrawingGroup>
                                                <GeometryDrawing Brush="#FFFFFFFF">
                                                    <GeometryDrawing.Geometry>
                                                        <RectangleGeometry Rect="0,0,14,14" />
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                                <GeometryDrawing Brush="#FFE8ECF3">
                                                    <GeometryDrawing.Geometry>
                                                        <GeometryGroup>
                                                            <RectangleGeometry Rect="0,0,7,7" />
                                                            <RectangleGeometry Rect="7,7,7,7" />
                                                        </GeometryGroup>
                                                    </GeometryDrawing.Geometry>
                                                </GeometryDrawing>
                                            </DrawingGroup>
                                        </DrawingBrush.Drawing>
                                    </DrawingBrush>
                                </Border.Background>
                                <Grid>
                                    <Image Source="{Binding SelectedItem.ThumbnailContent, IsAsync=True, Converter={StaticResource ImageBase64ToSourceConverter}, ConverterParameter=220}"
                                           Stretch="Uniform"
                                           Margin="10"
                                           RenderOptions.BitmapScalingMode="Fant" />
                                </Grid>
                            </Border>

                            <Border Height="170"
                                    CornerRadius="16"
                                    BorderBrush="#33111827"
                                    BorderThickness="1"
                                    Background="#FFFFFFFF"
                                    ClipToBounds="True">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Visibility" Value="Collapsed" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelectedText}" Value="True">
                                                <Setter Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <Grid>
                                    <ScrollViewer Margin="14">
                                        <TextBlock Text="{Binding SelectedItem.TextContent}"
                                                   TextWrapping="Wrap"
                                                   FontSize="14"
                                                   LineHeight="22"
                                                   Foreground="{DynamicResource BrushTextPrimary}" />
                                    </ScrollViewer>
                                </Grid>
                            </Border>

                            <Grid Margin="0,10,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="88" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="时间" Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Grid.Column="1" Text="{Binding SelectedCreatedAtText}" TextAlignment="Right" />
                                <TextBlock Grid.Row="1" Text="使用" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedUseCountText}" TextAlignment="Right" Margin="0,8,0,0" />
                                <TextBlock Grid.Row="2" Text="提示" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" />
                                <TextBlock Grid.Row="2"
                                           Grid.Column="1"
                                           Text="Enter 粘贴，Ctrl+C 复制选中"
                                           TextAlignment="Right"
                                           TextWrapping="Wrap"
                                           Margin="0,8,0,0" />
                            </Grid>

                            <WrapPanel Margin="0,10,0,0">
                                <Button x:Name="DetailCopyButton"
                                        Content="复制"
                                        Width="92"
                                        MinWidth="0"
                                        Margin="0,0,8,8"
                                        Click="CopySelectedMenuItem_Click" />
                                <Button x:Name="DetailPasteButton"
                                        Content="粘贴"
                                        Width="92"
                                        MinWidth="0"
                                        Margin="0,0,8,8"
                                        Click="PasteSelectedMenuItem_Click" />
                                <Button x:Name="DetailPinButton"
                                        Content="{Binding SelectedPinActionText}"
                                        Width="92"
                                        MinWidth="0"
                                        Margin="0,0,8,8"
                                        Click="TogglePinnedMenuItem_Click" />
                                <Button x:Name="DetailFavoriteButton"
                                        Content="{Binding SelectedFavoriteActionText}"
                                        Width="92"
                                        MinWidth="0"
                                        Margin="0,0,8,8"
                                        Click="ToggleFavoriteMenuItem_Click" />
                                <Button x:Name="DetailDeleteButton"
                                        Content="删除"
                                        Width="92"
                                        MinWidth="0"
                                        Style="{StaticResource DangerButtonStyle}"
                                        Click="DeleteSelectedMenuItem_Click" />
                            </WrapPanel>
                        </StackPanel>
                    </Grid>
                </Border>

                <Border Grid.ColumnSpan="2"
                        Panel.ZIndex="10"
                        HorizontalAlignment="Center"
                        VerticalAlignment="Top"
                        Margin="0,16,0,0"
                        Padding="14,8"
                        CornerRadius="14"
                        Background="#EEFFFFFF"
                        BorderBrush="#22111827"
                        BorderThickness="1"
                        IsHitTestVisible="False">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Collapsed" />
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsLoading}" Value="True">
                                    <Setter Property="Visibility" Value="Visible" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <TextBlock Text="正在加载剪贴板历史…"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushTextSecondary}" />
                </Border>
            </Grid>

            <StackPanel Grid.Row="4"
                        HorizontalAlignment="Center">
                <TextBlock Text="{Binding SummaryText}"
                           Foreground="{DynamicResource BrushTextPrimary}"
                           FontSize="12"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />
                <TextBlock Text="Ctrl + 1-5 分类 · Ctrl + P 置顶 · Ctrl + S 片段 · Ctrl + C 复制 · Delete 删除 · Esc 清搜索/关闭"
                           Style="{StaticResource MutedTextStyle}"
                           FontSize="11"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,4" />
                <TextBlock Text="{Binding EmptyStateText}"
                           Style="{StaticResource MutedTextStyle}"
                           HorizontalAlignment="Center" />
                <TextBlock Text="{Binding StatusText}"
                           Foreground="{DynamicResource BrushPrimaryBright}"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </Border>
</Window>

