<Window x:Class="GestureClip.App.ClipboardOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="剪贴板历史"
        Width="520"
        Height="560"
        MinWidth="420"
        MinHeight="420"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBox x:Name="SearchBox"
                 Height="36"
                 FontSize="15"
                 VerticalContentAlignment="Center"
                 Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" />

        <ListBox x:Name="HistoryList"
                 Grid.Row="1"
                 Margin="0,12,0,12"
                 ItemsSource="{Binding Items}"
                 SelectedItem="{Binding SelectedItem}"
                 MouseDoubleClick="HistoryList_MouseDoubleClick">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="32" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding RelativeSource={RelativeSource AncestorType=ListBoxItem}, Path=(ItemsControl.AlternationIndex)}"
                                   Foreground="#777777"
                                   VerticalAlignment="Top" />
                        <StackPanel Grid.Column="1">
                            <TextBlock Text="{Binding PreviewText}"
                                       TextWrapping="Wrap"
                                       TextTrimming="CharacterEllipsis"
                                       MaxHeight="42" />
                            <TextBlock Text="{Binding SourceProcess}"
                                       Foreground="#777777"
                                       FontSize="12"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>

        <TextBlock Grid.Row="2"
                   Text="{Binding EmptyStateText}"
                   Foreground="#777777"
                   HorizontalAlignment="Center" />
    </Grid>
</Window>
