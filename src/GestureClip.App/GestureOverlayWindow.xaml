<Window x:Class="GestureClip.App.GestureOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="800"
        Height="450"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Grid IsHitTestVisible="False">
        <Canvas IsHitTestVisible="False">
            <Polyline Points="{Binding Points}"
                      Stroke="{Binding StrokeBrush}"
                      StrokeThickness="7"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Opacity="0.95">
                <Polyline.Effect>
                    <DropShadowEffect Color="#805B8CFF"
                                      BlurRadius="14"
                                      ShadowDepth="0"
                                      Opacity="0.65" />
                </Polyline.Effect>
            </Polyline>
        </Canvas>
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,82"
                MinWidth="500"
                Style="{StaticResource GlassPanelStyle}"
                Padding="38,24"
                Background="{DynamicResource BrushGlassStrong}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="{Binding PresetName}"
                           Foreground="{DynamicResource BrushTextSecondary}"
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                    <TextBlock Text="{Binding DirectionText}"
                               Foreground="{DynamicResource BrushPrimaryBright}"
                               FontSize="52"
                               FontWeight="SemiBold"
                               Margin="0,0,20,0" />
                    <TextBlock Text="{Binding ActionName}"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               FontSize="46"
                               FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                    <TextBlock Text="{Binding Pattern}"
                               Foreground="{DynamicResource BrushPrimaryBright}"
                               FontSize="17"
                               FontWeight="SemiBold" />
                    <TextBlock Text="  ·  "
                               Foreground="{DynamicResource BrushTextMuted}"
                               FontSize="17" />
                    <TextBlock Text="{Binding ShortcutText}"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="17" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
