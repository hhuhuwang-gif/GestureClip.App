<Window x:Class="GestureClip.App.GestureOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="800"
        Height="450"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Grid IsHitTestVisible="False">
        <Canvas IsHitTestVisible="False">
            <Polyline Points="{Binding Points}"
                      Stroke="#FF2F80ED"
                      StrokeThickness="5"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Opacity="0.92" />
        </Canvas>
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,160"
                MinWidth="320"
                Background="#DD202020"
                CornerRadius="8"
                Padding="30,18">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="{Binding PresetName}"
                           Foreground="#BBBBBB"
                           FontSize="14"
                           HorizontalAlignment="Center" />
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0">
                    <TextBlock Text="{Binding DirectionText}"
                               Foreground="White"
                               FontSize="38"
                               FontWeight="SemiBold"
                               Margin="0,0,18,0" />
                    <TextBlock Text="{Binding ActionName}"
                               Foreground="White"
                               FontSize="38"
                               FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0">
                    <TextBlock Text="{Binding Pattern}"
                               Foreground="#A8C7FF"
                               FontSize="16"
                               FontWeight="SemiBold" />
                    <TextBlock Text="  ·  "
                               Foreground="#777777"
                               FontSize="16" />
                    <TextBlock Text="{Binding ShortcutText}"
                               Foreground="#DDDDDD"
                               FontSize="16" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
