<Window x:Class="GestureClip.App.GestureOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="800"
        Height="450"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Grid IsHitTestVisible="False">
        <Canvas IsHitTestVisible="False">
            <Polyline Points="{Binding Points}"
                      Stroke="{Binding StrokeBrush}"
                      StrokeThickness="6"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Opacity="0.95">
                <Polyline.Effect>
                    <DropShadowEffect Color="#AA2563EB"
                                      BlurRadius="18"
                                      ShadowDepth="0"
                                      Opacity="0.46" />
                </Polyline.Effect>
            </Polyline>
        </Canvas>
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,82"
                MinWidth="520"
                CornerRadius="26"
                Padding="36,24"
                Background="{DynamicResource BrushDarkPanel}">
            <Border.Effect>
                <DropShadowEffect Color="#111827" BlurRadius="32" ShadowDepth="10" Opacity="0.30" />
            </Border.Effect>
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0"
                           Text="{Binding PresetName}"
                           Foreground="#8F949E"
                           FontSize="15"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center" />
                <StackPanel Grid.Row="1"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                    <TextBlock Text="{Binding DirectionText}"
                               Foreground="{DynamicResource BrushPrimaryBright}"
                               FontSize="52"
                               FontWeight="SemiBold"
                               Margin="0,0,20,0" />
                           <TextBlock Text="{Binding ActionName}"
                               Foreground="White"
                               FontSize="46"
                               FontWeight="SemiBold" />
                </StackPanel>
                <StackPanel Grid.Row="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Center"
                            Margin="0,10,0,0">
                    <TextBlock Text="{Binding Pattern}"
                               Foreground="{DynamicResource BrushPrimaryBright}"
                               FontSize="17"
                               FontWeight="SemiBold" />
                    <TextBlock Text="  ·  "
                               Foreground="#6B7280"
                               FontSize="17" />
                    <TextBlock Text="{Binding ShortcutText}"
                               Foreground="#A7ADB8"
                               FontSize="17" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
