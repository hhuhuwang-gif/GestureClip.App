<Window x:Class="GestureClip.App.GestureOverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="800"
        Height="450"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        Focusable="False"
        IsHitTestVisible="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Grid IsHitTestVisible="False">
        <Canvas IsHitTestVisible="False">
            <Polyline Points="{Binding Points}"
                      Stroke="{Binding StrokeBrush}"
                      StrokeThickness="2.2"
                      StrokeStartLineCap="Round"
                      StrokeEndLineCap="Round"
                      StrokeLineJoin="Round"
                      Opacity="0.95">
                <Polyline.Effect>
                    <DropShadowEffect Color="#AA2563EB"
                                      BlurRadius="10"
                                      ShadowDepth="0"
                                      Opacity="0.28" />
                </Polyline.Effect>
            </Polyline>
        </Canvas>
        <Border HorizontalAlignment="Center"
                VerticalAlignment="Bottom"
                Margin="0,0,0,70"
                Width="860"
                Height="210"
                CornerRadius="24"
                Padding="12"
                Background="{Binding HudBackgroundBrush}"
                BorderBrush="#38FFFFFF"
                BorderThickness="1"
                x:Name="CompactGameHud"
                SnapsToDevicePixels="True">
            <Border.Effect>
                <DropShadowEffect Color="#101827" BlurRadius="22" ShadowDepth="7" Opacity="0.26" />
            </Border.Effect>
            <Grid x:Name="GestureActionStrip" SnapsToDevicePixels="True">
                <Grid.ColumnDefinitions>
                <ColumnDefinition Width="86" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="188" />
                </Grid.ColumnDefinitions>

                <Border Width="72"
                        Height="72"
                        CornerRadius="20"
                        Background="#E6111724"
                        BorderBrush="#6693C5FD"
                        BorderThickness="1"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Center">
                    <TextBlock Text="{Binding DirectionText}"
                               Foreground="#FFFFFFFF"
                               FontSize="34"
                               FontWeight="Bold"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis" />
                </Border>

                <StackPanel Grid.Column="1"
                            VerticalAlignment="Center"
                            Margin="2,0,12,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="工位小熊"
                                   Foreground="{Binding HudAccentBrush}"
                                   FontSize="13"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="  ·  "
                                   Foreground="#668A94A8"
                                   FontSize="13" />
                        <TextBlock Text="{Binding PresetName}"
                                   Foreground="#FFD8E1EE"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                    <TextBlock Text="{Binding ActionName}"
                               Foreground="#FFFFFFFF"
                               FontSize="28"
                               FontWeight="SemiBold"
                               Margin="0,3,0,0"
                               TextTrimming="CharacterEllipsis" />
                    <StackPanel Orientation="Horizontal" Margin="0,3,0,0">
                        <TextBlock Text="{Binding ShortcutText}"
                                   Foreground="#FFDCEBFF"
                                   FontSize="14"
                                   FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="   手势码: "
                                   Foreground="#FF8A94A8"
                                   FontSize="14"
                                   FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="{Binding Pattern}"
                                   Foreground="{Binding HudAccentBrush}"
                                   FontSize="14"
                                   FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI"
                                   FontWeight="Bold" />
                    </StackPanel>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding FunText}"
                                   Foreground="{Binding HudAccentBrush}"
                                   FontSize="14"
                                   FontWeight="SemiBold"
                                   TextWrapping="NoWrap"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding GainedXpText}"
                                   Foreground="#FF86EFAC"
                                   FontSize="13"
                                   FontWeight="Bold"
                                   Margin="12,0,0,0" />
                    </Grid>
                    <Grid Margin="0,8,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="120" />
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{Binding LevelText}"
                                   Foreground="#FFE0F2FE"
                                   FontSize="13"
                                   FontWeight="SemiBold"
                                   TextTrimming="CharacterEllipsis" />
                        <TextBlock Grid.Column="1"
                                   Text="{Binding XpText}"
                                   Foreground="{Binding HudAccentBrush}"
                                   FontSize="12"
                                   FontFamily="Cascadia Mono, Consolas, Microsoft YaHei UI"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Right"
                                   TextTrimming="CharacterEllipsis" />
                    </Grid>
                    <ProgressBar Minimum="0"
                                 Maximum="1"
                                 Value="{Binding XpProgressPercent}"
                                 Height="5"
                                 Margin="0,7,0,0"
                                 Foreground="{Binding HudAccentBrush}"
                                 Background="#24FFFFFF"
                                 BorderThickness="0" />
                    <StackPanel x:Name="TodayStatsLine" Margin="0,8,0,0">
                        <TextBlock Text="{Binding WorkSummaryText}" Foreground="#FFFFFFFF" FontSize="13" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                        <TextBlock Text="{Binding StatsText}" Foreground="#FFC9D4E5" FontSize="12" FontWeight="SemiBold" Margin="0,5,0,0" TextTrimming="CharacterEllipsis" />
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" VerticalAlignment="Center">
                    <TextBlock Text="松开右键执行"
                               Foreground="{Binding HudAccentBrush}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right" />
                    <TextBlock Text="{Binding WorkStatusText}"
                               Foreground="{Binding HudAccentBrush}"
                               FontSize="14"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               Margin="0,7,0,0"
                               TextTrimming="CharacterEllipsis" />
                    <TextBlock Text="普通右键不显示"
                               Foreground="#FF8A94A8"
                               FontSize="11"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Right"
                               Margin="0,6,0,0" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>



