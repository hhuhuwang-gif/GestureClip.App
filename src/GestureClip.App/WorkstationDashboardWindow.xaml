<Window x:Class="GestureClip.App.WorkstationDashboardWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="工位小熊 Hub"
        Icon="Assets/GestureClip.ico"
        Width="760"
        Height="860"
        MinWidth="680"
        MinHeight="720"
        WindowStartupLocation="CenterScreen"
        Background="Transparent"
        AllowsTransparency="True"
        WindowStyle="None"
        ResizeMode="CanResize"
        Foreground="{DynamicResource BrushTextPrimary}"
        Loaded="Window_Loaded"
        Closing="Window_Closing">
    <Border CornerRadius="28"
            Background="{DynamicResource BrushAppBackground}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="1"
            Padding="22"
            MouseLeftButtonDown="WindowBackground_MouseLeftButtonDown">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Margin="2,0,2,16">
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal">
                    <Button Content="－" Width="42" Height="34" MinWidth="0" Padding="0" Focusable="False" FocusVisualStyle="{x:Null}" FontSize="17" FontWeight="SemiBold" Background="#00FFFFFF" BorderBrush="#00000000" ToolTip="最小化" Click="MinimizeButton_Click" />
                    <Button Content="×" Width="42" Height="34" MinWidth="0" Padding="0" Margin="6,0,0,0" Focusable="False" FocusVisualStyle="{x:Null}" FontSize="17" FontWeight="SemiBold" Background="#00FFFFFF" BorderBrush="#00000000" Foreground="{DynamicResource BrushTextSecondary}" ToolTip="关闭" Click="CloseButton_Click" />
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="工位小熊 Hub" FontSize="30" FontWeight="SemiBold" />
                    <TextBlock Text="{Binding Subtitle}" Margin="0,5,0,0" FontSize="13" Foreground="{DynamicResource BrushTextSecondary}" />
                </StackPanel>
            </DockPanel>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <Border Style="{StaticResource GlassCardStyle}" Padding="24" Margin="0,0,0,14" Background="#CC172033">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="顶部实时状态" Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Text="{Binding CurrentStateText}" FontSize="28" FontWeight="SemiBold" Foreground="{DynamicResource BrushPrimaryBright}" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding BearStatusText}" FontSize="16" FontWeight="SemiBold" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding BearLineText}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,8,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right" MinWidth="240">
                                <TextBlock Text="今日已赚" Style="{StaticResource MutedTextStyle}" TextAlignment="Right" />
                                <TextBlock Text="{Binding TodayEarnedText}" FontSize="34" FontWeight="SemiBold" TextAlignment="Right" />
                                <TextBlock Text="距离下班" Style="{StaticResource MutedTextStyle}" TextAlignment="Right" Margin="0,10,0,0" />
                                <TextBlock Text="{Binding OffWorkCountdownText}" FontSize="26" FontWeight="SemiBold" TextAlignment="Right" />
                                <TextBlock Text="{Binding SavedClicksText}" Style="{StaticResource MutedTextStyle}" TextAlignment="Right" Margin="0,8,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>

                    <UniformGrid Columns="2" Margin="0,0,0,14">
                        <Border Style="{StaticResource GlassCardStyle}" Padding="20" Margin="0,0,7,0">
                            <StackPanel>
                                <TextBlock Text="今日收益与效率" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding SalaryHintText}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,12" />
                                <TextBlock Text="老板今日已支出" Style="{StaticResource MutedTextStyle}" />
                                <TextBlock Text="{Binding BossPaidText}" FontSize="24" FontWeight="SemiBold" />
                                <TextBlock Text="你每分钟约值" Style="{StaticResource MutedTextStyle}" Margin="0,10,0,0" />
                                <TextBlock Text="{Binding MinuteValueText}" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ActionStatsText}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,12,0,0" />
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource GlassCardStyle}" Padding="20" Margin="7,0,0,0">
                            <StackPanel>
                                <TextBlock Text="操作统计" FontSize="18" FontWeight="SemiBold" />
                                <UniformGrid Columns="2" Margin="0,12,0,0">
                                    <TextBlock Text="复制" Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock Text="{Binding CopyCountText}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                    <TextBlock Text="粘贴" Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock Text="{Binding PasteCountText}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                    <TextBlock Text="手势" Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock Text="{Binding GestureCountText}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                    <TextBlock Text="打开剪贴板" Style="{StaticResource MutedTextStyle}" />
                                    <TextBlock Text="{Binding OpenClipboardCountText}" FontWeight="SemiBold" HorizontalAlignment="Right" />
                                </UniformGrid>
                                <TextBlock Text="GestureClip 今日帮你减少重复点击。" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,14,0,0" />
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <UniformGrid Columns="2" Margin="0,0,0,14">
                        <Border Style="{StaticResource GlassCardStyle}" Padding="20" Margin="0,0,7,0">
                            <StackPanel>
                                <TextBlock Text="摸鱼模式" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="默认只记录你手动开启的摸鱼，不识别网页、不读取标题。" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,12" />
                                <TextBlock Text="{Binding CurrentFishingText, StringFormat=本次 {0}}" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding CurrentFishingValueText, StringFormat=本次约值 {0}}" Style="{StaticResource MutedTextStyle}" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding TodayFishingDurationText, StringFormat=今日累计 {0}}" Style="{StaticResource MutedTextStyle}" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding TodayFishingValueText, StringFormat=今日摸鱼价值 {0}}" Style="{StaticResource MutedTextStyle}" Margin="0,6,0,12" />
                                <WrapPanel>
                                    <Button Content="{Binding FishingButtonText}" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ToggleFishingCommand}" Margin="0,0,10,8" />
                                    <Button Content="清除今日摸鱼" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ClearFishingCommand}" Margin="0,0,10,8" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource GlassCardStyle}" Padding="20" Margin="7,0,0,0">
                            <StackPanel>
                                <TextBlock Text="休息提醒" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="轻量提醒，可稍后、可关闭，不抢焦点。" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,12" />
                                <TextBlock Text="{Binding ContinuousWorkText, StringFormat=连续工作 {0}}" FontSize="20" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding NextRestReminderText, StringFormat=下次提醒 {0}}" Style="{StaticResource MutedTextStyle}" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding RestReminderCountText}" Style="{StaticResource MutedTextStyle}" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding RestRiskText, StringFormat=当前风险等级：{0}}" Style="{StaticResource MutedTextStyle}" Margin="0,6,0,12" />
                                <WrapPanel>
                                    <Button Content="稍后提醒" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding SnoozeRestReminderCommand}" Margin="0,0,10,8" />
                                    <Button Content="{Binding RestReminderButtonText}" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ToggleRestReminderCommand}" Margin="0,0,10,8" />
                                    <Button Content="关闭提醒" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding DisableRestReminderCommand}" Margin="0,0,10,8" />
                                </WrapPanel>
                            </StackPanel>
                        </Border>
                    </UniformGrid>

                    <Border Style="{StaticResource GlassCardStyle}" Padding="20" Margin="0,0,0,14">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="下班冲刺" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ProtectionHintText}" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                <TextBlock Text="{Binding SprintSuggestionText}" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap" Margin="0,12,0,0" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" HorizontalAlignment="Right">
                                <TextBlock Text="距离下班" Style="{StaticResource MutedTextStyle}" TextAlignment="Right" />
                                <TextBlock Text="{Binding SprintCountdownText}" FontSize="24" FontWeight="SemiBold" TextAlignment="Right" />
                                <WrapPanel Margin="0,12,0,0" HorizontalAlignment="Right">
                                    <Button Content="开启冲刺" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding StartSprintCommand}" Margin="0,0,10,0" />
                                    <Button Content="关闭" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding StopSprintCommand}" />
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </Border>

                    <Border Style="{StaticResource GlassCardStyle}" Padding="20" Margin="0,0,0,14">
                        <StackPanel>
                            <DockPanel>
                                <TextBlock Text="今日牛马生存报告" FontSize="18" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding DailyRatingText}" DockPanel.Dock="Right" FontSize="16" FontWeight="SemiBold" Foreground="{DynamicResource BrushPrimaryBright}" HorizontalAlignment="Right" />
                            </DockPanel>
                            <TextBlock Text="{Binding DailyReportText}" TextWrapping="Wrap" Margin="0,10,0,0" Foreground="{DynamicResource BrushTextSecondary}" />
                            <WrapPanel Margin="0,14,0,0">
                                <Button Content="生成今日报告" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding GenerateReportCommand}" Margin="0,0,10,8" />
                                <Button Content="生成 PNG 分享卡片" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding GenerateShareCardCommand}" Margin="0,0,10,8" />
                                <Button Content="{Binding AutoDailyReportButtonText}" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding ToggleAutoDailyReportCommand}" Margin="0,0,10,8" />
                                <Button Content="今天不再显示" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding MuteDailyReportTodayCommand}" Margin="0,0,10,8" />
                            </WrapPanel>
                        </StackPanel>
                    </Border>

                    <Expander Header="工作规则设置" Margin="0,0,0,14" Foreground="{DynamicResource BrushTextPrimary}">
                        <Border Style="{StaticResource GlassCardStyle}" Padding="18" Margin="0,10,0,0">
                            <StackPanel>
                                <TextBlock Text="设置放在底部；缺少月薪时工资显示 0，不会崩溃。工作日：0=周日，1=周一 ... 6=周六。" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,0,0,12" />
                                <TextBlock Text="工作制模板" Style="{StaticResource MutedTextStyle}" />
                                <ItemsControl ItemsSource="{Binding WorkTemplateOptions}" Margin="0,6,0,12">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <WrapPanel />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Button Content="{Binding Name}"
                                                    Style="{StaticResource SecondaryButtonStyle}"
                                                    Command="{Binding DataContext.ApplyWorkTemplateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                    CommandParameter="{Binding}"
                                                    Margin="0,0,8,8" />
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <UniformGrid Columns="2">
                                    <StackPanel Margin="0,0,8,10"><TextBlock Text="月薪" Style="{StaticResource MutedTextStyle}" /><TextBox Text="{Binding WorkstationMonthlySalary, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" /></StackPanel>
                                    <StackPanel Margin="8,0,0,10"><TextBlock Text="发薪日" Style="{StaticResource MutedTextStyle}" /><TextBox Text="{Binding WorkstationPayday, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" /></StackPanel>
                                    <StackPanel Margin="0,0,8,10"><TextBlock Text="上班时间" Style="{StaticResource MutedTextStyle}" /><TextBox Text="{Binding WorkstationWorkStartTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" /></StackPanel>
                                    <StackPanel Margin="8,0,0,10"><TextBlock Text="下班时间" Style="{StaticResource MutedTextStyle}" /><TextBox Text="{Binding WorkstationWorkEndTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" /></StackPanel>
                                    <StackPanel Margin="0,0,8,10"><TextBlock Text="午休开始" Style="{StaticResource MutedTextStyle}" /><TextBox Text="{Binding WorkstationLunchStartTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" /></StackPanel>
                                    <StackPanel Margin="8,0,0,10"><TextBlock Text="午休结束" Style="{StaticResource MutedTextStyle}" /><TextBox Text="{Binding WorkstationLunchEndTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" /></StackPanel>
                                </UniformGrid>
                                <TextBlock Text="工作日" Style="{StaticResource MutedTextStyle}" />
                                <TextBox Text="{Binding WorkstationWorkdays, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" Margin="0,4,0,10" />
                                <TextBlock Text="文案风格" Style="{StaticResource MutedTextStyle}" />
                                <ComboBox ItemsSource="{Binding WorkBearTextStyleOptions}" SelectedItem="{Binding WorkBearTextStyle, Mode=TwoWay}" Margin="0,4,0,0" />
                            </StackPanel>
                        </Border>
                    </Expander>
                </StackPanel>
            </ScrollViewer>

            <DockPanel Grid.Row="2" Margin="0,16,0,0">
                <TextBlock Text="{Binding LastMessage}" TextWrapping="Wrap" Foreground="{DynamicResource BrushTextSecondary}" VerticalAlignment="Center" />
                <WrapPanel DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <Button Content="刷新" Style="{StaticResource SecondaryButtonStyle}" Command="{Binding RefreshCommand}" Margin="0,0,10,0" />
                    <Button Content="打开设置" Style="{StaticResource SecondaryButtonStyle}" Click="OpenSettingsButton_Click" Margin="0,0,10,0" />
                    <Button Content="重置今日" Style="{StaticResource DangerButtonStyle}" Command="{Binding ResetTodayCommand}" />
                </WrapPanel>
            </DockPanel>
        </Grid>
    </Border>
</Window>

