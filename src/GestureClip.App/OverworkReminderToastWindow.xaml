<Window x:Class="GestureClip.App.OverworkReminderToastWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Width="420"
        Height="178"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        Topmost="True"
        ShowActivated="False"
        ResizeMode="NoResize"
        WindowStartupLocation="Manual">
    <Border CornerRadius="22"
            Padding="18"
            Background="#F4FFFFFF"
            BorderBrush="#2A111827"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#334155" BlurRadius="24" ShadowDepth="8" Opacity="0.22" />
        </Border.Effect>
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel>
                <Border Width="32"
                        Height="32"
                        CornerRadius="10"
                        Background="#FFF3D48"
                        DockPanel.Dock="Left"
                        Margin="0,0,10,0">
                    <TextBlock Text="🐻"
                               FontSize="18"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center" />
                </Border>
                <StackPanel>
                    <TextBlock Text="{Binding Title}"
                               FontSize="15"
                               FontWeight="SemiBold"
                               Foreground="#111827" />
                    <TextBlock Text="{Binding StageText}"
                               Margin="0,2,0,0"
                               FontSize="12"
                               Foreground="#667085" />
                </StackPanel>
            </DockPanel>

            <StackPanel Grid.Row="1" Margin="0,12,0,0">
                <TextBlock Text="{Binding Message}"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           TextWrapping="Wrap" />
                <TextBlock Text="{Binding Detail}"
                           Margin="0,5,0,0"
                           FontSize="12"
                           Foreground="#667085"
                           TextWrapping="Wrap" />
            </StackPanel>

            <StackPanel Grid.Row="2"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,12,0,0">
                <Button Content="我知道了"
                        MinWidth="82"
                        Height="32"
                        Padding="12,0"
                        Click="DismissButton_Click" />
                <Button Content="稍后提醒"
                        MinWidth="82"
                        Height="32"
                        Padding="12,0"
                        Margin="8,0,0,0"
                        Visibility="{Binding SnoozeButtonVisibility}"
                        Click="SnoozeButton_Click" />
                <Button Content="今天不再提醒"
                        MinWidth="106"
                        Height="32"
                        Padding="12,0"
                        Margin="8,0,0,0"
                        Click="MuteTodayButton_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
