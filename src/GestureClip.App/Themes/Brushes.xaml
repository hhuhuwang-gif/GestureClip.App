<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColorBackgroundDark}" />
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurfaceDark}" />
    <SolidColorBrush x:Key="BrushGlass" Color="{StaticResource ColorGlassDark}" />
    <SolidColorBrush x:Key="BrushGlassStrong" Color="{StaticResource ColorGlassStrongDark}" />
    <SolidColorBrush x:Key="BrushGlassLight" Color="{StaticResource ColorGlassLight}" />
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorderDark}" />
    <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}" />
    <SolidColorBrush x:Key="BrushPrimarySoft" Color="{StaticResource ColorPrimarySoft}" />
    <SolidColorBrush x:Key="BrushPrimaryBright" Color="{StaticResource ColorPrimaryBright}" />
    <SolidColorBrush x:Key="BrushDanger" Color="{StaticResource ColorDanger}" />
    <SolidColorBrush x:Key="BrushDangerSoft" Color="{StaticResource ColorDangerSoft}" />
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimaryDark}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondaryDark}" />
    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMutedDark}" />
    <SolidColorBrush x:Key="BrushControlHover" Color="{StaticResource ColorControlHover}" />
    <SolidColorBrush x:Key="BrushControlSelected" Color="{StaticResource ColorControlSelected}" />
    <SolidColorBrush x:Key="BrushControlDisabled" Color="{StaticResource ColorControlDisabled}" />
    <SolidColorBrush x:Key="BrushComboBoxDropDown" Color="{StaticResource ColorComboBoxDropDown}" />
    <SolidColorBrush x:Key="BrushTabSelected" Color="{StaticResource ColorTabSelected}" />
    <SolidColorBrush x:Key="BrushTabSelectedText" Color="{StaticResource ColorTabSelectedText}" />
    <SolidColorBrush x:Key="BrushTabIdle" Color="{StaticResource ColorTabIdle}" />
    <LinearGradientBrush x:Key="BrushAppBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F8FAFC" Offset="0" />
        <GradientStop Color="#F2F5F9" Offset="0.5" />
        <GradientStop Color="#EDF1F6" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrushGlassHighlight" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F2FFFFFF" Offset="0" />
        <GradientStop Color="#CFFFFFFF" Offset="0.55" />
        <GradientStop Color="#B8FFFFFF" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrushTabSelectedGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#F8FBFF" Offset="0" />
        <GradientStop Color="#E8F1FF" Offset="1" />
    </LinearGradientBrush>
    <LinearGradientBrush x:Key="BrushPrimaryGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#3B82F6" Offset="0" />
        <GradientStop Color="#2563EB" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>
