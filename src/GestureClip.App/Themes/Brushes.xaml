<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <SolidColorBrush x:Key="BrushBackground" Color="{StaticResource ColorBackgroundDark}" />
    <SolidColorBrush x:Key="BrushSurface" Color="{StaticResource ColorSurfaceDark}" />
    <SolidColorBrush x:Key="BrushGlass" Color="{StaticResource ColorGlassDark}" />
    <SolidColorBrush x:Key="BrushGlassStrong" Color="{StaticResource ColorGlassStrongDark}" />
    <SolidColorBrush x:Key="BrushGlassLight" Color="{StaticResource ColorGlassLight}" />
    <SolidColorBrush x:Key="BrushBorder" Color="{StaticResource ColorBorderDark}" />
    <SolidColorBrush x:Key="BrushPrimary" Color="{StaticResource ColorPrimary}" />
    <SolidColorBrush x:Key="BrushPrimarySoft" Color="{StaticResource ColorPrimarySoft}" />
    <SolidColorBrush x:Key="BrushPrimaryBright" Color="{StaticResource ColorPrimaryBright}" />
    <SolidColorBrush x:Key="BrushDanger" Color="{StaticResource ColorDanger}" />
    <SolidColorBrush x:Key="BrushDangerSoft" Color="{StaticResource ColorDangerSoft}" />
    <SolidColorBrush x:Key="BrushTextPrimary" Color="{StaticResource ColorTextPrimaryDark}" />
    <SolidColorBrush x:Key="BrushTextSecondary" Color="{StaticResource ColorTextSecondaryDark}" />
    <SolidColorBrush x:Key="BrushTextMuted" Color="{StaticResource ColorTextMutedDark}" />
    <SolidColorBrush x:Key="BrushControlHover" Color="{StaticResource ColorControlHover}" />
    <SolidColorBrush x:Key="BrushControlSelected" Color="{StaticResource ColorControlSelected}" />
    <SolidColorBrush x:Key="BrushControlDisabled" Color="{StaticResource ColorControlDisabled}" />
    <SolidColorBrush x:Key="BrushComboBoxDropDown" Color="{StaticResource ColorComboBoxDropDown}" />
    <SolidColorBrush x:Key="BrushTabSelected" Color="{StaticResource ColorTabSelected}" />
    <SolidColorBrush x:Key="BrushTabSelectedText" Color="{StaticResource ColorTabSelectedText}" />
    <SolidColorBrush x:Key="BrushTabIdle" Color="{StaticResource ColorTabIdle}" />
    <SolidColorBrush x:Key="BrushDarkPanel" Color="{StaticResource ColorDarkPanel}" />
    <SolidColorBrush x:Key="BrushDarkPanelSoft" Color="{StaticResource ColorDarkPanelSoft}" />
    <SolidColorBrush x:Key="BrushCoral" Color="{StaticResource ColorCoral}" />
    <SolidColorBrush x:Key="BrushAccentSoft" Color="{StaticResource ColorAccentSoft}" />
    <SolidColorBrush x:Key="BrushSuccess" Color="{StaticResource ColorSuccess}" />
    <SolidColorBrush x:Key="BrushSeparator" Color="{StaticResource ColorSeparator}" />
    <SolidColorBrush x:Key="BrushFillTertiary" Color="{StaticResource ColorFillTertiary}" />
    <SolidColorBrush x:Key="BrushTrafficClose" Color="{StaticResource ColorTrafficClose}" />
    <SolidColorBrush x:Key="BrushTrafficYellow" Color="{StaticResource ColorTrafficYellow}" />
    <SolidColorBrush x:Key="BrushTrafficGreen" Color="{StaticResource ColorTrafficGreen}" />
    <SolidColorBrush x:Key="BrushTrafficMinimize" Color="{StaticResource ColorTrafficYellow}" />
    <SolidColorBrush x:Key="BrushTrafficMaximize" Color="{StaticResource ColorTrafficGreen}" />

    <!-- Soft daylight wash, not loud blue -->
    <LinearGradientBrush x:Key="BrushAppBackground" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FBFBFD" Offset="0" />
        <GradientStop Color="#F5F5F7" Offset="0.45" />
        <GradientStop Color="#EEF1F6" Offset="0.82" />
        <GradientStop Color="#F7F8FA" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BrushGlassHighlight" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FFFFFFFF" Offset="0" />
        <GradientStop Color="#FBFCFF" Offset="0.55" />
        <GradientStop Color="#F7F8FA" Offset="1" />
    </LinearGradientBrush>

    <!-- Sidebar selected pill -->
    <LinearGradientBrush x:Key="BrushTabSelectedGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#EEEEF2" Offset="0" />
        <GradientStop Color="#E5E5EA" Offset="1" />
    </LinearGradientBrush>

    <!-- Apple blue primary CTA (gradient kept for non-text accents) -->
    <LinearGradientBrush x:Key="BrushPrimaryGradient" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#0A84FF" Offset="0" />
        <GradientStop Color="#0071E3" Offset="0.55" />
        <GradientStop Color="#0060C0" Offset="1" />
    </LinearGradientBrush>
    <!-- Solid blue for primary buttons: better white-text contrast than light gradient -->
    <SolidColorBrush x:Key="BrushPrimarySolid" Color="#0071E3" />
    <SolidColorBrush x:Key="BrushPrimarySolidHover" Color="#0066CC" />
    <SolidColorBrush x:Key="BrushPrimarySolidPressed" Color="#0055AA" />

    <LinearGradientBrush x:Key="BrushCoralGradient" StartPoint="0,0" EndPoint="1,1">
        <GradientStop Color="#FF8A7A" Offset="0" />
        <GradientStop Color="#FF6B5A" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BrushOverlayPanel" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#FCFCFF" Offset="0" />
        <GradientStop Color="#F7F8FA" Offset="1" />
    </LinearGradientBrush>

    <LinearGradientBrush x:Key="BrushSidebarBackground" StartPoint="0,0" EndPoint="0,1">
        <GradientStop Color="#F2F2F7" Offset="0" />
        <GradientStop Color="#ECECF0" Offset="1" />
    </LinearGradientBrush>
</ResourceDictionary>
