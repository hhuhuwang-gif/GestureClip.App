<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Minimal luxury light palette: near-white surfaces, hairline ink, restrained blue -->
    <Color x:Key="ColorBackgroundLight">#F6F6F8</Color>
    <Color x:Key="ColorBackgroundDark">#F6F6F8</Color>
    <Color x:Key="ColorSurfaceDark">#FFFFFFFF</Color>
    <Color x:Key="ColorGlassLight">#FAFFFFFF</Color>
    <Color x:Key="ColorGlassDark">#F2FFFFFF</Color>
    <Color x:Key="ColorGlassStrongDark">#F8FFFFFF</Color>
    <Color x:Key="ColorBorderLight">#12000000</Color>
    <Color x:Key="ColorBorderDark">#0E000000</Color>
    <Color x:Key="ColorPrimary">#111113</Color>
    <Color x:Key="ColorPrimarySoft">#10111113</Color>
    <Color x:Key="ColorPrimaryBright">#0B6BCB</Color>
    <Color x:Key="ColorDanger">#E5484D</Color>
    <Color x:Key="ColorDangerSoft">#14E5484D</Color>
    <Color x:Key="ColorTextPrimaryLight">#111113</Color>
    <Color x:Key="ColorTextSecondaryLight">#6B6B73</Color>
    <Color x:Key="ColorTextPrimaryDark">#111113</Color>
    <Color x:Key="ColorTextSecondaryDark">#6B6B73</Color>
    <Color x:Key="ColorTextMutedDark">#8E8E96</Color>
    <Color x:Key="ColorControlHover">#F0F0F3</Color>
    <Color x:Key="ColorControlSelected">#EAF2FB</Color>
    <Color x:Key="ColorControlDisabled">#E8E8ED</Color>
    <Color x:Key="ColorComboBoxDropDown">#FCFCFD</Color>
    <Color x:Key="ColorTabSelected">#EBEBEF</Color>
    <Color x:Key="ColorTabSelectedText">#111113</Color>
    <Color x:Key="ColorTabIdle">#00FFFFFF</Color>
    <Color x:Key="ColorDarkPanel">#1C1C1E</Color>
    <Color x:Key="ColorDarkPanelSoft">#2C2C2E</Color>
    <Color x:Key="ColorCoral">#FF6B5A</Color>
    <Color x:Key="ColorAccentSoft">#EEF5FC</Color>
    <Color x:Key="ColorSuccess">#30A46C</Color>
    <Color x:Key="ColorSeparator">#12000000</Color>
    <Color x:Key="ColorFillTertiary">#F2F2F5</Color>
    <Color x:Key="ColorTrafficClose">#FF5F57</Color>
    <Color x:Key="ColorTrafficYellow">#FEBC2E</Color>
    <Color x:Key="ColorTrafficGreen">#28C840</Color>
    <Color x:Key="ColorTrafficMinimize">#FEBC2E</Color>
    <Color x:Key="ColorTrafficMaximize">#28C840</Color>
    <!-- Near-flat luxury wash (almost solid, slight depth) -->
    <Color x:Key="ColorAppBg0">#FAFAFB</Color>
    <Color x:Key="ColorAppBg1">#F6F6F8</Color>
    <Color x:Key="ColorAppBg2">#F3F4F7</Color>
    <Color x:Key="ColorAppBg3">#F8F8FA</Color>
    <Color x:Key="ColorOverlayTop">#FFFFFF</Color>
    <Color x:Key="ColorOverlayBottom">#F8F9FB</Color>
    <Color x:Key="ColorGlassTop">#FFFFFF</Color>
    <Color x:Key="ColorGlassMid">#FCFCFD</Color>
    <Color x:Key="ColorGlassBottom">#F7F7F9</Color>
    <Color x:Key="ColorSidebarTop">#F4F4F6</Color>
    <Color x:Key="ColorSidebarBottom">#EEEEF1</Color>
    <Color x:Key="ColorCardElevated">#FFFFFF</Color>
    <Color x:Key="ColorShadow">#000000</Color>
    <Color x:Key="ColorFocusRing">#400B6BCB</Color>
    <Color x:Key="ColorSegmentSelected">#FFFFFF</Color>
    <Color x:Key="ColorListHover">#F3F3F6</Color>
    <Color x:Key="ColorListSelectedHover">#DEEAF8</Color>
    <Color x:Key="ColorButtonFill">#F2F2F5</Color>
    <Color x:Key="ColorButtonHover">#E8E8ED</Color>
</ResourceDictionary>
