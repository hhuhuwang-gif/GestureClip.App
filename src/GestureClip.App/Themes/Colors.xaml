<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <!-- Apple-inspired light system palette -->
    <Color x:Key="ColorBackgroundLight">#F5F5F7</Color>
    <Color x:Key="ColorBackgroundDark">#F5F5F7</Color>
    <Color x:Key="ColorSurfaceDark">#FFFFFFFF</Color>
    <Color x:Key="ColorGlassLight">#F7FFFFFF</Color>
    <Color x:Key="ColorGlassDark">#E8FFFFFF</Color>
    <Color x:Key="ColorGlassStrongDark">#F2FFFFFF</Color>
    <Color x:Key="ColorBorderLight">#1A000000</Color>
    <Color x:Key="ColorBorderDark">#14000000</Color>
    <Color x:Key="ColorPrimary">#1D1D1F</Color>
    <Color x:Key="ColorPrimarySoft">#141D1D1F</Color>
    <!-- Apple system blue (links / accents). Primary buttons use deeper solid blue for white text. -->
    <Color x:Key="ColorPrimaryBright">#0071E3</Color>
    <Color x:Key="ColorDanger">#FF3B30</Color>
    <Color x:Key="ColorDangerSoft">#1AFF3B30</Color>
    <Color x:Key="ColorTextPrimaryLight">#1D1D1F</Color>
    <Color x:Key="ColorTextSecondaryLight">#6E6E73</Color>
    <Color x:Key="ColorTextPrimaryDark">#1D1D1F</Color>
    <Color x:Key="ColorTextSecondaryDark">#6E6E73</Color>
    <Color x:Key="ColorTextMutedDark">#8E8E93</Color>
    <Color x:Key="ColorControlHover">#EFEFF4</Color>
    <Color x:Key="ColorControlSelected">#E5F1FF</Color>
    <Color x:Key="ColorControlDisabled">#E5E5EA</Color>
    <Color x:Key="ColorComboBoxDropDown">#FBFBFD</Color>
    <!-- Sidebar selection: soft fill, dark text (macOS Settings style) -->
    <Color x:Key="ColorTabSelected">#E8E8ED</Color>
    <Color x:Key="ColorTabSelectedText">#1D1D1F</Color>
    <Color x:Key="ColorTabIdle">#00FFFFFF</Color>
    <Color x:Key="ColorDarkPanel">#1C1C1E</Color>
    <Color x:Key="ColorDarkPanelSoft">#2C2C2E</Color>
    <Color x:Key="ColorCoral">#FF6B5A</Color>
    <Color x:Key="ColorAccentSoft">#EAF3FF</Color>
    <Color x:Key="ColorSuccess">#34C759</Color>
    <Color x:Key="ColorSeparator">#1A3C3C43</Color>
    <Color x:Key="ColorFillTertiary">#F2F2F7</Color>
    <Color x:Key="ColorTrafficClose">#FF5F57</Color>
    <Color x:Key="ColorTrafficYellow">#FEBC2E</Color>
    <Color x:Key="ColorTrafficGreen">#28C840</Color>
    <!-- Legacy aliases (same values) for any older references -->
    <Color x:Key="ColorTrafficMinimize">#FEBC2E</Color>
    <Color x:Key="ColorTrafficMaximize">#28C840</Color>
</ResourceDictionary>
