<Window x:Class="GestureClip.App.QuickActionCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快捷动作"
        Width="520"
        Height="560"
        MinWidth="420"
        MinHeight="420"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Deactivated="Window_Deactivated">
    <Border CornerRadius="24"
            Margin="20"
            Padding="0"
            Background="{DynamicResource BrushOverlayPanel}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="52" ShadowDepth="10" Opacity="0.20" Direction="270" />
        </Border.Effect>
        <Grid Margin="18">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Spotlight-style search first -->
            <DockPanel Margin="2,0,2,12">
                <Border DockPanel.Dock="Right"
                        Style="{StaticResource AccentChipStyle}">
                    <TextBlock Text="{Binding OpenQuickActionHotkeyHint, FallbackValue=Ctrl + Shift + Q}"
                               FontSize="11"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushPrimaryBright}" />
                </Border>
                <TextBlock Text="快捷动作"
                           Style="{StaticResource Title22Style}"
                           VerticalAlignment="Center" />
            </DockPanel>

            <Border Grid.Row="1"
                    CornerRadius="14"
                    Background="{DynamicResource BrushFillTertiary}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1"
                    Padding="4"
                    Margin="0,0,0,12">
                <DockPanel LastChildFill="True">
                    <Button DockPanel.Dock="Right"
                            Content="↻"
                            Style="{StaticResource IconToolbarButtonStyle}"
                            Margin="8,0,4,0"
                            ToolTip="刷新输入"
                            Command="{Binding RefreshInputCommand}" />
                    <TextBox x:Name="SearchBox"
                             Height="40"
                             FontSize="16"
                             BorderThickness="0"
                             Background="Transparent"
                             VerticalContentAlignment="Center"
                             Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             Padding="12,0"
                             Tag="搜索 json、空格、链接…" />
                </DockPanel>
            </Border>

            <Grid Grid.Row="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="1.2*" />
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <Border Style="{StaticResource GlassCardStyle}"
                        Padding="6"
                        Effect="{x:Null}"
                        Background="{DynamicResource BrushSurface}">
                    <ListBox x:Name="ActionList"
                             ItemsSource="{Binding FilteredActions}"
                             SelectedItem="{Binding SelectedAction}"
                             ItemContainerStyle="{StaticResource GlassListBoxItemStyle}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             MouseDoubleClick="ActionList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="12"
                                        Padding="12,10"
                                        Margin="2"
                                        Background="Transparent">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Right"
                                                Style="{StaticResource PillBadgeStyle}">
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="10"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushPrimaryBright}" />
                                        </Border>
                                        <StackPanel>
                                            <TextBlock Text="{Binding DisplayName}"
                                                       Style="{StaticResource Title17Style}"
                                                       FontSize="15"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="{Binding Description}"
                                                       Style="{StaticResource Caption11Style}"
                                                       Margin="0,4,0,0" />
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Border Grid.Row="2"
                        Style="{StaticResource GlassCardStyle}"
                        Effect="{x:Null}"
                        Background="{DynamicResource BrushFillTertiary}">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,10">
                            <TextBlock Text="预览 / 结果"
                                       Style="{StaticResource Caption11Style}" />
                            <TextBlock Text="{Binding SelectedAction.DisplayName, FallbackValue=选择一个动作}"
                                       Style="{StaticResource Title17Style}"
                                       Margin="0,4,0,0" />
                        </StackPanel>
                        <DockPanel DockPanel.Dock="Bottom" LastChildFill="False" Margin="0,12,0,0">
                            <Button Content="复制结果"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Width="120"
                                    Margin="0,0,8,0"
                                    Command="{Binding RunSelectedCommand}" />
                            <Button Content="处理并粘贴"
                                    Width="120"
                                    Command="{Binding RunAndPasteCommand}" />
                        </DockPanel>
                        <TextBox Text="{Binding PreviewText}"
                                 IsReadOnly="True"
                                 TextWrapping="Wrap"
                                 AcceptsReturn="True"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="Consolas, Cascadia Mono, Microsoft YaHei UI"
                                 FontSize="12.5"
                                 Background="{DynamicResource BrushSurface}"
                                 BorderThickness="0"
                                 Padding="10" />
                    </DockPanel>
                </Border>
            </Grid>

            <TextBlock Grid.Row="3"
                       Text="{Binding StatusText}"
                       Style="{StaticResource Caption11Style}"
                       Margin="0,12,0,0"
                       HorizontalAlignment="Center" />

            <TextBlock Grid.Row="4"
                       Text="本地处理 · 不登录 · 不上传 · Esc 关闭"
                       Style="{StaticResource Caption11Style}"
                       HorizontalAlignment="Center"
                       Margin="0,6,0,0" />
        </Grid>
    </Border>
</Window>
