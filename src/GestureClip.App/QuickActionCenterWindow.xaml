<Window x:Class="GestureClip.App.QuickActionCenterWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="快捷动作"
        Width="760"
        Height="580"
        MinWidth="500"
        MinHeight="440"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterScreen"
        KeyDown="Window_KeyDown"
        Deactivated="Window_Deactivated">
    <Border CornerRadius="20"
            Margin="16"
            Padding="0"
            Background="{DynamicResource BrushOverlayPanel}"
            BorderBrush="#14000000"
            BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="40" ShadowDepth="6" Opacity="0.14" Direction="270" />
        </Border.Effect>
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DockPanel Margin="2,0,2,14">
                <Border DockPanel.Dock="Right"
                        Style="{StaticResource AccentChipStyle}">
                    <TextBlock Text="{Binding OpenQuickActionHotkeyHint, FallbackValue=Ctrl + Shift + Q}"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushPrimaryBright}" />
                </Border>
                <StackPanel>
                    <TextBlock Text="快捷动作"
                               FontSize="22"
                               FontWeight="SemiBold" />
                    <TextBlock Text="本地文本处理 · 不登录 · 不上传 · 结果默认写回剪贴板"
                               Style="{StaticResource MutedTextStyle}"
                               Margin="0,4,0,0" />
                </StackPanel>
            </DockPanel>

            <DockPanel Grid.Row="1" LastChildFill="True" Margin="0,0,0,14">
                <Button DockPanel.Dock="Right"
                        Content="刷新输入"
                        Width="96"
                        Height="40"
                        Margin="10,0,0,0"
                        Command="{Binding RefreshInputCommand}" />
                <TextBox x:Name="SearchBox"
                         Height="40"
                         FontSize="15"
                         VerticalContentAlignment="Center"
                         Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                         Padding="14,0"
                         Tag="搜索动作：json、空格、编码…" />
            </DockPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="1.15*" />
                    <ColumnDefinition Width="14" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource GlassCardStyle}"
                        Padding="10"
                        Effect="{x:Null}">
                    <ListBox x:Name="ActionList"
                             ItemsSource="{Binding FilteredActions}"
                             SelectedItem="{Binding SelectedAction}"
                             ItemContainerStyle="{StaticResource GlassListBoxItemStyle}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             VirtualizingPanel.IsVirtualizing="True"
                             VirtualizingPanel.VirtualizationMode="Recycling"
                             MouseDoubleClick="ActionList_MouseDoubleClick">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="10,8">
                                    <DockPanel>
                                        <Border DockPanel.Dock="Right"
                                                Style="{StaticResource AccentChipStyle}"
                                                Padding="8,3">
                                            <TextBlock Text="{Binding Category}"
                                                       FontSize="11"
                                                       Foreground="{DynamicResource BrushPrimaryBright}" />
                                        </Border>
                                        <TextBlock Text="{Binding DisplayName}"
                                                   FontSize="15"
                                                   FontWeight="SemiBold"
                                                   TextWrapping="Wrap" />
                                    </DockPanel>
                                    <TextBlock Text="{Binding Description}"
                                               Style="{StaticResource MutedTextStyle}"
                                               Margin="0,6,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource GlassCardStyle}"
                        Effect="{x:Null}">
                    <DockPanel LastChildFill="True">
                        <StackPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                            <TextBlock Text="当前动作"
                                       FontWeight="SemiBold"
                                       FontSize="14" />
                            <TextBlock Text="{Binding SelectedDescription}"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,8,0,0" />
                            <Border Style="{StaticResource SoftStatusCardStyle}" Margin="0,12,0,0" Padding="12">
                                <TextBlock Text="{Binding InputHint}"
                                           Style="{StaticResource MutedTextStyle}" />
                            </Border>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Bottom" Margin="0,12,0,0">
                            <TextBlock Text="预览"
                                       FontWeight="SemiBold"
                                       FontSize="14"
                                       Margin="0,0,0,8" />
                            <TextBox Text="{Binding PreviewText}"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     Height="128"
                                     VerticalScrollBarVisibility="Auto"
                                     Padding="12" />
                        </StackPanel>
                        <Border Style="{StaticResource SoftStatusCardStyle}"
                                VerticalAlignment="Top"
                                Padding="12">
                            <TextBlock Text="{Binding StatusText}"
                                       Style="{StaticResource MutedTextStyle}" />
                        </Border>
                    </DockPanel>
                </Border>
            </Grid>

            <StackPanel Grid.Row="3"
                        Orientation="Horizontal"
                        HorizontalAlignment="Right"
                        Margin="0,16,0,0">
                <Button Content="仅预览"
                        Width="100"
                        Height="38"
                        Margin="0,0,10,0"
                        Command="{Binding PreviewSelectedCommand}" />
                <Button Content="处理并粘贴"
                        Width="116"
                        Height="38"
                        Margin="0,0,10,0"
                        Command="{Binding RunAndPasteCommand}" />
                <Button Content="处理并复制"
                        Width="116"
                        Height="38"
                        Style="{StaticResource PrimaryButtonStyle}"
                        IsDefault="True"
                        Command="{Binding RunSelectedCommand}" />
            </StackPanel>

            <TextBlock Grid.Row="4"
                       Margin="0,14,0,0"
                       Style="{StaticResource MutedTextStyle}"
                       Text="↑↓ 选择 · Enter 复制结果 · Ctrl+Enter 粘贴 · Esc 关闭 · 仅本地确定性动作" />
        </Grid>
    </Border>
</Window>
