                                                              ItemsSource="{Binding WorkstationCopywritingStyleOptions}"
                                                              SelectedItem="{Binding WorkstationCopywritingStyle, Mode=TwoWay}" />
                                                </StackPanel>
                                                <TextBlock Text="正常模式 / 打工人模式 / 抽象模式：只影响 HUD 和预览文案，不影响统计数据。"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="诊断">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                        <StackPanel Margin="28,24,36,36" HorizontalAlignment="Stretch">
                            <Border x:Name="DiagnosticsPageIntro" Style="{StaticResource SettingsIntroCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="诊断与日志" Style="{StaticResource SettingsIntroTitleStyle}" />
                                    <TextBlock Text="遇到问题时先复制诊断信息或导出诊断包，方便定位热键、数据库、日志和运行路径。"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="诊断" Style="{StaticResource SettingsGroupTitleStyle}" Margin="2,20,0,10" />
                            <Border Style="{StaticResource SettingsListContainerStyle}" HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <WrapPanel>
                                        <Button Content="打开日志目录" Style="{StaticResource SettingsSecondaryActionButtonStyle}" Command="{Binding OpenLogDirectoryCommand}" />
                                        <Button Content="打开数据目录" Style="{StaticResource SettingsSecondaryActionButtonStyle}" Command="{Binding OpenDataDirectoryCommand}" />
                                        <Button Content="复制诊断信息" Style="{StaticResource SettingsSecondaryActionButtonStyle}" Command="{Binding CopyDiagnosticsCommand}" />
                                        <Button Content="导出诊断包" Style="{StaticResource SettingsSecondaryActionButtonStyle}" Command="{Binding ExportDiagnosticsCommand}" />
                                        <Button Content="刷新" Style="{StaticResource SettingsSecondaryActionButtonStyle}" Command="{Binding RefreshDiagnosticsCommand}" />
                                    </WrapPanel>
                                    <TextBlock Text="{Binding LastDiagnosticsExportText}"
                                               Style="{StaticResource MutedTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                    <TextBox Text="{Binding DiagnosticsText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="220" Margin="0,10,0,0" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="关于">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                        <StackPanel Margin="28,24,36,36" HorizontalAlignment="Stretch">
                            <Border x:Name="AboutPageIntro" Style="{StaticResource SettingsIntroCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="关于与更新" Style="{StaticResource SettingsIntroTitleStyle}" />
                                    <TextBlock Text="查看 GestureClip 的定位，并从这里检查更新或执行一键覆盖更新。"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Border>
                            <TextBlock Text="关于" Style="{StaticResource SettingsGroupTitleStyle}" Margin="2,20,0,10" />
                            <Border Style="{StaticResource SettingsListContainerStyle}" HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="GestureClip 是本地优先的 Windows 剪贴板历史与右键手势工具。剪贴板文本存储在本机 SQLite，日志不记录剪贴板正文。MVP 不保证控制管理员权限窗口，如需控制管理员窗口，请以管理员身份运行 GestureClip。" />
                                    <Border Style="{StaticResource SoftStatusCardStyle}" Margin="0,14,0,0">
                                        <StackPanel>
                                            <TextBlock Text="当前版本" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding AppVersionText}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushPrimaryBright}"
                                                       Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <WrapPanel Margin="0,14,0,0">
                                        <Button Content="检查更新"
                                                Style="{StaticResource SettingsSecondaryActionButtonStyle}"
                                                Click="CheckUpdateButton_Click" />
                                        <Button Content="一键覆盖更新"
                                                Style="{StaticResource SettingsPrimaryActionButtonStyle}"
                                                Click="UpdateButton_Click" />
                                        <Button Content="打开 Release 页面"
                                                Style="{StaticResource SettingsSecondaryActionButtonStyle}"
                                                Click="OpenReleaseButton_Click" />
                                    </WrapPanel>
                                    <TextBlock Text="检查更新会比较当前版本和 GitHub Latest Release。网络不佳时会自动尝试：系统代理 → 直连 → 镜像加速。一键覆盖更新下载最新 zip 后覆盖重启，本地历史与设置保留。仍失败时可打开 Release 手动下载。"
                                               Style="{StaticResource MutedTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="更新日志" Style="{StaticResource SettingsGroupTitleStyle}" Margin="2,20,0,10" />
                            <Border Style="{StaticResource SettingsListContainerStyle}" HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <TextBlock Text="本地 CHANGELOG（发布包会附带）。也可以用“检查更新”查看 GitHub 最新 Release Notes。"
                                               Style="{StaticResource MutedTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10" />
                                    <TextBox Text="{Binding ChangelogText, Mode=OneWay}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             MinHeight="280"
                                             MaxHeight="480"
                                             Padding="12" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                </TabControl>
            </Border>

            <!-- Collapse rail toggle on content's right edge -->
            <Button x:Name="ToggleRailButton"
                    Grid.Column="1"
                    Width="20"
                    Height="52"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,6,0"
                    Panel.ZIndex="30"
                    ToolTip="折叠 / 展开右侧栏"
                    Click="ToggleRailButton_Click"
                    Focusable="False"
                    Cursor="Hand"
                    Background="{DynamicResource BrushGlassCard}"
                    BorderBrush="{DynamicResource BrushBorder}"
                    BorderThickness="1"
                    Padding="0">
                <Button.Template>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="10"
                                Width="20"
                                Height="52"
                                SnapsToDevicePixels="True">
                            <TextBlock x:Name="Chevron"
                                       Text="‹"
                                       FontSize="13"
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"
                                       Foreground="{DynamicResource BrushTextSecondary}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BrushControlHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Button.Template>
            </Button>

            <Border x:Name="RightRailBorder"
                    Grid.Column="2"
                    Background="{DynamicResource BrushRailBackground}"
                    BorderBrush="{DynamicResource BrushSeparator}"
                    BorderThickness="1,0,0,0"
                    ClipToBounds="True"
                    Focusable="False"
                    Padding="16,20,16,16">
                <Grid Focusable="False">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Focusable="False"
                                  FocusVisualStyle="{x:Null}"
                                  ClipToBounds="True">
                        <StackPanel Focusable="False">
                            <Border Background="{DynamicResource BrushGlassCard}"
                                    BorderBrush="{DynamicResource BrushBorder}"
                                    BorderThickness="1"
                                    CornerRadius="12"
                                    Padding="12"
                                    Margin="0,0,0,18"
                                    Focusable="False">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="36" Height="36" CornerRadius="10"
                                            Background="{DynamicResource BrushPrimaryBright}">
                                        <TextBlock Text="GC" Foreground="White" FontSize="12" FontWeight="SemiBold"
                                                   HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <StackPanel Margin="10,0,0,0" VerticalAlignment="Center">
                                        <TextBlock Text="GestureClip" FontSize="14" FontWeight="SemiBold"
                                                   LineHeight="18"
                                                   Foreground="{DynamicResource BrushTextPrimary}" />
                                        <TextBlock Text="本地优先 · 剪贴板与手势" FontSize="11"
                                                   LineHeight="15"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   Margin="0,2,0,0" />
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock Text="运行状态" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextMuted}"
                                       Margin="2,0,0,8" />
                            <Grid MinHeight="40" Margin="0,0,0,4">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock Text="剪贴板记录" FontWeight="Medium" FontSize="13" />
                                    <TextBlock Text="{Binding ClipboardCaptureStatusText}"
                                               Style="{StaticResource MutedTextStyle}"
                                               FontSize="12" Margin="0,2,0,0" />
                                </StackPanel>
                                <Ellipse Grid.Column="1" Width="8" Height="8"
                                         Fill="{DynamicResource BrushSuccess}"
                                         VerticalAlignment="Center" />
                            </Grid>
                            <Border BorderBrush="{DynamicResource BrushSeparator}"
                                    BorderThickness="0,0,0,1"
                                    Padding="0,0,0,12"
                                    Margin="0,0,0,12">
                                <Grid MinHeight="40">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="鼠标手势" FontWeight="Medium" FontSize="13" />
                                        <TextBlock Text="{Binding GestureStatusText}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   FontSize="12" Margin="0,2,0,0" />
                                    </StackPanel>
                                    <Ellipse Grid.Column="1" Width="8" Height="8"
                                             Fill="{DynamicResource BrushSuccess}"
                                             VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <TextBlock Text="快捷" FontSize="11" FontWeight="SemiBold"
                                       Foreground="{DynamicResource BrushTextMuted}"
                                       Margin="2,0,0,10" />
                            <Grid Margin="0,0,0,10" MinHeight="28">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="剪贴板历史" FontSize="13" VerticalAlignment="Center" />
                                <Border Grid.Column="1" Style="{StaticResource KeyboardKeyStyle}">
                                    <TextBlock Text="{Binding OpenClipboardHotkeyText}"
                                               FontSize="11" LineHeight="14"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               FontFamily="Cascadia Mono, Consolas, Segoe UI" />
                                </Border>
                            </Grid>
                            <Grid Margin="0,0,0,14" MinHeight="28">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="快捷动作" FontSize="13" VerticalAlignment="Center" />
                                <Border Grid.Column="1" Style="{StaticResource KeyboardKeyStyle}">
                                    <TextBlock Text="{Binding OpenQuickActionHotkeyText}"
                                               FontSize="11" LineHeight="14"
                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                               TextAlignment="Center"
                                               FontFamily="Cascadia Mono, Consolas, Segoe UI" />
                                </Border>
                            </Grid>

                            <Border BorderBrush="{DynamicResource BrushSeparator}"
                                    BorderThickness="0,1,0,0"
                                    Padding="0,12,0,0">
                                <StackPanel>
                                    <TextBlock Text="当前预设" FontSize="11"
                                               Foreground="{DynamicResource BrushTextMuted}" />
                                    <TextBlock Text="{Binding SelectedGesturePresetOption.DisplayName}"
                                               FontSize="13" FontWeight="Medium"
                                               Margin="0,4,0,0" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>

                    <Border Grid.Row="1"
                            Background="{DynamicResource BrushHintYellow}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1"
                            CornerRadius="10"
                            Padding="12,10"
                            Margin="0,12,0,0"
                            Focusable="False">
                        <TextBlock Text="右键画线执行动作。数据默认保存在本机。"
                                   FontSize="11" LineHeight="16"
                                   Foreground="{DynamicResource BrushTextSecondary}"
                                   TextWrapping="Wrap" />
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
    </Border>
</Window>


