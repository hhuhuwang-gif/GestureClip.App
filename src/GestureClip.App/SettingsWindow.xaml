                <TabItem Header="隐私">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  ClipToBounds="True">
                        <StackPanel Margin="28,24,36,40" HorizontalAlignment="Stretch">
                            <Border x:Name="PrivacyPageIntro" Style="{StaticResource SettingsIntroCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="隐私与屏蔽名单" Style="{StaticResource SettingsIntroTitleStyle}" />
