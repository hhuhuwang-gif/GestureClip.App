                                               Style="{StaticResource SettingsPageSubtitleStyle}" />
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="SectionPrivacyAdd" Text="添加进程" Style="{StaticResource SettingsGroupTitleStyle}" />
                            <Border Style="{StaticResource SettingsListContainerStyle}" HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <Border Style="{StaticResource SettingsFormRowStyle}" BorderThickness="0,0,0,1">
                                        <Grid HorizontalAlignment="Stretch">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" MinWidth="160" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBox Text="{Binding NewBlacklistProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     MinHeight="36"
                                                     VerticalContentAlignment="Center"
                                                     HorizontalAlignment="Stretch"
                                                     Margin="0,0,12,0"
                                                     ToolTip="例如 notepad.exe" />
