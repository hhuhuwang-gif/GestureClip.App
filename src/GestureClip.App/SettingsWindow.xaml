                                                    <TextBlock Text="高风险阈值" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                    <TextBox Width="72"
                                                             Text="{Binding WorkstationOverworkHighRiskAfterHours, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
