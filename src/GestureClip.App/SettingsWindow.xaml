<Window x:Class="GestureClip.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GestureClip.App.Controls"
        Title="GestureClip 设置"
        Icon="Assets/GestureClip.ico"
        Width="1360"
        Height="740"
        MinWidth="1080"
        MinHeight="560"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        Foreground="{DynamicResource BrushTextPrimary}">
    <Window.Resources>
        <Style x:Key="SettingsIntroCardStyle" TargetType="Border" BasedOn="{StaticResource GlassCardStyle}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,0,14" />
            <Setter Property="Background" Value="#FBFBFD" />
            <Setter Property="BorderBrush" Value="#0F000000" />
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="SettingsIntroTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SectionTitleStyle}">
            <Setter Property="FontSize" Value="22" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="SettingsFormRowStyle" TargetType="Border" BasedOn="{StaticResource SettingRowStyle}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="SettingsCompactIntroCardStyle" TargetType="Border" BasedOn="{StaticResource SettingsIntroCardStyle}">
            <Setter Property="Padding" Value="14" />
            <Setter Property="Margin" Value="0,0,0,10" />
        </Style>
        <Style x:Key="SettingsCompactFormRowStyle" TargetType="Border" BasedOn="{StaticResource SettingsFormRowStyle}">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="FeatureMapItemCardStyle" TargetType="Border" BasedOn="{StaticResource GlassCardStyle}">
            <Setter Property="Padding" Value="16" />
            <Setter Property="Margin" Value="0,0,12,12" />
            <Setter Property="MinHeight" Value="132" />
            <Setter Property="Background" Value="#FBFBFD" />
            <Setter Property="BorderBrush" Value="#0F000000" />
            <Setter Property="Effect" Value="{x:Null}" />
        </Style>
        <Style x:Key="SettingsActionButtonBaseStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="120" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsSecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="120" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsPrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="128" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsDangerActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="128" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsCompactActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="108" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsGestureDirectionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsGestureTemplateButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="168" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsDangerZoneStyle" TargetType="Border" BasedOn="{StaticResource SettingsFormRowStyle}">
            <Setter Property="Background" Value="#FFF2F2" />
            <Setter Property="BorderBrush" Value="#22FF3B30" />
        </Style>
        <Style x:Key="SettingsCompactDangerZoneStyle" TargetType="Border" BasedOn="{StaticResource SettingsDangerZoneStyle}">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
    </Window.Resources>
    <Border CornerRadius="20"
            Background="{DynamicResource BrushAppBackground}"
            BorderBrush="#18000000"
            BorderThickness="1"
            ClipToBounds="True"
            MouseLeftButtonDown="WindowBackground_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="48" ShadowDepth="8" Opacity="0.16" Direction="270" />
        </Border.Effect>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="4,2,4,14" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel DockPanel.Dock="Left"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="2,0,16,0">
                <!-- 用户约定：红=关闭，黄=放大，绿=缩小 -->
                <Button Style="{StaticResource TrafficLightButtonStyle}"
                        Background="{DynamicResource BrushTrafficClose}"
                        ToolTip="关闭到托盘"
                        Click="CloseButton_Click" />
                <Button Style="{StaticResource TrafficLightButtonStyle}"
                        Background="{DynamicResource BrushTrafficYellow}"
                        ToolTip="放大窗口"
                        Click="MaximizeButton_Click" />
                <Button Style="{StaticResource TrafficLightButtonStyle}"
                        Background="{DynamicResource BrushTrafficGreen}"
                        ToolTip="缩小窗口"
                        Click="MinimizeButton_Click" />
            </StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center">
                    <TextBlock Text="GestureClip"
                               FontSize="22"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushTextPrimary}" />
                    <TextBlock Text="剪贴板 · 手势 · 本地办公加速"
                               Margin="0,3,0,0"
                               FontSize="12"
                               Foreground="{DynamicResource BrushTextSecondary}" />
                </StackPanel>
                <Border Grid.Column="1"
                        Height="32"
                        CornerRadius="10"
                        Background="#14FFFFFF"
                        BorderBrush="#12000000"
                        BorderThickness="1"
                        VerticalAlignment="Center">
                    <TextBlock Text="搜索设置稍后开放"
                               VerticalAlignment="Center"
                               Margin="12,0"
                               FontSize="12"
                               Foreground="{DynamicResource BrushTextMuted}" />
                </Border>
            </Grid>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="248" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource GlassPanelStyle}" Padding="0" CornerRadius="18">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="188" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Background="{DynamicResource BrushSidebarBackground}"
                            CornerRadius="18,0,0,18" />
                    <TabControl Grid.Column="0"
                                Grid.ColumnSpan="2"
                                TabStripPlacement="Left"
                                Background="Transparent"
                                BorderThickness="0"
                                Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource GlassTabItemStyle}">
                        <Setter Property="Margin" Value="0,0,0,2" />
                        <Setter Property="MinWidth" Value="168" />
                    </Style>
                </TabControl.Resources>

                <TabItem Header="首页">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="18">
                            <Border x:Name="HomePageIntro" Style="{StaticResource SettingsIntroCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="总览" Style="{StaticResource SettingsIntroTitleStyle}" />
                                    <TextBlock Text="先确认权限、数据位置和运行状态。这里不改变功能，只帮你看 GestureClip 当前是否正常。"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Border>
                            <Border x:Name="SmartPasteRecommendationCard"
                                    Padding="20"
                                    Margin="0,0,0,16"
                                    Background="#EEF6FF"
                                    BorderBrush="{DynamicResource BrushPrimaryBright}"
                                    BorderThickness="2"
                                    CornerRadius="20">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="智能粘贴"
                                                       FontSize="22"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushTextPrimary}" />
                                            <Border Style="{StaticResource StatusBadgeStyle}"
                                                    Margin="12,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="推荐开启"
                                                           Foreground="{DynamicResource BrushPrimary}"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="下划手势自动聪明粘贴"
                                                   FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{DynamicResource BrushPrimaryBright}" />
                                        <TextBlock Text="用下划手势粘贴时，GestureClip 会看你正在用的软件，自动选择普通粘贴、纯文本粘贴或干净粘贴。"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="0,8,24,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              Content="开启智能粘贴（推荐）"
                                              Margin="24,0,0,0"
                                              VerticalAlignment="Center"
                                              IsChecked="{Binding IsSmartPasteEnabled, Mode=TwoWay}" />
                                </Grid>
                            </Border>
                            <Border x:Name="FeatureMapCard"
                                    Padding="20"
                                    Margin="0,0,0,16"
                                    Background="#F7FBFF"
                                    BorderBrush="#BBD7FF"
                                    BorderThickness="1"
                                    CornerRadius="20">
                                <StackPanel>
                                    <TextBlock Text="我能帮你做什么"
                                               FontSize="22"
                                               FontWeight="SemiBold"
                                               Foreground="{DynamicResource BrushTextPrimary}" />
                                    <TextBlock Text="先看这 6 个入口，不用猜功能藏在哪里。"
                                               Style="{StaticResource MutedTextStyle}"
                                               Margin="0,6,0,16"
                                               TextWrapping="Wrap" />
                                    <UniformGrid Columns="2" Margin="0,0,-12,-12">
                                        <Border Style="{StaticResource FeatureMapItemCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="智能粘贴"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrushTextPrimary}" />
                                                <TextBlock Text="在微信/飞书/Word/浏览器里粘贴时自动选合适方式。"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Margin="0,8,0,0"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="用法：下划手势 D；首页可开关“开启智能粘贴（推荐）”。"
                                                           Foreground="{DynamicResource BrushPrimaryBright}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,10,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource FeatureMapItemCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="鼠标手势"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrushTextPrimary}" />
                                                <TextBlock Text="按住右键划一下，不用找菜单。"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Margin="0,8,0,0"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="入口：设置 → 手势，可改上划复制、下划粘贴、左划后退、右划前进。"
                                                           Foreground="{DynamicResource BrushPrimaryBright}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,10,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource FeatureMapItemCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="左键增强动作"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrushTextPrimary}" />
                                                <TextBlock Text="画手势时点一下左键，触发增强版动作。"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Margin="0,8,0,0"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="入口：设置 → 动作绑定 → 左键增强动作（可设置）。"
                                                           Foreground="{DynamicResource BrushPrimaryBright}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,10,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource FeatureMapItemCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="剪贴板历史"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrushTextPrimary}" />
                                                <TextBlock Text="找回刚复制过的文字/图片。"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Margin="0,8,0,0"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="入口：设置 → 剪贴板，开启历史和快捷入口。"
                                                           Foreground="{DynamicResource BrushPrimaryBright}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,10,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource FeatureMapItemCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="快捷入口 / 系统工具"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrushTextPrimary}" />
                                                <TextBlock Text="快速打开常用工具，不用翻开始菜单。"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Margin="0,8,0,0"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="入口：设置 → 快捷入口 / 系统，按需开启。"
                                                           Foreground="{DynamicResource BrushPrimaryBright}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,10,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                        <Border Style="{StaticResource FeatureMapItemCardStyle}">
                                            <StackPanel>
                                                <TextBlock Text="本地安全"
                                                           FontSize="17"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrushTextPrimary}" />
                                                <TextBlock Text="数据留在本机，不上云。"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Margin="0,8,0,0"
                                                           TextWrapping="Wrap" />
                                                <TextBlock Text="入口：设置 → 数据，可查看数据位置和清理方式。"
                                                           Foreground="{DynamicResource BrushPrimaryBright}"
                                                           FontWeight="SemiBold"
                                                           Margin="0,10,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>
                                </StackPanel>
                            </Border>
                        <GroupBox Header="首页" Margin="0" Padding="12">
                            <StackPanel>
                                <Border Style="{StaticResource SettingsFormRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="132" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="权限状态" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <Border Grid.Column="1" Style="{StaticResource StatusBadgeStyle}" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding PermissionStatusText}" Foreground="{DynamicResource BrushPrimary}" FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsFormRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="132" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="数据库路径" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Text="{Binding DatabasePath, Mode=OneWay}" IsReadOnly="True" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsFormRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="132" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="日志目录" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Text="{Binding LogDirectory, Mode=OneWay}" IsReadOnly="True" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingsFormRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="132" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="运行状态" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" Fill="#22C55E" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding StartupStatus}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding HotkeyStatusText}" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="剪贴板">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="14">
                            <Border x:Name="ClipboardPageIntro" Style="{StaticResource SettingsCompactIntroCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="剪贴板设置" Style="{StaticResource SettingsIntroTitleStyle}" />
                                    <TextBlock Text="控制是否记录剪贴板历史、热键怎么打开、历史保留多久。清理按钮会明确写出影响范围。"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Border>
                            <GroupBox Header="剪贴板" Padding="10">
                                <StackPanel>
                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="记录状态" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <CheckBox Grid.Column="1" Content="启用剪贴板记录" IsChecked="{Binding ClipboardCaptureEnabled, Mode=TwoWay}" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="打开历史热键" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1">
                                                <TextBox Width="190"
                                                         HorizontalAlignment="Left"
                                                         Text="{Binding OpenClipboardHotkeyText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <TextBlock Text="{Binding HotkeyStatusText}" Margin="0,6,0,0" Style="{StaticResource MutedTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="快捷动作热键" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1">
                                                <TextBox Width="190"
                                                         HorizontalAlignment="Left"
                                                         Text="{Binding OpenQuickActionHotkeyText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <TextBlock Text="默认 Ctrl + Shift + Q。支持 Ctrl/Alt/Shift + 字母或数字，失焦后生效。"
                                                           Margin="0,6,0,0"
                                                           Style="{StaticResource MutedTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="数据与清理" Padding="10" Margin="0,10,0,0">
                                <StackPanel>
                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="历史数量" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="{Binding ClipboardItemCountText}" VerticalAlignment="Center" />
                                                <Button Content="刷新"
                                                        Style="{StaticResource SettingsSecondaryActionButtonStyle}"
                                                        Margin="14,0,0,0"
                                                        Command="{Binding RefreshClipboardStatsCommand}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="保留策略" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="最大保存数量" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                <ComboBox Width="110"
                                                          Margin="0,0,22,0"
                                                          ItemsSource="{Binding ClipboardMaxItemOptions}"
                                                          SelectedItem="{Binding ClipboardMaxItems, Mode=TwoWay}" />
                                                <TextBlock Text="保留天数" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                <ComboBox Width="110"
                                                          ItemsSource="{Binding ClipboardRetentionOptions}"
                                                          SelectedItem="{Binding SelectedClipboardRetentionOption, Mode=TwoWay}"
                                                          DisplayMemberPath="Label" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingsCompactDangerZoneStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="危险操作" FontWeight="SemiBold" Foreground="#B42318" />
                                                <TextBlock Text="会影响剪贴板历史，执行前请确认。"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                            <WrapPanel Grid.Column="1">
                                                <Button Content="清空非固定项"
                                                        Style="{StaticResource SettingsSecondaryActionButtonStyle}"
                                                        Command="{Binding ClearUnpinnedClipboardItemsCommand}" />
                                                <Button Content="清空全部历史"
                                                        Style="{StaticResource SettingsDangerActionButtonStyle}"
                                                        Command="{Binding ClearAllClipboardItemsCommand}" />
                                                <Button Content="立即执行清理"
                                                        Style="{StaticResource SettingsPrimaryActionButtonStyle}"
                                                        Command="{Binding ApplyClipboardCleanupCommand}" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="手势">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="14">
                            <Border x:Name="GesturePageIntro" Style="{StaticResource SettingsCompactIntroCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="鼠标手势设置" Style="{StaticResource SettingsIntroTitleStyle}" />
                                    <TextBlock Text="先开关手势，再选择触发方式。新手建议保留鼠标右键，其他触发方式需要时再开。"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Border>
                            <GroupBox Header="手势" Padding="10">
                                <StackPanel>
                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <StackPanel>
                                            <TextBlock Text="按住右键，往一个方向划一下，松开右键就会执行动作。"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="上划复制，下划粘贴，左划后退，右划前进，上下划回车，下上划 Esc。"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="智能粘贴"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="推荐开关已放到首页顶部"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="同一个下划手势会根据当前软件自动选择普通粘贴、纯文本粘贴或干净粘贴；打开设置就能在首页看到推荐卡。"
                                                            TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <StackPanel>
                                            <TextBlock Text="打工人等级" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding WorkerLevelText}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding WorkerXpText}" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0" />
                                            <WrapPanel Margin="0,12,0,0">
                                                <CheckBox Content="显示升级弹窗" Margin="0,0,18,0" IsChecked="{Binding WorkerLevelShowLevelUpPopup, Mode=TwoWay}" />
                                                <CheckBox Content="HUD 显示等级" Margin="0,0,18,0" IsChecked="{Binding WorkerLevelShowLevelInHud, Mode=TwoWay}" />
                                                <CheckBox Content="HUD 趣味战报" Margin="0,0,18,0" IsChecked="{Binding HudFunTextEnabled, Mode=TwoWay}" />
                                                <CheckBox Content="HUD 状态等级" IsChecked="{Binding HudStatusLevelEnabled, Mode=TwoWay}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="常用开关" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <WrapPanel Grid.Column="1">
                                                <CheckBox Content="启用鼠标手势"
                                                          Margin="0,0,20,0"
                                                          IsChecked="{Binding GestureEnabled, Mode=TwoWay}" />
                                                <CheckBox Content="显示划线和提示"
                                                          Margin="0,0,20,0"
                                                          IsChecked="{Binding GestureShowOverlay, Mode=TwoWay}" />
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <CheckBox Content="开启智能粘贴（推荐）"
                                                              IsChecked="{Binding IsSmartPasteEnabled, Mode=TwoWay}"
                                                              ToolTip="和首页推荐卡是同一个开关" />
                                                    <TextBlock Text="同首页推荐卡"
                                                               Style="{StaticResource MutedTextStyle}"
                                                               Margin="8,2,0,0" />
                                                </StackPanel>
                                            </WrapPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="使用模式" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="1"
                                                      Width="220"
                                                      HorizontalAlignment="Left"
                                                      ItemsSource="{Binding GesturePresetOptions}"
                                                      SelectedItem="{Binding SelectedGesturePresetOption, Mode=TwoWay}"
                                                      DisplayMemberPath="DisplayName" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="划线颜色" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="1"
                                                      Width="220"
                                                      HorizontalAlignment="Left"
                                                      ItemsSource="{Binding GestureStrokeColorOptions}"
                                                      SelectedItem="{Binding SelectedGestureStrokeColorOption, Mode=TwoWay}"
                                                      DisplayMemberPath="DisplayName" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </GroupBox>

                            <Expander Header="高级设置"
                                      Margin="0,10,0,0"
                                      IsExpanded="False">
                                <StackPanel Margin="0,8,0,0">
                                    <GroupBox Header="触发方式" Padding="10">
                                        <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="当前启用" FontWeight="SemiBold" Foreground="{DynamicResource BrushPrimaryBright}" />
                                            <TextBlock Text="：" FontWeight="SemiBold" Foreground="{DynamicResource BrushPrimaryBright}" />
                                            <TextBlock Text="{Binding EnabledGestureTriggerSummary}" FontWeight="SemiBold" Foreground="{DynamicResource BrushPrimaryBright}" />
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding GestureTriggerModes}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource BrushGlass}"
                                                            BorderBrush="{DynamicResource BrushBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="14"
                                                            Padding="12,8"
                                                            Margin="0,0,0,8">
                                                        <DockPanel>
                                                            <TextBlock DockPanel.Dock="Right"
                                                                       Text="{Binding Status}"
                                                                       Foreground="{DynamicResource BrushPrimaryBright}"
                                                                       FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontWeight="SemiBold" />
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Header="高级手势开关" Padding="10" Margin="0,10,0,0">
                                        <StackPanel>
                                            <TextBlock Text="触发方式只允许右键、中键、侧键和屏幕边缘；左键点击可以作为执行动作，但不是手势触发键。"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,0,0,8"
                                                       TextWrapping="Wrap" />
                                            <CheckBox Content="启用鼠标右键手势（默认推荐）" IsChecked="{Binding GestureRightButtonEnabled, Mode=TwoWay}" />
                                            <CheckBox Content="启用鼠标中键手势" Margin="0,8,0,0" IsChecked="{Binding GestureMiddleButtonEnabled, Mode=TwoWay}" />
                                            <CheckBox Content="启用鼠标侧键 1 手势" Margin="0,8,0,0" IsChecked="{Binding GestureXButton1Enabled, Mode=TwoWay}" />
                                            <CheckBox Content="启用鼠标侧键 2 手势" Margin="0,8,0,0" IsChecked="{Binding GestureXButton2Enabled, Mode=TwoWay}" />
                                            <CheckBox Content="启用手势调试日志" Margin="0,8,0,0" IsChecked="{Binding GestureDebugEnabled, Mode=TwoWay}" />
                                            <CheckBox Content="启用 UD 关闭窗口手势" Margin="0,8,0,0" IsChecked="{Binding GestureCloseWindowEnabled, Mode=TwoWay}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <TextBlock Text="划多远才算手势" VerticalAlignment="Center" />
                                                <TextBox Width="70" Margin="12,0,0,0" Text="{Binding GestureTriggerThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="像素" Margin="6,0,0,0" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Header="屏幕角落和边缘" Padding="10" Margin="0,10,0,0">
                                        <StackPanel>
                                            <CheckBox Content="启用屏幕角落触发"
                                                      IsChecked="{Binding EdgeTriggerEnabled, Mode=TwoWay}" />
                                            <TextBlock Text="把鼠标移到屏幕角落或边缘时执行动作。默认关闭，不需要就不用管。"
                                               Style="{StaticResource MutedTextStyle}"
                                               Margin="0,8,0,10"
                                               TextWrapping="Wrap" />
                                    <WrapPanel Margin="0,0,0,12">
                                        <Button Content="浏览器增强"
                                                Style="{StaticResource SettingsSecondaryActionButtonStyle}"
                                                Command="{Binding ApplyBrowserEdgePresetCommand}" />
                                        <Button Content="系统控制"
                                                Style="{StaticResource SettingsSecondaryActionButtonStyle}"
                                                Command="{Binding ApplySystemEdgePresetCommand}" />
                                        <Button Content="剪贴板增强"
                                                Style="{StaticResource SettingsSecondaryActionButtonStyle}"
                                                Command="{Binding ApplyClipboardEdgePresetCommand}" />
                                    </WrapPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="触发范围" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Text="{Binding EdgeTriggerHotZoneSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2" Text="停留多久" Margin="10,0,0,0" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="3" Text="{Binding EdgeTriggerDwellMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="4" Text="防误触间隔" Margin="10,0,0,0" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="5" Text="{Binding EdgeTriggerCooldownMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="6" Text="滑多远触发" Margin="10,0,0,0" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="7" Text="{Binding EdgeTriggerSlideThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="左上角" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerTopLeftAction, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="1" Text="右上角" Margin="0,8,0,0" VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="1"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerTopRightAction, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="2" Text="右下角" Margin="0,8,0,0" VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="2"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerBottomRightAction, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="3" Text="左下角" Margin="0,8,0,0" VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="3"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerBottomLeftAction, Mode=TwoWay}" />
                                    </Grid>

                                    <TextBlock Text="边缘滑动"
                                               FontWeight="SemiBold"
                                               Margin="0,16,0,8" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="210" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <CheckBox Content="左边缘向右滑"
                                                  IsChecked="{Binding EdgeTriggerSlideLeftEnabled, Mode=TwoWay}" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerSlideLeftAction, Mode=TwoWay}" />
                                        <CheckBox Grid.Row="1"
                                                  Content="右边缘向左滑"
                                                  Margin="0,8,0,0"
                                                  IsChecked="{Binding EdgeTriggerSlideRightEnabled, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="1"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerSlideRightAction, Mode=TwoWay}" />
                                        <CheckBox Grid.Row="2"
                                                  Content="上边缘向下滑"
                                                  Margin="0,8,0,0"
                                                  IsChecked="{Binding EdgeTriggerSlideTopEnabled, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="2"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerSlideTopAction, Mode=TwoWay}" />
                                        <CheckBox Grid.Row="3"
                                                  Content="下边缘向上滑"
                                                  Margin="0,8,0,0"
                                                  IsChecked="{Binding EdgeTriggerSlideBottomEnabled, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="3"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerSlideBottomAction, Mode=TwoWay}" />
                                    </Grid>
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>
                            </Expander>

                            <Expander Header="手势测试（需要时展开）" Margin="0,10,0,0" IsExpanded="False">
                                <Border Padding="10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Hook 状态" />
                                    <TextBlock Grid.Column="1" Text="{Binding GestureHookStatus}" />
                                    <TextBlock Grid.Row="1" Text="当前状态" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GestureRuntimeStateText}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="2" Text="最近手势码" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastGesturePattern}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="3" Text="最近 Action" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastGestureAction}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="4" Text="最近错误" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastGestureError}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="5" Text="最近事件" Margin="0,6,0,0" />
                                    <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding LastGestureEventTime}" />
                                        <TextBlock Text="{Binding GestureEnvironmentStatus}" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="6" Text="边缘来源" Margin="0,10,0,0" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding EdgeTriggerLastSource}" Margin="0,10,0,0" />
                                    <TextBlock Grid.Row="7" Text="边缘位置" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding EdgeTriggerLastPosition}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="8" Text="边缘动作" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding EdgeTriggerLastAction}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="9" Text="边缘状态" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding EdgeTriggerLastReason}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="10" Text="边缘冷却" Margin="0,6,0,0" />
                                    <StackPanel Grid.Row="10" Grid.Column="1" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding EdgeTriggerCooldownText}" />
                                        <TextBlock Text="{Binding EdgeTriggerLastEventTime}" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>
                                </Border>
                            </Expander>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="动作绑定">
                    <ScrollViewer x:Name="GestureBindingPageScrollViewer"
                                  VerticalScrollBarVisibility="Auto"
                                  CanContentScroll="False">
                        <StackPanel Margin="18">
                                <Border x:Name="GestureBindingListPanel"
                                        Style="{StaticResource GlassCardStyle}"
                                        Padding="20">
                                    <StackPanel>
                                        <TextBlock Text="动作绑定"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="先看卡片：手势怎么画、现在绑定什么动作、按住右键画完会发生什么。要修改就点卡片里的“更换动作”，要移除就点同一张卡片里的“删除”。R+L 组合手势表示按住右键时点击左键。"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,6,0,14" />

                                        <Border Background="#FFF7ED"
                                                BorderBrush="#FED7AA"
                                                BorderThickness="1"
                                                CornerRadius="18"
                                                Padding="14"
                                                Margin="0,0,0,14">
                                            <StackPanel>
                                                <TextBlock Text="左键增强动作（可设置）"
                                                           FontSize="16"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="用法：按住右键开始画手势时，再点一下左键，会执行这里配置的增强动作，而不是普通动作。例如默认：下划+左键=智能干净粘贴，上划+左键=全选。"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,6,0,10" />
                                                <ItemsControl ItemsSource="{Binding LeftButtonEnhancedBindings}">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <Border Style="{StaticResource SoftStatusCardStyle}"
                                                                    Margin="0,0,0,8"
                                                                    Padding="12">
                                                                <Grid>
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="90" />
                                                                        <ColumnDefinition Width="12" />
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="Auto" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <StackPanel>
                                                                        <TextBlock Text="手势码" FontSize="11" Style="{StaticResource MutedTextStyle}" />
                                                                        <TextBox Text="{Binding Pattern, UpdateSourceTrigger=LostFocus}"
                                                                                 Width="80"
                                                                                 Height="34"
                                                                                 Margin="0,4,0,0" />
                                                                    </StackPanel>
                                                                    <StackPanel Grid.Column="2">
                                                                        <TextBlock Text="增强动作" FontSize="11" Style="{StaticResource MutedTextStyle}" />
                                                                        <ComboBox ItemsSource="{Binding ActionOptions}"
                                                                                  SelectedValue="{Binding Action, Mode=TwoWay}"
                                                                                  SelectedValuePath="Action"
                                                                                  DisplayMemberPath="DisplayName"
                                                                                  Height="34"
                                                                                  Margin="0,4,0,0" />
                                                                        <TextBlock Text="{Binding SummaryText}"
                                                                                   Style="{StaticResource MutedTextStyle}"
                                                                                   Margin="0,6,0,0"
                                                                                   FontSize="12" />
                                                                    </StackPanel>
                                                                    <Button Grid.Column="3"
                                                                            Content="删除"
                                                                            Width="64"
                                                                            Height="32"
                                                                            Margin="10,18,0,0"
                                                                            VerticalAlignment="Top"
                                                                            Command="{Binding DeleteCommand}" />
                                                                </Grid>
                                                            </Border>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                                <WrapPanel Margin="0,4,0,0">
                                                    <Button Content="添加一条"
                                                            Style="{StaticResource SettingsSecondaryActionButtonStyle}"
                                                            Command="{Binding AddLeftButtonEnhancedBindingCommand}" />
                                                    <Button Content="恢复默认"
                                                            Style="{StaticResource SettingsSecondaryActionButtonStyle}"
                                                            Command="{Binding ResetLeftButtonEnhancedBindingsCommand}" />
                                                </WrapPanel>
                                                <TextBlock Text="{Binding LeftButtonEnhancedStatusText}"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Margin="0,8,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>

                                        <Border x:Name="RecommendedGesturePanel"
                                                Background="#FFF7ED"
                                                BorderBrush="#FED7AA"
                                                BorderThickness="1"
                                                CornerRadius="18"
                                                Padding="14"
                                                Margin="0,0,0,14">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <StackPanel>
                                                        <TextBlock Text="推荐给新手的 3 个手势"
                                                                   FontSize="16"
                                                                   FontWeight="SemiBold"
                                                                   Foreground="{DynamicResource BrushTextPrimary}" />
                                                        <TextBlock Text="先用这 3 个就够了，之后可以自己修改。已有的自定义手势不会被删除；如果某个推荐手势已经存在，会自动跳过。"
                                                                   Style="{StaticResource MutedTextStyle}"
                                                                   TextWrapping="Wrap"
                                                                   Margin="0,5,0,0" />
                                                    </StackPanel>
                                                    <Button Grid.Column="1"
                                                            Content="一键添加推荐手势"
                                                            MinWidth="0"
                                                            Width="150"
                                                            Height="36"
                                                            Margin="16,0,0,0"
