                                                      Content="显示工位小熊入口和统计"
                                                      IsChecked="{Binding WorkstationEnabled, Mode=TwoWay}" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
