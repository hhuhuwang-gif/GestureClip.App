                                    </Border>
                                    <Border Padding="20,12" BorderThickness="0">
                                        <TextBlock Text="添加进程名后，会按进程阻止剪贴板记录和鼠标手势。"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   FontSize="12"
                                                   TextWrapping="Wrap" />
                                    </Border>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="SectionPrivacyList" Text="屏蔽名单" Style="{StaticResource SettingsGroupTitleStyle}" Margin="2,28,0,12" />
                            <Border Style="{StaticResource SettingsListContainerStyle}" HorizontalAlignment="Stretch">
                                <ItemsControl ItemsSource="{Binding AppBlacklistItems}"
                                              HorizontalContentAlignment="Stretch">
                                    <ItemsControl.ItemContainerStyle>
                                        <Style TargetType="ContentPresenter">
                                            <Setter Property="HorizontalAlignment" Value="Stretch" />
                                        </Style>
                                    </ItemsControl.ItemContainerStyle>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Style="{StaticResource SettingsFormRowStyle}"
                                                    Padding="20,12"
                                                    MinHeight="52"
                                                    HorizontalAlignment="Stretch">
                                                <Grid HorizontalAlignment="Stretch">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" MinWidth="120" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Text="{Binding ProcessName}"
                                                               FontSize="13"
                                                               FontWeight="Medium"
                                                               VerticalAlignment="Center"
                                                               TextTrimming="CharacterEllipsis"
                                                               TextWrapping="NoWrap"
                                                               Margin="0,0,16,0" />
                                                    <CheckBox Grid.Column="1"
                                                              Content="剪贴板"
                                                              Margin="0,0,20,0"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding BlockClipboard, Mode=TwoWay}" />
                                                    <CheckBox Grid.Column="2"
                                                              Content="手势"
                                                              Margin="0,0,20,0"
                                                              VerticalAlignment="Center"
                                                              IsChecked="{Binding BlockGesture, Mode=TwoWay}" />
                                                    <Button Grid.Column="3"
                                                            Content="删除"
                                                            Style="{StaticResource SettingsDangerTextButtonStyle}"
                                                            MinWidth="72"
                                                            Height="32"
                                                            Padding="12,0"
                                                            VerticalAlignment="Center"
                                                            Command="{Binding DeleteCommand}" />
                                                </Grid>
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="自启">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
