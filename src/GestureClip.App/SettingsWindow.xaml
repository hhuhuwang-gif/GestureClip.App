                                                  DisplayMemberPath="DisplayName"
                                                              SelectedItem="{Binding EdgeTriggerSlideRightAction, Mode=TwoWay, Converter={StaticResource GestureActionOptionConverter}}" />
                                        <CheckBox Grid.Row="2"
