                                                        <TextBlock Text="工位小熊" FontSize="16" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding WorkstationPreviewStatusText}" Margin="0,6,0,0" />
                                                        <TextBlock Text="{Binding WorkstationPreviewTodayEarnedText}" Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding WorkstationPreviewOffWorkText}" Margin="0,4,0,0" />
                                                        <TextBlock Text="{Binding WorkstationPreviewPaydayText}" Margin="0,4,0,0" />
                                                    </StackPanel>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsFormRowStyle}">
