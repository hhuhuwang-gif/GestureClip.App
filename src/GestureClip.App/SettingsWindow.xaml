                                                              ItemsSource="{Binding WorkstationCopywritingStyleOptions}"
                                                              SelectedItem="{Binding WorkstationCopywritingStyle, Mode=TwoWay}" />
                                                </StackPanel>
                                                <TextBlock Text="正常模式 / 打工人模式 / 抽象模式：只影响 HUD 和预览文案，不影响统计数据。"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           TextWrapping="Wrap"
                                                           Margin="0,8,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="诊断">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="18">
                            <Border x:Name="DiagnosticsPageIntro" Style="{StaticResource SettingsIntroCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="诊断与日志" Style="{StaticResource SettingsIntroTitleStyle}" />
                                    <TextBlock Text="遇到问题时先复制诊断信息或导出诊断包，方便定位热键、数据库、日志和运行路径。"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Border>
                            <GroupBox Header="诊断" Padding="12" Margin="0">
                                <StackPanel>
                                    <WrapPanel>
                                        <Button Content="打开日志目录" Style="{StaticResource SettingsSecondaryActionButtonStyle}" Command="{Binding OpenLogDirectoryCommand}" />
                                        <Button Content="打开数据目录" Style="{StaticResource SettingsSecondaryActionButtonStyle}" Command="{Binding OpenDataDirectoryCommand}" />
                                        <Button Content="复制诊断信息" Style="{StaticResource SettingsSecondaryActionButtonStyle}" Command="{Binding CopyDiagnosticsCommand}" />
                                        <Button Content="导出诊断包" Style="{StaticResource SettingsSecondaryActionButtonStyle}" Command="{Binding ExportDiagnosticsCommand}" />
                                        <Button Content="刷新" Style="{StaticResource SettingsSecondaryActionButtonStyle}" Command="{Binding RefreshDiagnosticsCommand}" />
                                    </WrapPanel>
                                    <TextBlock Text="{Binding LastDiagnosticsExportText}"
                                               Style="{StaticResource MutedTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                    <TextBox Text="{Binding DiagnosticsText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="220" Margin="0,10,0,0" />
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="关于">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="18">
                            <Border x:Name="AboutPageIntro" Style="{StaticResource SettingsIntroCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="关于与更新" Style="{StaticResource SettingsIntroTitleStyle}" />
                                    <TextBlock Text="查看 GestureClip 的定位，并从这里检查更新或执行一键覆盖更新。"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Border>
                            <GroupBox Header="关于" Padding="12" Margin="0">
                                <StackPanel>
                                    <TextBlock TextWrapping="Wrap"
                                               Style="{StaticResource MutedTextStyle}"
                                               Text="GestureClip 是本地优先的 Windows 剪贴板历史与右键手势工具。剪贴板文本存储在本机 SQLite，日志不记录剪贴板正文。MVP 不保证控制管理员权限窗口，如需控制管理员窗口，请以管理员身份运行 GestureClip。" />
                                    <Border Style="{StaticResource SoftStatusCardStyle}" Margin="0,14,0,0">
                                        <StackPanel>
                                            <TextBlock Text="当前版本" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding AppVersionText}"
                                                       FontSize="18"
                                                       FontWeight="SemiBold"
                                                       Foreground="{DynamicResource BrushPrimaryBright}"
                                                       Margin="0,6,0,0" />
                                        </StackPanel>
                                    </Border>
                                    <WrapPanel Margin="0,14,0,0">
                                        <Button Content="检查更新"
                                                Style="{StaticResource SettingsSecondaryActionButtonStyle}"
                                                Click="CheckUpdateButton_Click" />
                                        <Button Content="一键覆盖更新"
                                                Style="{StaticResource SettingsPrimaryActionButtonStyle}"
                                                Click="UpdateButton_Click" />
                                        <Button Content="打开 Release 页面"
                                                Style="{StaticResource SettingsSecondaryActionButtonStyle}"
                                                Click="OpenReleaseButton_Click" />
                                    </WrapPanel>
                                    <TextBlock Text="检查更新会比较当前版本和 GitHub Latest Release。网络不佳时会自动尝试：系统代理 → 直连 → 镜像加速。一键覆盖更新下载最新 zip 后覆盖重启，本地历史与设置保留。仍失败时可打开 Release 手动下载。"
                                               Style="{StaticResource MutedTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,8,0,0" />
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="更新日志" Padding="12" Margin="0,14,0,0">
                                <StackPanel>
                                    <TextBlock Text="本地 CHANGELOG（发布包会附带）。也可以用“检查更新”查看 GitHub 最新 Release Notes。"
                                               Style="{StaticResource MutedTextStyle}"
                                               TextWrapping="Wrap"
                                               Margin="0,0,0,10" />
                                    <TextBox Text="{Binding ChangelogText, Mode=OneWay}"
                                             IsReadOnly="True"
                                             TextWrapping="Wrap"
                                             AcceptsReturn="True"
                                             VerticalScrollBarVisibility="Auto"
                                             MinHeight="280"
                                             MaxHeight="480"
                                             Padding="12" />
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
                </TabControl>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    Margin="12,0,0,0"
                    CornerRadius="18"
                    Background="#FBFBFD"
                    BorderBrush="#0F000000"
                    BorderThickness="1"
                    Padding="18">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Width="64"
                            Height="64"
                            CornerRadius="16"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource BrushCoralGradient}">
                        <TextBlock Text="GC"
                                   Foreground="White"
                                   FontSize="22"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="GestureClip"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               FontSize="16"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0" />
                    <TextBlock Text="本地优先的剪贴板与手势工具"
                               Foreground="{DynamicResource BrushTextSecondary}"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,4,0,20" />

                    <TextBlock Text="运行状态"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               FontWeight="SemiBold"
                               FontSize="13"
                               Margin="0,0,0,8" />
                    <Border Style="{StaticResource SoftStatusCardStyle}" Margin="0,0,0,8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="剪贴板记录" FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="{Binding ClipboardCaptureStatusText}" Style="{StaticResource MutedTextStyle}" FontSize="12" Margin="0,4,0,0" />
                            </StackPanel>
                            <Ellipse Grid.Column="1" Width="8" Height="8" Fill="{DynamicResource BrushSuccess}" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource SoftStatusCardStyle}" Margin="0,0,0,16">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="鼠标手势" FontWeight="SemiBold" FontSize="13" />
                                <TextBlock Text="{Binding GestureStatusText}" Style="{StaticResource MutedTextStyle}" FontSize="12" Margin="0,4,0,0" />
                            </StackPanel>
                            <Ellipse Grid.Column="1" Width="8" Height="8" Fill="{DynamicResource BrushSuccess}" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <TextBlock Text="快捷"
                               Foreground="{DynamicResource BrushTextPrimary}"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <Border Style="{StaticResource SoftStatusCardStyle}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="剪贴板热键" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding OpenClipboardHotkeyText}" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SoftStatusCardStyle}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="快捷动作热键" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding OpenQuickActionHotkeyText}" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource SoftStatusCardStyle}" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="当前预设" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedGesturePresetOption.DisplayName}" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="提示"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <TextBlock Text="右键画线执行动作。Ctrl + ` 打开剪贴板历史。Ctrl + Shift + Q 打开快捷动作。数据默认保存在本机。"
                               Style="{StaticResource MutedTextStyle}"
                               FontSize="12"
                               LineHeight="20" />
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
    </Border>
</Window>


