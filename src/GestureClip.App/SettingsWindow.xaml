<Window x:Class="GestureClip.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GestureClip.App.Controls"
        Title="GestureClip 设置"
        Icon="Assets/GestureClip.ico"
        Width="1440"
        Height="900"
        MinWidth="1180"
        MinHeight="700"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResize"
        Background="Transparent"
        Foreground="{DynamicResource BrushTextPrimary}"
        FocusVisualStyle="{x:Null}">
    <Window.Resources>
        <Style x:Key="SettingsIntroCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Effect" Value="{x:Null}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="SettingsIntroTitleStyle" TargetType="TextBlock" BasedOn="{StaticResource SettingsPageTitleStyle}">
            <Setter Property="Margin" Value="0,0,0,6" />
        </Style>
        <Style x:Key="SettingsFormRowStyle" TargetType="Border" BasedOn="{StaticResource SettingRowStyle}">
            <Setter Property="Padding" Value="20,16" />
            <Setter Property="Margin" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
        <Style x:Key="SettingsCompactIntroCardStyle" TargetType="Border" BasedOn="{StaticResource SettingsIntroCardStyle}">
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>
        <Style x:Key="SettingsCompactFormRowStyle" TargetType="Border" BasedOn="{StaticResource SettingsFormRowStyle}">
            <Setter Property="Padding" Value="20,16" />
            <Setter Property="Margin" Value="0" />
        </Style>
        <Style x:Key="FeatureMapItemCardStyle" TargetType="Border">
            <Setter Property="Padding" Value="18,16" />
            <Setter Property="Margin" Value="0,0,14,14" />
            <Setter Property="MinHeight" Value="112" />
            <Setter Property="Background" Value="{DynamicResource BrushGlassCard}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="14" />
            <Setter Property="Effect" Value="{x:Null}" />
            <Setter Property="ClipToBounds" Value="True" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="SnapsToDevicePixels" Value="True" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsHotkeyBoxStyle" TargetType="TextBox" BasedOn="{StaticResource GlassTextBoxStyle}">
            <Setter Property="Width" Value="220" />
            <Setter Property="MinWidth" Value="200" />
            <Setter Property="Height" Value="36" />
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="TextAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Padding" Value="12,8" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontFamily" Value="Segoe UI, Microsoft YaHei UI" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
            <Setter Property="CaretBrush" Value="{DynamicResource BrushPrimaryBright}" />
            <Setter Property="Background" Value="{DynamicResource BrushFillTertiary}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushBorder}" />
        </Style>
        <Style x:Key="SettingsControlHostStyle" TargetType="StackPanel">
            <Setter Property="HorizontalAlignment" Value="Right" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Orientation" Value="Horizontal" />
        </Style>
        <Style x:Key="SettingsActionButtonBaseStyle" TargetType="Button">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="120" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsSecondaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="120" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsPrimaryActionButtonStyle" TargetType="Button" BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="128" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsDangerActionButtonStyle" TargetType="Button" BasedOn="{StaticResource DangerButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="128" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsCompactActionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="108" />
            <Setter Property="Height" Value="30" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsGestureDirectionButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="60" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsGestureTemplateButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Width" Value="168" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Margin" Value="0,0,8,8" />
            <Setter Property="Focusable" Value="False" />
        </Style>
        <Style x:Key="SettingsDangerZoneStyle" TargetType="Border" BasedOn="{StaticResource SettingsFormRowStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderBrush" Value="{DynamicResource BrushSeparator}" />
        </Style>
        <Style x:Key="SettingsDangerTextButtonStyle" TargetType="Button" BasedOn="{StaticResource SecondaryButtonStyle}">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Foreground" Value="{DynamicResource BrushDanger}" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Height" Value="32" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="SettingsCompactDangerZoneStyle" TargetType="Border" BasedOn="{StaticResource SettingsDangerZoneStyle}">
            <Setter Property="Padding" Value="12" />
            <Setter Property="Margin" Value="0,0,0,8" />
        </Style>

        <Style x:Key="NavGroupTitleStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Foreground" Value="{DynamicResource BrushTextMuted}" />
            <Setter Property="Margin" Value="14,14,14,6" />
            <Setter Property="LineHeight" Value="14" />
        </Style>
        <Style x:Key="NavItemButtonStyle" TargetType="RadioButton">
            <Setter Property="Height" Value="38" />
            <Setter Property="Margin" Value="10,0,10,2" />
            <Setter Property="Padding" Value="12,0" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Foreground" Value="{DynamicResource BrushTextPrimary}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="GroupName" Value="SettingsNav" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="RadioButton">
                        <Border x:Name="Root"
                                CornerRadius="8"
                                Background="{TemplateBinding Background}"
                                Padding="{TemplateBinding Padding}"
                                SnapsToDevicePixels="True">
                            <ContentPresenter VerticalAlignment="Center" HorizontalAlignment="Left" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BrushControlHover}" />
                            </Trigger>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BrushTabSelected}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="SearchResultItemStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="12,10" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FocusVisualStyle" Value="{x:Null}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Root" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}" CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Root" Property="Background" Value="{DynamicResource BrushControlHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Border CornerRadius="14"
            Background="{DynamicResource BrushAppBackground}"
            BorderBrush="{DynamicResource BrushBorder}"
            BorderThickness="1"
            ClipToBounds="True"
            MouseLeftButtonDown="WindowBackground_MouseLeftButtonDown">
        <Border.Effect>
            <DropShadowEffect Color="#000000" BlurRadius="24" ShadowDepth="2" Opacity="0.10" Direction="270" RenderingBias="Performance" />
        </Border.Effect>
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="4,4,4,16" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel DockPanel.Dock="Left"
                        Orientation="Horizontal"
                        VerticalAlignment="Center"
                        Margin="2,0,16,0">
                <!-- 用户约定：红=关闭，黄=放大，绿=缩小 -->
                <Button Style="{StaticResource TrafficLightButtonStyle}"
                        Background="{DynamicResource BrushTrafficClose}"
                        ToolTip="关闭到托盘"
                        Click="CloseButton_Click" />
                <Button Style="{StaticResource TrafficLightButtonStyle}"
                        Background="{DynamicResource BrushTrafficYellow}"
                        ToolTip="放大窗口"
                        Click="MaximizeButton_Click" />
                <Button Style="{StaticResource TrafficLightButtonStyle}"
                        Background="{DynamicResource BrushTrafficGreen}"
                        ToolTip="缩小窗口"
                        Click="MinimizeButton_Click" />
            </StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="280" />
                </Grid.ColumnDefinitions>
                <StackPanel VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="GestureClip"
                               FontSize="20"
                               FontWeight="SemiBold"
                               LineHeight="26"
                               LineStackingStrategy="BlockLineHeight"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BrushTextPrimary}" />
                    <TextBlock Text="剪贴板 · 手势 · 本地办公加速"
                               Margin="0,4,0,0"
                               FontSize="12"
                               LineHeight="16"
                               LineStackingStrategy="BlockLineHeight"
                               VerticalAlignment="Center"
                               Foreground="{DynamicResource BrushTextSecondary}" />
                </StackPanel>
                <Grid Grid.Column="1" VerticalAlignment="Center">
                    <Border x:Name="SearchBoxBorder"
                            Height="38"
                            CornerRadius="12"
                            Background="{DynamicResource BrushGlassCard}"
                            BorderBrush="{DynamicResource BrushBorder}"
                            BorderThickness="1"
                            Padding="12,0"
                            SnapsToDevicePixels="True">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="⌕"
                                       FontSize="14"
                                       VerticalAlignment="Center"
                                       Margin="0,0,8,0"
                                       Foreground="{DynamicResource BrushTextMuted}" />
                            <TextBox x:Name="SettingsSearchBox"
                                     Grid.Column="1"
                                     Style="{x:Null}"
                                     BorderThickness="0"
                                     Background="Transparent"
                                     Height="Auto"
                                     MinHeight="0"
                                     VerticalContentAlignment="Center"
                                     FontSize="12"
                                     Padding="0"
                                     CaretBrush="{DynamicResource BrushPrimaryBright}"
                                     Foreground="{DynamicResource BrushTextPrimary}"
                                     TextChanged="SettingsSearchBox_TextChanged"
                                     PreviewKeyDown="SettingsSearchBox_PreviewKeyDown"
                                     GotKeyboardFocus="SettingsSearchBox_GotKeyboardFocus" />
                            <TextBlock x:Name="SearchPlaceholder"
                                       Grid.Column="1"
                                       Text="搜索设置…"
                                       FontSize="12"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False"
                                       Foreground="{DynamicResource BrushTextMuted}" />
                            <Button x:Name="ClearSearchButton"
                                    Grid.Column="2"
                                    Content="×"
                                    Width="22"
                                    Height="22"
                                    FontSize="14"
                                    Visibility="Collapsed"
                                    Background="Transparent"
                                    BorderThickness="0"
                                    Foreground="{DynamicResource BrushTextMuted}"
                                    Cursor="Hand"
                                    Click="ClearSearchButton_Click"
                                    Focusable="False" />
                        </Grid>
                    </Border>
                    <Popup x:Name="SearchResultsPopup"
                           PlacementTarget="{Binding ElementName=SearchBoxBorder}"
                           Placement="Bottom"
                           StaysOpen="False"
                           AllowsTransparency="False"
                           PopupAnimation="None">
                        <Border Width="{Binding ActualWidth, ElementName=SearchBoxBorder}"
                                MaxHeight="320"
                                Background="{DynamicResource BrushComboBoxDropDown}"
                                BorderBrush="{DynamicResource BrushBorder}"
                                BorderThickness="1"
                                CornerRadius="0,0,10,10"
                                Padding="6"
                                SnapsToDevicePixels="True">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled"
                                          MaxHeight="300">
                                <StackPanel x:Name="SearchResultsPanel" />
                            </ScrollViewer>
                        </Border>
                    </Popup>
                </Grid>
            </Grid>
        </DockPanel>

        <Grid x:Name="MainBodyGrid" Grid.Row="1" ClipToBounds="False">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="NavColumn" Width="200" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition x:Name="RailColumn" Width="240" />
            </Grid.ColumnDefinitions>

            <!-- Left navigation with groups -->
            <Border Grid.Column="0"
                    Background="{DynamicResource BrushSidebarBackground}"
                    CornerRadius="14,0,0,14"
                    BorderBrush="{DynamicResource BrushSeparator}"
                    BorderThickness="0,0,1,0"
                    ClipToBounds="True">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  FocusVisualStyle="{x:Null}">
                        <StackPanel Margin="0,8,0,12">
                            <TextBlock Text="常用" Style="{StaticResource NavGroupTitleStyle}" Margin="14,4,14,6" />
                            <RadioButton x:Name="NavHome" Content="首页" Style="{StaticResource NavItemButtonStyle}" IsChecked="True" Tag="home" Checked="NavItem_Checked" />
                            <RadioButton x:Name="NavClipboard" Content="剪贴板" Style="{StaticResource NavItemButtonStyle}" Tag="clipboard" Checked="NavItem_Checked" />
                            <RadioButton x:Name="NavGestures" Content="手势" Style="{StaticResource NavItemButtonStyle}" Tag="gestures" Checked="NavItem_Checked" />
                            <RadioButton x:Name="NavBindings" Content="动作绑定" Style="{StaticResource NavItemButtonStyle}" Tag="bindings" Checked="NavItem_Checked" />

                            <TextBlock Text="系统" Style="{StaticResource NavGroupTitleStyle}" />
                            <RadioButton x:Name="NavPrivacy" Content="隐私" Style="{StaticResource NavItemButtonStyle}" Tag="privacy" Checked="NavItem_Checked" />
                            <RadioButton x:Name="NavStartup" Content="自启" Style="{StaticResource NavItemButtonStyle}" Tag="startup" Checked="NavItem_Checked" />

                            <TextBlock Text="其他" Style="{StaticResource NavGroupTitleStyle}" />
                            <RadioButton x:Name="NavWorkbear" Content="小熊" Style="{StaticResource NavItemButtonStyle}" Tag="workbear" Checked="NavItem_Checked" />
                            <RadioButton x:Name="NavDiagnostics" Content="诊断" Style="{StaticResource NavItemButtonStyle}" Tag="diagnostics" Checked="NavItem_Checked" />
                            <RadioButton x:Name="NavAbout" Content="关于" Style="{StaticResource NavItemButtonStyle}" Tag="about" Checked="NavItem_Checked" />
                        </StackPanel>
                    </ScrollViewer>
                    <StackPanel Grid.Row="1" Margin="14,8,14,14">
                        <TextBlock Text="GestureClip"
                                   FontSize="11"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushTextMuted}" />
                        <TextBlock Text="{Binding StartupStatus}"
                                   FontSize="10"
                                   Foreground="{DynamicResource BrushTextMuted}"
                                   TextWrapping="Wrap"
                                   Margin="0,4,0,0"
                                   Opacity="0.85" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Center content -->
            <Border Grid.Column="1"
                    Background="{DynamicResource BrushGlassPanel}"
                    ClipToBounds="True">
                <TabControl x:Name="MainSettingsTabControl"
                            Style="{StaticResource GlassTabControlStyle}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="0"
                            Margin="0"
                            HorizontalContentAlignment="Stretch"
                            VerticalContentAlignment="Stretch"
                            SelectionChanged="MainSettingsTabControl_SelectionChanged">
                    <TabControl.Resources>
                        <!-- Headers hidden by GlassTabControlStyle template; keep items measurable -->
                        <Style TargetType="TabItem">
                            <Setter Property="Height" Value="0" />
                            <Setter Property="Padding" Value="0" />
                            <Setter Property="Margin" Value="0" />
                            <Setter Property="Focusable" Value="False" />
                        </Style>
                    </TabControl.Resources>

                <TabItem Header="首页">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                        <StackPanel Margin="28,24,36,36" HorizontalAlignment="Stretch">
                            <Border x:Name="HomePageIntro" Style="{StaticResource SettingsIntroCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="总览" Style="{StaticResource SettingsIntroTitleStyle}" />
                                    <TextBlock Text="确认权限、数据位置与运行状态。这里不改变功能，只帮你判断 GestureClip 当前是否正常。"
                                               Style="{StaticResource SettingsPageSubtitleStyle}" />
                                </StackPanel>
                            </Border>

                            <Border x:Name="SmartPasteRecommendationCard"
                                    Padding="24,20"
                                    Margin="0,0,0,28"
                                    Background="{DynamicResource BrushGlassAccent}"
                                    BorderBrush="{DynamicResource BrushPrimarySoft}"
                                    BorderThickness="1"
                                    CornerRadius="14"
                                    ClipToBounds="True"
                                    HorizontalAlignment="Stretch"
                                    SnapsToDevicePixels="True">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Margin="0,0,24,0" VerticalAlignment="Center">
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                                            <TextBlock Text="智能粘贴"
                                                       FontSize="16"
                                                       FontWeight="SemiBold"
                                                       LineHeight="22"
                                                       LineStackingStrategy="BlockLineHeight"
                                                       Foreground="{DynamicResource BrushTextPrimary}"
                                                       VerticalAlignment="Center" />
                                            <Border Style="{StaticResource StatusBadgeStyle}"
                                                    Margin="10,0,0,0"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="推荐"
                                                           FontSize="11"
                                                           LineHeight="14"
                                                           VerticalAlignment="Center"
                                                           HorizontalAlignment="Center"
                                                           TextAlignment="Center"
                                                           Foreground="{DynamicResource BrushPrimaryBright}"
                                                           FontWeight="SemiBold" />
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="只净化剪贴板内容，粘贴方式与关闭时相同。开启后按当前应用尽力改写为纯文本/干净文本，再统一发送 Ctrl+V。"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   FontSize="13"
                                                   LineHeight="20"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                    <CheckBox Grid.Column="1"
                                              Style="{StaticResource SettingsToggleCheckBoxStyle}"
                                              ToolTip="开启智能粘贴（推荐）"
                                              IsChecked="{Binding IsSmartPasteEnabled, Mode=TwoWay}" />
                                </Grid>
                            </Border>

                            <TextBlock Text="我能帮你做什么"
                                       Style="{StaticResource SettingsGroupTitleStyle}"
                                       Margin="0,0,0,6" />
                            <TextBlock Text="先看这些入口，不用猜功能藏在哪里。"
                                       Style="{StaticResource MutedTextStyle}"
                                       Margin="0,0,0,12"
                                       FontSize="13" />

                            <UniformGrid Columns="2" Margin="0,0,-16,-16" HorizontalAlignment="Stretch">
                                <Border Style="{StaticResource FeatureMapItemCardStyle}"
                                        Cursor="Hand"
                                        Tag="clipboard"
                                        MouseLeftButtonUp="FeatureMapCard_MouseLeftButtonUp"
                                        ToolTip="前往剪贴板设置">
                                    <StackPanel>
                                        <TextBlock Text="智能粘贴" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="在微信 / 飞书 / Word / 浏览器粘贴时自动选择合适方式。"
                                                   Style="{StaticResource MutedTextStyle}" Margin="0,6,0,0" FontSize="12" />
                                        <TextBlock Text="打开剪贴板页 →"
                                                   Foreground="{DynamicResource BrushPrimaryBright}"
                                                   FontSize="12" FontWeight="Medium" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FeatureMapItemCardStyle}"
                                        Cursor="Hand" Tag="gestures"
                                        MouseLeftButtonUp="FeatureMapCard_MouseLeftButtonUp"
                                        ToolTip="前往手势设置">
                                    <StackPanel>
                                        <TextBlock Text="鼠标手势" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="按住右键划一下，不用找菜单。"
                                                   Style="{StaticResource MutedTextStyle}" Margin="0,6,0,0" FontSize="12" />
                                        <TextBlock Text="打开手势页 →"
                                                   Foreground="{DynamicResource BrushPrimaryBright}"
                                                   FontSize="12" FontWeight="Medium" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FeatureMapItemCardStyle}"
                                        Cursor="Hand" Tag="bindings"
                                        MouseLeftButtonUp="FeatureMapCard_MouseLeftButtonUp"
                                        ToolTip="前往动作绑定">
                                    <StackPanel>
                                        <TextBlock Text="左键增强 / 设计动作" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="画手势时点一下左键，触发增强版动作。"
                                                   Style="{StaticResource MutedTextStyle}" Margin="0,6,0,0" FontSize="12" />
                                        <TextBlock Text="打开动作绑定 →"
                                                   Foreground="{DynamicResource BrushPrimaryBright}"
                                                   FontSize="12" FontWeight="Medium" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FeatureMapItemCardStyle}"
                                        Cursor="Hand" Tag="clipboard"
                                        MouseLeftButtonUp="FeatureMapCard_MouseLeftButtonUp"
                                        ToolTip="前往剪贴板历史">
                                    <StackPanel>
                                        <TextBlock Text="剪贴板历史" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="找回刚复制过的文字和图片。"
                                                   Style="{StaticResource MutedTextStyle}" Margin="0,6,0,0" FontSize="12" />
                                        <TextBlock Text="打开剪贴板页 →"
                                                   Foreground="{DynamicResource BrushPrimaryBright}"
                                                   FontSize="12" FontWeight="Medium" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FeatureMapItemCardStyle}">
                                    <StackPanel>
                                        <TextBlock Text="快捷入口 / 系统工具" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="快速打开常用工具，不用翻开始菜单。"
                                                   Style="{StaticResource MutedTextStyle}" Margin="0,6,0,0" FontSize="12" />
                                        <TextBlock Text="设置内按需开启"
                                                   Foreground="{DynamicResource BrushTextSecondary}"
                                                   FontSize="12" FontWeight="Medium" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource FeatureMapItemCardStyle}"
                                        Cursor="Hand" Tag="privacy"
                                        MouseLeftButtonUp="FeatureMapCard_MouseLeftButtonUp"
                                        ToolTip="前往隐私设置">
                                    <StackPanel>
                                        <TextBlock Text="本地安全" FontSize="14" FontWeight="SemiBold" />
                                        <TextBlock Text="数据留在本机，不上云。"
                                                   Style="{StaticResource MutedTextStyle}" Margin="0,6,0,0" FontSize="12" />
                                        <TextBlock Text="打开隐私页 →"
                                                   Foreground="{DynamicResource BrushPrimaryBright}"
                                                   FontSize="12" FontWeight="Medium" Margin="0,10,0,0" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <TextBlock x:Name="SectionSystemInfo" Text="系统信息" Style="{StaticResource SettingsGroupTitleStyle}" Margin="0,28,0,10" />
                            <Border Style="{StaticResource SettingsListContainerStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="外观" FontSize="14" FontWeight="Medium" />
                                                <TextBlock Text="深色模式可随时切换" Style="{StaticResource MutedTextStyle}" FontSize="12" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <CheckBox Grid.Column="1"
                                                      Style="{StaticResource SettingsToggleCheckBoxStyle}"
                                                      ToolTip="深色模式"
                                                      IsChecked="{Binding IsDarkTheme, Mode=TwoWay}" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="权限状态" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                                            <Border Grid.Column="1" Style="{StaticResource StatusBadgeStyle}" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding PermissionStatusText}"
                                                           Foreground="{DynamicResource BrushPrimaryBright}"
                                                           FontSize="12" FontWeight="SemiBold" />
                                            </Border>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="数据库路径" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Text="{Binding DatabasePath, Mode=OneWay}" IsReadOnly="True" FontSize="12" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="120" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="日志目录" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                                            <TextBox Grid.Column="1" Text="{Binding LogDirectory, Mode=OneWay}" IsReadOnly="True" FontSize="12" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingsFormRowStyle}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="运行状态" FontSize="14" FontWeight="Medium" />
                                                <TextBlock Text="{Binding HotkeyStatusText}" Style="{StaticResource MutedTextStyle}" FontSize="12" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Ellipse Width="8" Height="8" Fill="{DynamicResource BrushSuccess}" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding StartupStatus}" FontSize="13" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="剪贴板">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                        <StackPanel Margin="28,24,36,36" HorizontalAlignment="Stretch">
                            <Border x:Name="ClipboardPageIntro" Style="{StaticResource SettingsCompactIntroCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="剪贴板设置" Style="{StaticResource SettingsIntroTitleStyle}" />
                                    <TextBlock Text="控制是否记录历史、热键如何打开，以及保留策略。危险操作会明确写出影响范围。"
                                               Style="{StaticResource SettingsPageSubtitleStyle}" />
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="SectionClipboardCapture" Text="剪贴板记录" Style="{StaticResource SettingsGroupTitleStyle}" />
                            <Border Style="{StaticResource SettingsListContainerStyle}">
                                <Border Style="{StaticResource SettingsFormRowStyle}" BorderThickness="0">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Margin="0,0,16,0">
                                            <TextBlock Text="启用剪贴板记录" FontSize="14" FontWeight="Medium" />
                                            <TextBlock Text="关闭后不再写入新历史，已有记录仍可查看与清理。"
                                                       Style="{StaticResource MutedTextStyle}" FontSize="12" Margin="0,4,0,0" />
                                        </StackPanel>
                                        <CheckBox Grid.Column="1" Style="{StaticResource SettingsToggleCheckBoxStyle}" VerticalAlignment="Center"
                                                  ToolTip="启用剪贴板记录"
                                                  IsChecked="{Binding ClipboardCaptureEnabled, Mode=TwoWay}" />
                                    </Grid>
                                </Border>
                            </Border>

                            <TextBlock x:Name="SectionClipboardHotkeys" Text="快捷键" Style="{StaticResource SettingsGroupTitleStyle}" Margin="4,28,0,10" />
                            <Border Style="{StaticResource SettingsListContainerStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,16,0">
                                                <TextBlock Text="打开历史" FontSize="14" FontWeight="Medium" />
                                                <TextBlock Text="{Binding HotkeyStatusText}"
                                                           Style="{StaticResource MutedTextStyle}" FontSize="12" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsHotkeyBoxStyle}"
                                                     Tag="OpenClipboard"
                                                     Text="{Binding OpenClipboardHotkeyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     IsReadOnly="True"
                                                     Cursor="Hand"
                                                     ToolTip="点击后按下新快捷键（Esc 取消，Backspace 恢复默认）"
                                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                                     GotKeyboardFocus="HotkeyBox_GotKeyboardFocus"
                                                     LostKeyboardFocus="HotkeyBox_LostKeyboardFocus" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,16,0">
                                                <TextBlock Text="快捷动作" FontSize="14" FontWeight="Medium" />
                                                <TextBlock Text="默认 Ctrl + Shift + Q。支持 Ctrl/Alt/Shift + 字母或数字，失焦后生效。"
                                                           Style="{StaticResource MutedTextStyle}" FontSize="12" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsHotkeyBoxStyle}"
                                                     Tag="OpenQuickAction"
                                                     Text="{Binding OpenQuickActionHotkeyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     IsReadOnly="True"
                                                     Cursor="Hand"
                                                     ToolTip="点击后按下新快捷键（Esc 取消，Backspace 恢复默认）"
                                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                                     GotKeyboardFocus="HotkeyBox_GotKeyboardFocus"
                                                     LostKeyboardFocus="HotkeyBox_LostKeyboardFocus" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingsFormRowStyle}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,16,0">
                                                <TextBlock Text="纯文本粘贴" FontSize="14" FontWeight="Medium" />
                                                <TextBlock Text="默认 Ctrl + Shift + V。网页复制后进微信/文档一键去格式。"
                                                           Style="{StaticResource MutedTextStyle}" FontSize="12" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <TextBox Grid.Column="1" Style="{StaticResource SettingsHotkeyBoxStyle}"
                                                     Tag="PastePlainText"
                                                     Text="{Binding PastePlainTextHotkeyText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     IsReadOnly="True"
                                                     Cursor="Hand"
                                                     ToolTip="点击后按下新快捷键（Esc 取消，Backspace 恢复默认）"
                                                     PreviewKeyDown="HotkeyBox_PreviewKeyDown"
                                                     GotKeyboardFocus="HotkeyBox_GotKeyboardFocus"
                                                     LostKeyboardFocus="HotkeyBox_LostKeyboardFocus" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="SectionClipboardCleanup" Text="历史数据与清理" Style="{StaticResource SettingsGroupTitleStyle}" Margin="4,28,0,10" />
                            <Border Style="{StaticResource SettingsListContainerStyle}">
                                <StackPanel>
                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="历史数量" FontSize="14" FontWeight="Medium" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ClipboardItemCountText}" VerticalAlignment="Center" FontSize="13" Margin="0,0,12,0" />
                                                <Button Content="刷新" Style="{StaticResource SettingsSecondaryActionButtonStyle}" Margin="0"
                                                        Command="{Binding RefreshClipboardStatsCommand}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="保留策略" FontSize="14" FontWeight="Medium" />
                                                <TextBlock Text="超过数量或天数的记录将在清理时移除。"
                                                           Style="{StaticResource MutedTextStyle}" FontSize="12" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <ComboBox Width="100" Margin="0,0,8,0"
                                                          ItemsSource="{Binding ClipboardMaxItemOptions}"
                                                          SelectedItem="{Binding ClipboardMaxItems, Mode=TwoWay}"
                                                          ToolTip="最大保存数量" />
                                                <ComboBox Width="120"
                                                          ItemsSource="{Binding ClipboardRetentionOptions}"
                                                          SelectedItem="{Binding SelectedClipboardRetentionOption, Mode=TwoWay}"
                                                          DisplayMemberPath="Label"
                                                          ToolTip="保留天数" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingsFormRowStyle}" BorderThickness="0">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="Auto" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Margin="0,0,16,0">
                                                <TextBlock Text="危险操作" FontSize="14" FontWeight="Medium"
                                                           Foreground="{DynamicResource BrushDanger}" />
                                                <TextBlock Text="会影响剪贴板历史，执行前请确认。"
                                                           Style="{StaticResource MutedTextStyle}" FontSize="12" Margin="0,4,0,0" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                                <Button Content="清空非固定项"
                                                        Style="{StaticResource SettingsSecondaryActionButtonStyle}"
                                                        Margin="0,0,8,0"
                                                        Command="{Binding ClearUnpinnedClipboardItemsCommand}" />
                                                <Button Content="清空全部历史"
                                                        Style="{StaticResource SettingsDangerTextButtonStyle}"
                                                        Margin="0,0,8,0"
                                                        Command="{Binding ClearAllClipboardItemsCommand}" />
                                                <Button Content="立即执行清理"
                                                        Style="{StaticResource SettingsPrimaryActionButtonStyle}"
                                                        Margin="0"
                                                        Command="{Binding ApplyClipboardCleanupCommand}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="手势">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" ClipToBounds="True">
                        <StackPanel Margin="28,24,36,36" HorizontalAlignment="Stretch">
                            <Border x:Name="GesturePageIntro" Style="{StaticResource SettingsCompactIntroCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="鼠标手势设置" Style="{StaticResource SettingsIntroTitleStyle}" />
                                    <TextBlock Text="先开关手势。默认右键就够用。改「每个手势做什么」去动作绑定；屏幕边缘增强在下方；更多项在高级设置。"
                                               Style="{StaticResource SettingsPageSubtitleStyle}" />
                                    <WrapPanel Margin="0,4,0,8">
                                        <Button Content="去设计 / 更换动作"
                                                Style="{StaticResource PrimaryButtonStyle}"
                                                MinWidth="0"
                                                Width="160"
                                                Height="34"
                                                Margin="0,0,8,8"
                                                Click="NavigateToBindings_Click" />
                                        <Button Content="查看边缘增强"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                MinWidth="0"
                                                Width="140"
                                                Height="34"
                                                Margin="0,0,8,8"
                                                Click="NavigateToEdgeEnhancement_Click" />
                                        <Button Content="展开高级设置"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                MinWidth="0"
                                                Width="140"
                                                Height="34"
                                                Margin="0,0,8,8"
                                                Click="ExpandGestureAdvanced_Click" />
                                    </WrapPanel>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="SectionGestureBasics"
                                       Text="手势基础"
                                       Style="{StaticResource SettingsGroupTitleStyle}" />
                            <Border Style="{StaticResource SettingsListContainerStyle}" HorizontalAlignment="Stretch">
                                <StackPanel>
                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <StackPanel>
                                            <TextBlock Text="按住右键，往一个方向划一下，松开右键就会执行动作。"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="上划复制，下划粘贴，左划后退，右划前进，上下划回车，下上划 Esc。"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <StackPanel>
                                                <TextBlock Text="智能粘贴"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="推荐开关已放到首页顶部"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Margin="0,4,0,0"
                                                           TextWrapping="Wrap" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="智能粘贴只做剪贴板改写（内容不变则跳过），注入始终走可靠 Ctrl+V。与首页推荐卡是同一开关。"
                                                            TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <StackPanel>
                                            <TextBlock Text="打工人等级" FontWeight="SemiBold" />
                                            <TextBlock Text="{Binding WorkerLevelText}" FontSize="18" FontWeight="SemiBold" Margin="0,8,0,0" />
                                            <TextBlock Text="{Binding WorkerXpText}" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0" />
                                            <WrapPanel Margin="0,12,0,0">
                                                <CheckBox Content="显示升级弹窗" Margin="0,0,18,0" IsChecked="{Binding WorkerLevelShowLevelUpPopup, Mode=TwoWay}" />
                                                <CheckBox Content="HUD 显示等级" Margin="0,0,18,0" IsChecked="{Binding WorkerLevelShowLevelInHud, Mode=TwoWay}" />
                                                <CheckBox Content="HUD 趣味战报" Margin="0,0,18,0" IsChecked="{Binding HudFunTextEnabled, Mode=TwoWay}" />
                                                <CheckBox Content="HUD 状态等级" IsChecked="{Binding HudStatusLevelEnabled, Mode=TwoWay}" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="常用开关" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <WrapPanel Grid.Column="1">
                                                <CheckBox Content="启用鼠标手势"
                                                          Margin="0,0,20,0"
                                                          IsChecked="{Binding GestureEnabled, Mode=TwoWay}" />
                                                <CheckBox Content="显示划线和提示"
                                                          Margin="0,0,20,0"
                                                          IsChecked="{Binding GestureShowOverlay, Mode=TwoWay}" />
                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                    <CheckBox Content="开启智能粘贴（推荐）"
                                                              IsChecked="{Binding IsSmartPasteEnabled, Mode=TwoWay}"
                                                              ToolTip="和首页推荐卡是同一个开关" />
                                                    <TextBlock Text="同首页推荐卡"
                                                               Style="{StaticResource MutedTextStyle}"
                                                               Margin="8,2,0,0" />
                                                </StackPanel>
                                            </WrapPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="使用模式" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="1"
                                                      Width="220"
                                                      HorizontalAlignment="Left"
                                                      ItemsSource="{Binding GesturePresetOptions}"
                                                      SelectedItem="{Binding SelectedGesturePresetOption, Mode=TwoWay}"
                                                      DisplayMemberPath="DisplayName" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsCompactFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="划线颜色" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="1"
                                                      Width="220"
                                                      HorizontalAlignment="Left"
                                                      ItemsSource="{Binding GestureStrokeColorOptions}"
                                                      SelectedItem="{Binding SelectedGestureStrokeColorOption, Mode=TwoWay}"
                                                      DisplayMemberPath="DisplayName" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Border>

                            <TextBlock x:Name="SectionEdgeEnhancement"
                                       Text="边缘增强"
                                       Style="{StaticResource SettingsGroupTitleStyle}"
                                       Margin="2,28,0,12" />
                            <Border x:Name="EdgeEnhancementPromoCard"
                                    Style="{StaticResource GlassCardStyle}"
                                    Padding="16"
                                    Margin="0,10,0,0"
                                    Background="{DynamicResource BrushFillTertiary}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="屏幕边缘增强（可选，以前藏在高级设置里）"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="鼠标移到屏幕四角或边缘可触发动作（开始菜单、切换窗口、剪贴板等）。默认关闭；打开后可用右侧预设一键配置。"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="0,6,0,10"
                                                   TextWrapping="Wrap" />
                                        <CheckBox Content="启用屏幕角落 / 边缘触发"
                                                  IsChecked="{Binding EdgeTriggerEnabled, Mode=TwoWay}"
                                                  FontWeight="SemiBold" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="16,0,0,0">
                                        <Button Content="完整边缘设置"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                MinWidth="0"
                                                Width="128"
                                                Height="34"
                                                Margin="0,0,0,8"
                                                Click="NavigateToEdgeEnhancement_Click" />
                                        <Button Content="浏览器预设"
                                                Style="{StaticResource SettingsSecondaryActionButtonStyle}"
                                                Width="128"
                                                Command="{Binding ApplyBrowserEdgePresetCommand}" />
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Expander x:Name="GestureAdvancedSettingsExpander"
                                      Header="高级设置 · 触发键 / 边缘详细项（点此展开）"
                                      Margin="0,10,0,0"
                                      IsExpanded="False">
                                <StackPanel Margin="0,8,0,0">
                                    <TextBlock Text="触发方式" Style="{StaticResource SettingsGroupTitleStyle}" Margin="2,8,0,10" />
                                    <Border Style="{StaticResource SettingsListContainerStyle}" HorizontalAlignment="Stretch">
                                        <StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                                            <TextBlock Text="当前启用" FontWeight="SemiBold" Foreground="{DynamicResource BrushPrimaryBright}" />
                                            <TextBlock Text="：" FontWeight="SemiBold" Foreground="{DynamicResource BrushPrimaryBright}" />
                                            <TextBlock Text="{Binding EnabledGestureTriggerSummary}" FontWeight="SemiBold" Foreground="{DynamicResource BrushPrimaryBright}" />
                                        </StackPanel>
                                        <ItemsControl ItemsSource="{Binding GestureTriggerModes}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource BrushGlass}"
                                                            BorderBrush="{DynamicResource BrushBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="14"
                                                            Padding="12,8"
                                                            Margin="0,0,0,8">
                                                        <DockPanel>
                                                            <TextBlock DockPanel.Dock="Right"
                                                                       Text="{Binding Status}"
                                                                       Foreground="{DynamicResource BrushPrimaryBright}"
                                                                       FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontWeight="SemiBold" />
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                        </StackPanel>
                                    </Border>

                                    <TextBlock Text="高级手势开关" Style="{StaticResource SettingsGroupTitleStyle}" Margin="2,20,0,10" />
                                    <Border Style="{StaticResource SettingsListContainerStyle}" HorizontalAlignment="Stretch" Margin="0,0,0,0">
                                        <StackPanel>
                                            <TextBlock Text="触发方式只允许右键、中键、侧键和屏幕边缘；左键点击可以作为执行动作，但不是手势触发键。"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,0,0,8"
                                                       TextWrapping="Wrap" />
                                            <CheckBox Content="启用鼠标右键手势（默认推荐）" IsChecked="{Binding GestureRightButtonEnabled, Mode=TwoWay}" />
