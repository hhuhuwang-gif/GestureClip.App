<Window x:Class="GestureClip.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:GestureClip.App.Controls"
        Title="GestureClip 设置"
        Icon="Assets/GestureClip.ico"
        Width="1360"
        Height="740"
        MinWidth="1080"
        MinHeight="560"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="NoResize"
        Background="Transparent"
        Foreground="{DynamicResource BrushTextPrimary}">
    <Border CornerRadius="28"
            Background="{DynamicResource BrushAppBackground}"
            BorderBrush="#26FFFFFF"
            BorderThickness="1"
            ClipToBounds="True"
            MouseLeftButtonDown="WindowBackground_MouseLeftButtonDown">
    <Grid Margin="18">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Margin="8,4,8,16" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <StackPanel DockPanel.Dock="Right"
                        Orientation="Horizontal"
                        VerticalAlignment="Top"
                        Margin="12,0,0,0">
                <Button Content="－"
                        Width="42"
                        Height="34"
                        MinWidth="0"
                        Padding="0"
                        Focusable="False"
                        FocusVisualStyle="{x:Null}"
                        FontSize="17"
                        FontWeight="SemiBold"
                        Background="#00FFFFFF"
                        BorderBrush="#00000000"
                        ToolTip="最小化"
                        Click="MinimizeButton_Click" />
                <Button Content="×"
                        Width="42"
                        Height="34"
                        MinWidth="0"
                        Padding="0"
                        Margin="6,0,0,0"
                        Focusable="False"
                        FocusVisualStyle="{x:Null}"
                        FontSize="17"
                        FontWeight="SemiBold"
                        Background="#00FFFFFF"
                        BorderBrush="#00000000"
                        Foreground="{DynamicResource BrushTextSecondary}"
                        ToolTip="关闭到托盘"
                        Click="CloseButton_Click" />
            </StackPanel>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="GestureClip"
                               FontSize="30"
                               FontWeight="SemiBold"
                               Foreground="{DynamicResource BrushTextPrimary}" />
                    <TextBlock Text="剪贴板、手势与系统快捷入口"
                               Margin="0,5,0,0"
                               FontSize="13"
                               Foreground="{DynamicResource BrushTextSecondary}" />
                </StackPanel>
                <TextBox Grid.Column="1"
                         Margin="28,4,0,0"
                         Height="42"
                         IsReadOnly="True"
                         Text="搜索设置稍后开放"
                         Opacity="0.64" />
            </Grid>
        </DockPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="280" />
            </Grid.ColumnDefinitions>

            <Border Style="{StaticResource GlassPanelStyle}" Padding="0">
                <TabControl TabStripPlacement="Left"
                        Background="Transparent"
                        BorderThickness="0"
                        Padding="0">
                <TabControl.Resources>
                    <Style TargetType="TabItem" BasedOn="{StaticResource GlassTabItemStyle}">
                        <Setter Property="Margin" Value="0,0,0,9" />
                        <Setter Property="MinWidth" Value="210" />
                    </Style>
                </TabControl.Resources>

                <TabItem Header="基础设置">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <GroupBox Header="基础设置" Margin="20" Padding="12">
                            <StackPanel>
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="132" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="权限状态" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <Border Grid.Column="1" Style="{StaticResource StatusBadgeStyle}" HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding PermissionStatusText}" Foreground="{DynamicResource BrushPrimary}" FontWeight="SemiBold" />
                                        </Border>
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="132" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="数据库路径" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Text="{Binding DatabasePath, Mode=OneWay}" IsReadOnly="True" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="132" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="日志目录" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Text="{Binding LogDirectory, Mode=OneWay}" IsReadOnly="True" />
                                    </Grid>
                                </Border>
                                <Border Style="{StaticResource SettingRowStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="132" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="运行状态" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        <StackPanel Grid.Column="1">
                                            <StackPanel Orientation="Horizontal">
                                                <Ellipse Width="8" Height="8" Fill="#22C55E" Margin="0,0,8,0" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding StartupStatus}" />
                                            </StackPanel>
                                            <TextBlock Text="{Binding HotkeyStatusText}" Style="{StaticResource MutedTextStyle}" Margin="0,8,0,0" />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </GroupBox>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="剪贴板">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="18">
                            <GroupBox Header="剪贴板" Padding="12">
                                <StackPanel>
                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="记录状态" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <CheckBox Grid.Column="1" Content="启用剪贴板记录" IsChecked="{Binding ClipboardCaptureEnabled, Mode=TwoWay}" />
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="打开历史热键" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1">
                                                <TextBox Width="190"
                                                         HorizontalAlignment="Left"
                                                         Text="{Binding OpenClipboardHotkeyText, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <TextBlock Text="{Binding HotkeyStatusText}" Margin="0,6,0,0" Style="{StaticResource MutedTextStyle}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </GroupBox>

                            <GroupBox Header="数据与清理" Padding="12" Margin="0,14,0,0">
                                <StackPanel>
                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="历史数量" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal">
                                                <TextBlock Text="{Binding ClipboardItemCountText}" VerticalAlignment="Center" />
                                                <Button Content="刷新"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Margin="14,0,0,0"
                                                        Command="{Binding RefreshClipboardStatsCommand}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="保留策略" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <WrapPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="最大保存数量" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                <ComboBox Width="110"
                                                          Margin="0,0,22,0"
                                                          ItemsSource="{Binding ClipboardMaxItemOptions}"
                                                          SelectedItem="{Binding ClipboardMaxItems, Mode=TwoWay}" />
                                                <TextBlock Text="保留天数" VerticalAlignment="Center" Margin="0,0,10,0" />
                                                <ComboBox Width="110"
                                                          ItemsSource="{Binding ClipboardRetentionOptions}"
                                                          SelectedItem="{Binding SelectedClipboardRetentionOption, Mode=TwoWay}"
                                                          DisplayMemberPath="Label" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="清理操作" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <WrapPanel Grid.Column="1">
                                                <Button Content="清空非固定项"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        Margin="0,0,12,10"
                                                        Command="{Binding ClearUnpinnedClipboardItemsCommand}" />
                                                <Button Content="清空全部历史"
                                                        Style="{StaticResource DangerButtonStyle}"
                                                        Margin="0,0,12,10"
                                                        Command="{Binding ClearAllClipboardItemsCommand}" />
                                                <Button Content="立即执行清理"
                                                        Style="{StaticResource PrimaryButtonStyle}"
                                                        Margin="0,0,0,10"
                                                        Command="{Binding ApplyClipboardCleanupCommand}" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="鼠标手势">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="18">
                            <GroupBox Header="鼠标手势" Padding="12">
                                <StackPanel>
                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <StackPanel>
                                            <TextBlock Text="按住右键，往一个方向划一下，松开右键就会执行动作。"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="上划复制，下划粘贴，左划后退，右划前进，上下划回车，下上划 Esc。"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="常用开关" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <WrapPanel Grid.Column="1">
                                                <CheckBox Content="启用鼠标手势"
                                                          Margin="0,0,20,0"
                                                          IsChecked="{Binding GestureEnabled, Mode=TwoWay}" />
                                                <CheckBox Content="显示划线和提示"
                                                          IsChecked="{Binding GestureShowOverlay, Mode=TwoWay}" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="使用模式" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="1"
                                                      Width="220"
                                                      HorizontalAlignment="Left"
                                                      ItemsSource="{Binding GesturePresetOptions}"
                                                      SelectedItem="{Binding SelectedGesturePresetOption, Mode=TwoWay}"
                                                      DisplayMemberPath="DisplayName" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="划线颜色" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <ComboBox Grid.Column="1"
                                                      Width="220"
                                                      HorizontalAlignment="Left"
                                                      ItemsSource="{Binding GestureStrokeColorOptions}"
                                                      SelectedItem="{Binding SelectedGestureStrokeColorOption, Mode=TwoWay}"
                                                      DisplayMemberPath="DisplayName" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </GroupBox>

                            <Expander Header="高级设置"
                                      Margin="0,12,0,0"
                                      IsExpanded="True">
                                <StackPanel Margin="0,10,0,0">
                                    <GroupBox Header="触发方式" Padding="12">
                                        <ItemsControl ItemsSource="{Binding GestureTriggerModes}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{DynamicResource BrushGlass}"
                                                            BorderBrush="{DynamicResource BrushBorder}"
                                                            BorderThickness="1"
                                                            CornerRadius="14"
                                                            Padding="12,8"
                                                            Margin="0,0,0,8">
                                                        <DockPanel>
                                                            <TextBlock DockPanel.Dock="Right"
                                                                       Text="{Binding Status}"
                                                                       Foreground="{DynamicResource BrushPrimaryBright}"
                                                                       FontWeight="SemiBold" />
                                                            <TextBlock Text="{Binding Name}"
                                                                       FontWeight="SemiBold" />
                                                        </DockPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </GroupBox>

                                    <GroupBox Header="高级手势开关" Padding="12" Margin="0,12,0,0">
                                        <StackPanel>
                                            <CheckBox Content="启用鼠标中键手势" IsChecked="{Binding GestureMiddleButtonEnabled, Mode=TwoWay}" />
                                            <CheckBox Content="启用鼠标侧键 1 手势" Margin="0,8,0,0" IsChecked="{Binding GestureXButton1Enabled, Mode=TwoWay}" />
                                            <CheckBox Content="启用鼠标侧键 2 手势" Margin="0,8,0,0" IsChecked="{Binding GestureXButton2Enabled, Mode=TwoWay}" />
                                            <CheckBox Content="启用手势调试日志" Margin="0,8,0,0" IsChecked="{Binding GestureDebugEnabled, Mode=TwoWay}" />
                                            <CheckBox Content="启用 UD 关闭窗口手势" Margin="0,8,0,0" IsChecked="{Binding GestureCloseWindowEnabled, Mode=TwoWay}" />
                                            <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                                                <TextBlock Text="划多远才算手势" VerticalAlignment="Center" />
                                                <TextBox Width="70" Margin="12,0,0,0" Text="{Binding GestureTriggerThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                                <TextBlock Text="像素" Margin="6,0,0,0" VerticalAlignment="Center" />
                                            </StackPanel>
                                        </StackPanel>
                                    </GroupBox>

                                    <GroupBox Header="屏幕角落和边缘" Padding="12" Margin="0,12,0,0">
                                        <StackPanel>
                                            <CheckBox Content="启用屏幕角落触发"
                                                      IsChecked="{Binding EdgeTriggerEnabled, Mode=TwoWay}" />
                                            <TextBlock Text="把鼠标移到屏幕角落或边缘时执行动作。默认关闭，不需要就不用管。"
                                               Style="{StaticResource MutedTextStyle}"
                                               Margin="0,8,0,10"
                                               TextWrapping="Wrap" />
                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                                        <Button Content="浏览器增强"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Command="{Binding ApplyBrowserEdgePresetCommand}" />
                                        <Button Content="系统控制"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                Command="{Binding ApplySystemEdgePresetCommand}" />
                                        <Button Content="剪贴板增强"
                                                Style="{StaticResource SecondaryButtonStyle}"
                                                Margin="8,0,0,0"
                                                Command="{Binding ApplyClipboardEdgePresetCommand}" />
                                    </StackPanel>
                                    <Grid Margin="0,0,0,12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                            <ColumnDefinition Width="100" />
                                            <ColumnDefinition Width="90" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="触发范围" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="1" Text="{Binding EdgeTriggerHotZoneSize, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="2" Text="停留多久" Margin="10,0,0,0" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="3" Text="{Binding EdgeTriggerDwellMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="4" Text="防误触间隔" Margin="10,0,0,0" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="5" Text="{Binding EdgeTriggerCooldownMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Grid.Column="6" Text="滑多远触发" Margin="10,0,0,0" VerticalAlignment="Center" />
                                        <TextBox Grid.Column="7" Text="{Binding EdgeTriggerSlideThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    </Grid>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="130" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="左上角" VerticalAlignment="Center" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerTopLeftAction, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="1" Text="右上角" Margin="0,8,0,0" VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="1"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerTopRightAction, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="2" Text="右下角" Margin="0,8,0,0" VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="2"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerBottomRightAction, Mode=TwoWay}" />

                                        <TextBlock Grid.Row="3" Text="左下角" Margin="0,8,0,0" VerticalAlignment="Center" />
                                        <ComboBox Grid.Row="3"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerBottomLeftAction, Mode=TwoWay}" />
                                    </Grid>

                                    <TextBlock Text="边缘 + 鼠标按钮"
                                               FontWeight="SemiBold"
                                               Margin="0,16,0,8" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="210" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <CheckBox Content="左边缘 + 鼠标中键"
                                                  IsChecked="{Binding EdgeTriggerLeftEdgeMiddleButtonEnabled, Mode=TwoWay}" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerLeftEdgeMiddleButtonAction, Mode=TwoWay}" />

                                        <CheckBox Grid.Row="1"
                                                  Content="左边缘 + 鼠标侧键 1"
                                                  Margin="0,8,0,0"
                                                  IsChecked="{Binding EdgeTriggerLeftEdgeXButton1Enabled, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="1"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerLeftEdgeXButton1Action, Mode=TwoWay}" />

                                        <CheckBox Grid.Row="2"
                                                  Content="左边缘 + 鼠标侧键 2"
                                                  Margin="0,8,0,0"
                                                  IsChecked="{Binding EdgeTriggerLeftEdgeXButton2Enabled, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="2"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerLeftEdgeXButton2Action, Mode=TwoWay}" />

                                        <CheckBox Grid.Row="3"
                                                  Content="右上角 + 滚轮"
                                                  Margin="0,8,0,0"
                                                  IsChecked="{Binding EdgeTriggerTopRightWheelEnabled, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="3"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerTopRightWheelAction, Mode=TwoWay}" />
                                    </Grid>

                                    <TextBlock Text="边缘滑动"
                                               FontWeight="SemiBold"
                                               Margin="0,16,0,8" />
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="210" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>
                                        <CheckBox Content="左边缘向右滑"
                                                  IsChecked="{Binding EdgeTriggerSlideLeftEnabled, Mode=TwoWay}" />
                                        <ComboBox Grid.Column="1"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerSlideLeftAction, Mode=TwoWay}" />
                                        <CheckBox Grid.Row="1"
                                                  Content="右边缘向左滑"
                                                  Margin="0,8,0,0"
                                                  IsChecked="{Binding EdgeTriggerSlideRightEnabled, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="1"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerSlideRightAction, Mode=TwoWay}" />
                                        <CheckBox Grid.Row="2"
                                                  Content="上边缘向下滑"
                                                  Margin="0,8,0,0"
                                                  IsChecked="{Binding EdgeTriggerSlideTopEnabled, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="2"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerSlideTopAction, Mode=TwoWay}" />
                                        <CheckBox Grid.Row="3"
                                                  Content="下边缘向上滑"
                                                  Margin="0,8,0,0"
                                                  IsChecked="{Binding EdgeTriggerSlideBottomEnabled, Mode=TwoWay}" />
                                        <ComboBox Grid.Row="3"
                                                  Grid.Column="1"
                                                  Margin="0,8,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding EdgeTriggerSlideBottomAction, Mode=TwoWay}" />
                                    </Grid>
                                        </StackPanel>
                                    </GroupBox>
                                </StackPanel>
                            </Expander>

                            <GroupBox Header="手势测试" Padding="12" Margin="0,12,0,0">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="120" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="Hook 状态" />
                                    <TextBlock Grid.Column="1" Text="{Binding GestureHookStatus}" />
                                    <TextBlock Grid.Row="1" Text="当前状态" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GestureRuntimeStateText}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="2" Text="最近 Pattern" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LastGesturePattern}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="3" Text="最近 Action" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastGestureAction}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="4" Text="最近错误" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastGestureError}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="5" Text="最近事件" Margin="0,6,0,0" />
                                    <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding LastGestureEventTime}" />
                                        <TextBlock Text="{Binding GestureEnvironmentStatus}" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0" />
                                    </StackPanel>
                                    <TextBlock Grid.Row="6" Text="边缘来源" Margin="0,10,0,0" />
                                    <TextBlock Grid.Row="6" Grid.Column="1" Text="{Binding EdgeTriggerLastSource}" Margin="0,10,0,0" />
                                    <TextBlock Grid.Row="7" Text="边缘位置" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="7" Grid.Column="1" Text="{Binding EdgeTriggerLastPosition}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="8" Text="边缘动作" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="8" Grid.Column="1" Text="{Binding EdgeTriggerLastAction}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="9" Text="边缘状态" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="9" Grid.Column="1" Text="{Binding EdgeTriggerLastReason}" Margin="0,6,0,0" />
                                    <TextBlock Grid.Row="10" Text="边缘冷却" Margin="0,6,0,0" />
                                    <StackPanel Grid.Row="10" Grid.Column="1" Margin="0,6,0,0">
                                        <TextBlock Text="{Binding EdgeTriggerCooldownText}" />
                                        <TextBlock Text="{Binding EdgeTriggerLastEventTime}" Style="{StaticResource MutedTextStyle}" Margin="0,4,0,0" />
                                    </StackPanel>
                                </Grid>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="手势绑定">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="18">
                            <GroupBox Header="添加自定义手势" Padding="12">
                                <StackPanel>
                                    <TextBlock Text="点方向按钮设计手势，也可以手动输入 U / D / L / R。最长 8 段。"
                                               Style="{StaticResource MutedTextStyle}"
                                               Margin="0,0,0,10" />
                                    <Border x:Name="GestureDesignerPanel"
                                            Background="#F8FAFD"
                                            BorderBrush="{DynamicResource BrushBorder}"
                                            BorderThickness="1"
                                            CornerRadius="18"
                                            Padding="16"
                                            Margin="0,0,0,12">
                                        <StackPanel>
                                            <StackPanel Margin="0,0,0,14">
                                                <Border Width="420"
                                                        Height="190"
                                                        HorizontalAlignment="Left"
                                                        CornerRadius="18"
                                                        Background="#FFFFFFFF"
                                                        BorderBrush="#26768AA8"
                                                        BorderThickness="1"
                                                        ClipToBounds="True"
                                                        MouseLeftButtonDown="RecordGesturePad_MouseLeftButtonDown"
                                                        MouseMove="RecordGesturePad_MouseMove"
                                                        MouseLeftButtonUp="RecordGesturePad_MouseLeftButtonUp">
                                                    <Grid>
                                                        <TextBlock Text="在这里按住并拖动，松开后自动识别"
                                                                   Style="{StaticResource MutedTextStyle}"
                                                                   FontSize="14"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center" />
                                                        <Canvas x:Name="RecordGestureCanvas"
                                                                Background="Transparent"
                                                                IsHitTestVisible="False">
                                                            <Polyline x:Name="RecordGesturePolyline"
                                                                      Stroke="{DynamicResource BrushPrimaryBright}"
                                                                      StrokeThickness="5"
                                                                      StrokeStartLineCap="Round"
                                                                      StrokeEndLineCap="Round"
                                                                      StrokeLineJoin="Round" />
                                                        </Canvas>
                                                    </Grid>
                                                </Border>
                                                <TextBlock Text="{Binding NewGestureDirectionPreview}"
                                                           FontSize="15"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrushPrimaryBright}"
                                                           Margin="0,10,0,0" />
                                                <TextBlock Text="{Binding RecordGestureStatusText}"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                            <WrapPanel VerticalAlignment="Center">
                                                <Button Content="↑" MinWidth="0" Width="64" Height="36" Margin="0,0,8,8" Command="{Binding AppendGestureDirectionCommand}" CommandParameter="U" />
                                                <Button Content="↓" MinWidth="0" Width="64" Height="36" Margin="0,0,8,8" Command="{Binding AppendGestureDirectionCommand}" CommandParameter="D" />
                                                <Button Content="←" MinWidth="0" Width="64" Height="36" Margin="0,0,8,8" Command="{Binding AppendGestureDirectionCommand}" CommandParameter="L" />
                                                <Button Content="→" MinWidth="0" Width="64" Height="36" Margin="0,0,8,8" Command="{Binding AppendGestureDirectionCommand}" CommandParameter="R" />
                                                <Button Content="退一格" MinWidth="0" Width="96" Height="36" Margin="0,0,8,8" Command="{Binding RemoveLastGestureDirectionCommand}" />
                                                <Button Content="清空" MinWidth="0" Width="84" Height="36" Margin="0,0,8,8" Command="{Binding ClearNewGesturePatternCommand}" />
                                            </WrapPanel>
                                            <TextBlock Text="常用折线模板"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,8,0,8" />
                                            <WrapPanel>
                                                <Button Content="↓←  左键点击" MinWidth="0" Width="150" Height="34" Margin="0,0,8,8" Command="{Binding SetNewGesturePatternCommand}" CommandParameter="DL" />
                                                <Button Content="↓→  右键点击" MinWidth="0" Width="150" Height="34" Margin="0,0,8,8" Command="{Binding SetNewGesturePatternCommand}" CommandParameter="DR" />
                                                <Button Content="↑→↓  下一标签" MinWidth="0" Width="158" Height="34" Margin="0,0,8,8" Command="{Binding SetNewGesturePatternCommand}" CommandParameter="URD" />
                                                <Button Content="↑←↓  上一标签" MinWidth="0" Width="158" Height="34" Margin="0,0,8,8" Command="{Binding SetNewGesturePatternCommand}" CommandParameter="ULD" />
                                                <Button Content="→↓←  截图" MinWidth="0" Width="132" Height="34" Margin="0,0,8,8" Command="{Binding SetNewGesturePatternCommand}" CommandParameter="RDL" />
                                                <Button Content="→↑↓  缩放重置" MinWidth="0" Width="150" Height="34" Margin="0,0,8,8" Command="{Binding SetNewGesturePatternCommand}" CommandParameter="RUD" />
                                            </WrapPanel>
                                        </StackPanel>
                                    </Border>
                                    <WrapPanel>
                                        <TextBox Width="120"
                                                 Text="{Binding NewGesturePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                        <ComboBox Width="220"
                                                  Margin="10,0,0,0"
                                                  ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding NewGestureAction, Mode=TwoWay}" />
                                        <Button Content="{Binding NewGestureAddButtonText}"
                                                MinWidth="0"
                                                Width="108"
                                                Margin="10,0,0,0"
                                                Background="#F0F2F7"
                                                Foreground="#111827"
                                                BorderBrush="{DynamicResource BrushBorder}"
                                                Command="{Binding AddCustomGestureBindingCommand}" />
                                    </WrapPanel>
                                </StackPanel>
                            </GroupBox>

                            <Grid Margin="0,14,0,0">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="420" />
                                </Grid.ColumnDefinitions>

                                <Border x:Name="GestureBindingListPanel"
                                        Style="{StaticResource GlassCardStyle}"
                                        Padding="0">
                                    <DockPanel>
                                        <Grid DockPanel.Dock="Top" Margin="18,16,18,12">
                                            <StackPanel>
                                                <TextBlock Text="全局 的手势"
                                                           FontSize="17"
                                                           FontWeight="SemiBold" />
                                                <TextBlock Text="点左侧手势，右侧改动作。修改后自动保存。"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Grid>

                                        <ListBox ItemsSource="{Binding GestureBindingCards}"
                                                 SelectedItem="{Binding SelectedGestureBindingCard, Mode=TwoWay}"
                                                 BorderThickness="0"
                                                 Background="Transparent"
                                                 ScrollViewer.CanContentScroll="True"
                                                 VirtualizingPanel.IsVirtualizing="True"
                                                 VirtualizingPanel.VirtualizationMode="Recycling">
                                            <ListBox.ItemContainerStyle>
                                                <Style TargetType="ListBoxItem">
                                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                                    <Setter Property="Padding" Value="0" />
                                                    <Setter Property="Margin" Value="0" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="BorderThickness" Value="0" />
                                                </Style>
                                            </ListBox.ItemContainerStyle>
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="#F8FAFD"
                                                            BorderBrush="{DynamicResource BrushBorder}"
                                                            BorderThickness="0,1,0,0"
                                                            Padding="14,12">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="104" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="190" />
                                                            </Grid.ColumnDefinitions>

                                                            <Border Width="88"
                                                                    Height="66"
                                                                    CornerRadius="14"
                                                                    Background="#18FFFFFF"
                                                                    BorderBrush="#26768AA8"
                                                                    BorderThickness="1">
                                                                <controls:GesturePatternView Pattern="{Binding Pattern}"
                                                                                             Width="88"
                                                                                             Height="66" />
                                                            </Border>

                                                            <StackPanel Grid.Column="1"
                                                                        VerticalAlignment="Center">
                                                                <TextBlock Text="{Binding GestureName}"
                                                                           FontSize="15"
                                                                           FontWeight="SemiBold" />
                                                                <TextBlock Text="{Binding Pattern, StringFormat=Pattern: {0}}"
                                                                           Style="{StaticResource MutedTextStyle}"
                                                                           Margin="0,4,0,0" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2"
                                                                        VerticalAlignment="Center"
                                                                        HorizontalAlignment="Right">
                                                                <TextBlock Text="{Binding ActionName}"
                                                                           FontWeight="SemiBold"
                                                                           TextAlignment="Right" />
                                                                <TextBlock Text="{Binding ShortcutText}"
                                                                           Style="{StaticResource MutedTextStyle}"
                                                                           TextAlignment="Right"
                                                                           Margin="0,4,0,0" />
                                                            </StackPanel>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </DockPanel>
                                </Border>

                                <Border x:Name="GestureBindingDetailPanel"
                                        Grid.Column="1"
                                        Style="{StaticResource GlassCardStyle}"
                                        Margin="14,0,0,0"
                                        Padding="22">
                                    <StackPanel>
                                        <TextBlock Text="动作编辑器"
                                                   FontSize="18"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="选中一个手势后，在这里修改动作。"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,16" />
                                        <Border Background="#F8FAFD"
                                                BorderBrush="{DynamicResource BrushBorder}"
                                                BorderThickness="1"
                                                CornerRadius="18"
                                                Padding="16"
                                                Margin="0,0,0,16">
                                            <StackPanel>
                                                <controls:GesturePatternView Pattern="{Binding SelectedGestureBindingPattern}"
                                                                             Width="320"
                                                                             Height="170"
                                                                             HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding SelectedGestureBindingDirectionText}"
                                                           FontSize="18"
                                                           FontWeight="SemiBold"
                                                           Foreground="{DynamicResource BrushPrimaryBright}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,10,0,0" />
                                                <TextBlock Text="{Binding SelectedGestureBindingPattern, StringFormat=Pattern: {0}}"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           HorizontalAlignment="Center"
                                                           Margin="0,4,0,0" />
                                            </StackPanel>
                                        </Border>
                                        <TextBlock Text="当前动作"
                                                   FontWeight="SemiBold"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Text="{Binding SelectedGestureBindingActionName}"
                                                   FontSize="16"
                                                   FontWeight="SemiBold" />
                                        <TextBlock Text="{Binding SelectedGestureBindingShortcutText}"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   Margin="0,4,0,12" />
                                        <ComboBox ItemsSource="{Binding GestureActionOptions}"
                                                  DisplayMemberPath="DisplayName"
                                                  SelectedValuePath="Action"
                                                  SelectedValue="{Binding SelectedGestureBindingCard.SelectedAction, Mode=TwoWay}"
                                                  IsEnabled="{Binding HasSelectedGestureBinding}" />
                                        <Button Content="删除这个手势"
                                                MinWidth="0"
                                                Height="38"
                                                Margin="0,14,0,0"
                                                Style="{StaticResource DangerButtonStyle}"
                                                IsEnabled="{Binding HasSelectedGestureBinding}"
                                                Command="{Binding DeleteSelectedGestureBindingCommand}" />
                                        <TextBlock Text="提示"
                                                   FontWeight="SemiBold"
                                                   Margin="0,18,0,0" />
                                        <TextBlock Text="手势最多 8 段。重复方向会自动合并，例如一直向右只算 R。"
                                                   Style="{StaticResource MutedTextStyle}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,8,0,0" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="隐私黑名单">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <GroupBox Header="隐私黑名单" Padding="12" Margin="18">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox Width="220" Text="{Binding NewBlacklistProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="添加" Style="{StaticResource PrimaryButtonStyle}" MinWidth="0" Width="84" Margin="8,0,0,0" Command="{Binding AddBlacklistItemCommand}" />
                                </StackPanel>
                                <TextBlock Text="添加进程名后，会按进程阻止剪贴板记录和鼠标手势。" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,8" />
                                <ItemsControl ItemsSource="{Binding AppBlacklistItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="170" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="104" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding ProcessName}" VerticalAlignment="Center" />
                                                <CheckBox Grid.Column="1" Content="剪贴板" IsChecked="{Binding BlockClipboard, Mode=TwoWay}" />
                                                <CheckBox Grid.Column="2" Content="手势" IsChecked="{Binding BlockGesture, Mode=TwoWay}" />
                                                <Button Grid.Column="3" Content="删除" MinWidth="0" Width="88" Style="{StaticResource DangerButtonStyle}" Command="{Binding DeleteCommand}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </GroupBox>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="开机自启">
                    <GroupBox Header="开机自启" Padding="12" Margin="18">
                        <StackPanel>
                            <CheckBox Content="开机自动启动 GestureClip" IsChecked="{Binding StartWithWindows, Mode=TwoWay}" />
                            <TextBlock Text="{Binding StartupModeWarning}" Foreground="{DynamicResource BrushPrimaryBright}" TextWrapping="Wrap" Margin="0,6,0,0" />
                        </StackPanel>
                    </GroupBox>
                </TabItem>

                <TabItem Header="工位小熊">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="18">
                            <GroupBox Header="工位小熊" Padding="12">
                                <StackPanel>
                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <StackPanel>
                                            <TextBlock Text="用大白话看今天还要熬多久、赚了多少、摸鱼值多少钱。"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="所有统计只在本地计算，不上传，也不记录剪贴板正文。"
                                                       Style="{StaticResource MutedTextStyle}"
                                                       Margin="0,6,0,0"
                                                       TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Border>

                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="启用面板" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <CheckBox Grid.Column="1"
                                                      Content="显示工位小熊入口和统计"
                                                      IsChecked="{Binding WorkstationEnabled, Mode=TwoWay}" />
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="月薪" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal">
                                                <TextBox Width="150"
                                                         Text="{Binding WorkstationMonthlySalary, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <TextBlock Text="元，用来估算今日已赚和摸鱼价值"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="工作时间" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <WrapPanel Grid.Column="1"
                                                       VerticalAlignment="Center">
                                                <TextBlock Text="上班" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBox Width="100"
                                                         Text="{Binding WorkstationWorkStartTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <TextBlock Text="下班" VerticalAlignment="Center" Margin="18,0,8,0" />
                                                <TextBox Width="100"
                                                         Text="{Binding WorkstationWorkEndTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="午休时间" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <WrapPanel Grid.Column="1"
                                                       VerticalAlignment="Center">
                                                <TextBlock Text="开始" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBox Width="100"
                                                         Text="{Binding WorkstationLunchStartTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <TextBlock Text="结束" VerticalAlignment="Center" Margin="18,0,8,0" />
                                                <TextBox Width="100"
                                                         Text="{Binding WorkstationLunchEndTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="工作日" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal">
                                                <TextBox Width="180"
                                                         Text="{Binding WorkstationWorkdays, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <TextBlock Text="1=周一，5=周五，默认 1,2,3,4,5"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="发薪日" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal">
                                                <TextBox Width="90"
                                                         Text="{Binding WorkstationPayday, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <TextBlock Text="每月几号，范围 1-28"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="显示内容" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <WrapPanel Grid.Column="1">
                                                <CheckBox Content="显示摸鱼价值"
                                                          Margin="0,0,20,0"
                                                          IsChecked="{Binding WorkstationShowFishingValue, Mode=TwoWay}" />
                                                <CheckBox Content="显示下班倒计时"
                                                          Margin="0,0,20,0"
                                                          IsChecked="{Binding WorkstationShowOffWorkCountdown, Mode=TwoWay}" />
                                                <CheckBox Content="每日存活报告"
                                                          IsChecked="{Binding WorkstationDailyReportEnabled, Mode=TwoWay}" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="诊断">
                    <GroupBox Header="诊断" Padding="12" Margin="18">
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="打开日志目录" Command="{Binding OpenLogDirectoryCommand}" />
                                <Button Content="打开数据目录" Margin="8,0,0,0" Command="{Binding OpenDataDirectoryCommand}" />
                                <Button Content="复制诊断信息" Margin="8,0,0,0" Command="{Binding CopyDiagnosticsCommand}" />
                                <Button Content="刷新" Margin="8,0,0,0" Command="{Binding RefreshDiagnosticsCommand}" />
                            </StackPanel>
                            <TextBox Text="{Binding DiagnosticsText, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap" AcceptsReturn="True" MinHeight="220" Margin="0,10,0,0" />
                        </StackPanel>
                    </GroupBox>
                </TabItem>

                <TabItem Header="关于">
                    <GroupBox Header="关于" Padding="12" Margin="18">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap"
                                       Style="{StaticResource MutedTextStyle}"
                                       Text="GestureClip 是本地优先的 Windows 剪贴板历史与右键手势工具。剪贴板文本存储在本机 SQLite，日志不记录剪贴板正文。MVP 不保证控制管理员权限窗口，如需控制管理员窗口，请以管理员身份运行 GestureClip。" />
                            <Button Content="一键更新"
                                    Width="120"
                                    HorizontalAlignment="Left"
                                    Margin="0,14,0,0"
                                    Style="{StaticResource PrimaryButtonStyle}"
                                    Click="UpdateButton_Click" />
                            <TextBlock Text="会打开 GitHub 最新 Release 页面，下载新版后覆盖旧版即可。"
                                       Style="{StaticResource MutedTextStyle}"
                                       TextWrapping="Wrap"
                                       Margin="0,8,0,0" />
                        </StackPanel>
                    </GroupBox>
                </TabItem>
                </TabControl>
            </Border>

            <Border Grid.Column="1"
                    Margin="14,0,0,0"
                    CornerRadius="24"
                    Background="#F0101011"
                    Padding="24">
                <ScrollViewer VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled">
                <StackPanel>
                    <Border Width="72"
                            Height="72"
                            CornerRadius="20"
                            HorizontalAlignment="Center"
                            Background="{DynamicResource BrushCoralGradient}">
                        <TextBlock Text="GC"
                                   Foreground="White"
                                   FontSize="24"
                                   FontWeight="SemiBold"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center" />
                    </Border>
                    <TextBlock Text="GestureClip"
                               Foreground="White"
                               FontSize="18"
                               FontWeight="SemiBold"
                               HorizontalAlignment="Center"
                               Margin="0,14,0,0" />
                    <TextBlock Text="本地优先的剪贴板与手势工具"
                               Foreground="#8F949E"
                               FontSize="12"
                               HorizontalAlignment="Center"
                               TextWrapping="Wrap"
                               Margin="0,6,0,24" />

                    <TextBlock Text="运行状态"
                               Foreground="#F6F7FB"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <Border CornerRadius="16" Background="{DynamicResource BrushDarkPanelSoft}" Padding="14" Margin="0,0,0,10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="剪贴板记录" Foreground="#E8EAEE" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding ClipboardCaptureStatusText}" Foreground="#8F949E" FontSize="12" Margin="0,4,0,0" />
                            </StackPanel>
                            <Ellipse Grid.Column="1" Width="10" Height="10" Fill="#61D394" VerticalAlignment="Center" />
                        </Grid>
                    </Border>
                    <Border CornerRadius="16" Background="{DynamicResource BrushDarkPanelSoft}" Padding="14" Margin="0,0,0,18">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="鼠标手势" Foreground="#E8EAEE" FontWeight="SemiBold" />
                                <TextBlock Text="{Binding GestureStatusText}" Foreground="#8F949E" FontSize="12" Margin="0,4,0,0" />
                            </StackPanel>
                            <Ellipse Grid.Column="1" Width="10" Height="10" Fill="#61D394" VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                    <TextBlock Text="快捷入口"
                               Foreground="#F6F7FB"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <Border CornerRadius="16" Background="{DynamicResource BrushDarkPanelSoft}" Padding="14" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Text="剪贴板热键" Foreground="#E8EAEE" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding OpenClipboardHotkeyText}" Foreground="#8F949E" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>
                    <Border CornerRadius="16" Background="{DynamicResource BrushDarkPanelSoft}" Padding="14" Margin="0,0,0,18">
                        <StackPanel>
                            <TextBlock Text="当前预设" Foreground="#E8EAEE" FontWeight="SemiBold" />
                            <TextBlock Text="{Binding SelectedGesturePresetOption.DisplayName}" Foreground="#8F949E" FontSize="12" Margin="0,4,0,0" />
                        </StackPanel>
                    </Border>

                    <TextBlock Text="提示"
                               Foreground="#F6F7FB"
                               FontWeight="SemiBold"
                               Margin="0,0,0,10" />
                    <TextBlock Text="右键画线执行动作。Ctrl + ` 打开剪贴板历史。数据默认保存在本机。"
                               Foreground="#8F949E"
                               FontSize="12"
                               LineHeight="20"
                               TextWrapping="Wrap" />
                </StackPanel>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
    </Border>
</Window>
