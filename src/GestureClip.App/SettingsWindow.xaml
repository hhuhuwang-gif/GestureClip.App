                                                    BorderThickness="1"
                                                    CornerRadius="18"
                                                    Padding="16"
                                                    Margin="0,2,0,0">
                                                <StackPanel>
                                                    <TextBlock Text="选择要执行的动作"
                                                               FontWeight="SemiBold" />
                                                    <TextBlock Text="右键按住 + 左键点击是手势触发方式；这里选择的是触发后要执行的动作。"
                                                               Style="{StaticResource MutedTextStyle}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,6,0,14" />

                                                    <Expander Header="快捷动作"
                                                              IsExpanded="False"
                                                              Margin="0,0,0,14">
                                                        <WrapPanel Margin="0,10,0,0">
                                                            <Button Content="Google 搜索"
                                                                    Style="{StaticResource SettingsGestureTemplateButtonStyle}"
                                                                    Command="{Binding SetNewGestureActionCommand}"
                                                                    CommandParameter="SearchSelectedTextWithGoogle" />
                                                            <Button Content="百度搜索"
                                                                    Style="{StaticResource SettingsGestureTemplateButtonStyle}"
                                                                    Command="{Binding SetNewGestureActionCommand}"
                                                                    CommandParameter="SearchSelectedTextWithBaidu" />
                                                        </WrapPanel>
                                                    </Expander>

                                                    <TextBlock Text="手势码"
                                                               FontWeight="SemiBold"
                                                               Margin="0,0,0,6" />
                                                    <TextBox Height="40"
                                                             HorizontalAlignment="Stretch"
                                                             Text="{Binding NewGesturePattern, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />

                                                    <TextBlock Text="执行动作"
                                                               FontWeight="SemiBold"
                                                               Margin="0,14,0,6" />
                                                    <ComboBox Height="40"
                                                              HorizontalAlignment="Stretch"
                                                              ItemsSource="{Binding GestureActionOptions}"
                                                              DisplayMemberPath="DisplayName"
                                                              SelectedValuePath="Action"
                                                              SelectedValue="{Binding NewGestureAction, Mode=TwoWay}" />

                                                    <Button Content="{Binding NewGestureAddButtonText}"
                                                            MinWidth="0"
                                                            Height="40"
                                                            Margin="0,16,0,0"
                                                            Style="{StaticResource PrimaryButtonStyle}"
                                                            Focusable="False"
                                                            Command="{Binding AddCustomGestureBindingCommand}" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Border>
                                </Expander>
                            </StackPanel>


                    </ScrollViewer>
                </TabItem>

                <TabItem Header="隐私">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="18">
                            <Border x:Name="PrivacyPageIntro" Style="{StaticResource SettingsIntroCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="隐私与屏蔽名单" Style="{StaticResource SettingsIntroTitleStyle}" />
                                    <TextBlock Text="把不想记录剪贴板或不想响应手势的软件加进来。规则只在本机生效。"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Border>
                        <GroupBox Header="隐私" Padding="12" Margin="0">
                            <StackPanel>
                                <StackPanel Orientation="Horizontal">
                                    <TextBox Width="220" Text="{Binding NewBlacklistProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                                    <Button Content="添加"
                                            Style="{StaticResource SettingsPrimaryActionButtonStyle}"
                                            Width="96"
                                            Margin="8,0,0,0"
                                            Command="{Binding AddBlacklistItemCommand}" />
                                </StackPanel>
                                <TextBlock Text="添加进程名后，会按进程阻止剪贴板记录和鼠标手势。" Style="{StaticResource MutedTextStyle}" TextWrapping="Wrap" Margin="0,6,0,8" />
                                <ItemsControl ItemsSource="{Binding AppBlacklistItems}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,4,0,0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="170" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="110" />
                                                    <ColumnDefinition Width="104" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding ProcessName}" VerticalAlignment="Center" />
                                                <CheckBox Grid.Column="1" Content="剪贴板" IsChecked="{Binding BlockClipboard, Mode=TwoWay}" />
                                                <CheckBox Grid.Column="2" Content="手势" IsChecked="{Binding BlockGesture, Mode=TwoWay}" />
                                                <Button Grid.Column="3"
                                                        Content="删除"
                                                        Style="{StaticResource SettingsDangerActionButtonStyle}"
                                                        Width="88"
                                                        Margin="0"
                                                        Command="{Binding DeleteCommand}" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="自启">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="18">
                            <Border x:Name="StartupPageIntro" Style="{StaticResource SettingsIntroCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="开机启动" Style="{StaticResource SettingsIntroTitleStyle}" />
                                    <TextBlock Text="需要每天自动常驻时开启。关闭窗口仍会隐藏到托盘，不会清空本地历史。"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Border>
                            <GroupBox Header="自启" Padding="12" Margin="0">
                                <StackPanel>
                                    <CheckBox Content="开机自动启动 GestureClip" IsChecked="{Binding StartWithWindows, Mode=TwoWay}" />
                                    <TextBlock Text="{Binding StartupModeWarning}" Foreground="{DynamicResource BrushPrimaryBright}" TextWrapping="Wrap" Margin="0,6,0,0" />
                                </StackPanel>
                            </GroupBox>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="小熊">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="18">
                            <Border x:Name="WorkstationPageIntro" Style="{StaticResource SettingsIntroCardStyle}">
                                <StackPanel>
                                    <TextBlock Text="工位小熊" Style="{StaticResource SettingsIntroTitleStyle}" />
                                    <TextBlock Text="用更直观的方式看工作时间、下班倒计时、今日收入和提醒。所有统计仍然只在本地计算。"
                                               Style="{StaticResource MutedTextStyle}" />
                                </StackPanel>
                            </Border>
                            <GroupBox Header="小熊" Padding="12">
                                <StackPanel>
                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <StackPanel>
                                            <TextBlock Text="用大白话看今天还要熬多久、赚了多少、摸鱼值多少钱。"
                                                       FontWeight="SemiBold"
                                                       TextWrapping="Wrap" />
                                            <TextBlock Text="所有统计只在本地计算，不上传，也不记录剪贴板正文。"
