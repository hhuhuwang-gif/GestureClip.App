                                                    <TextBlock Text="稍后提醒" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                    <TextBox Width="72"
                                                             Text="{Binding WorkstationOverworkSnoozeMinutes, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                    <TextBlock Text="分钟（5-60）" Style="{StaticResource MutedTextStyle}" VerticalAlignment="Center" Margin="8,0,0,0" />
                                                </WrapPanel>
                                                <Border Background="#EEF2F7"
                                                        BorderBrush="{DynamicResource BrushBorder}"
                                                        BorderThickness="1"
                                                        CornerRadius="14"
                                                        Padding="12"
                                                        Margin="0,10,0,0">
                                                    <WrapPanel>
                                                        <TextBlock Text="{Binding OverworkPreviewStageText}" Margin="0,0,18,6" />
                                                        <TextBlock Text="{Binding OverworkPreviewHudColorText}" Margin="0,0,18,6" />
                                                        <TextBlock Text="{Binding OverworkPreviewNextReminderText}" Margin="0,0,18,6" />
                                                        <TextBlock Text="{Binding OverworkPreviewWorkedText}" Margin="0,0,0,6" />
                                                    </WrapPanel>
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="工作制模板" FontWeight="SemiBold" VerticalAlignment="Top" />
                                            <ItemsControl Grid.Column="1" ItemsSource="{Binding WorkstationTemplateOptions}">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <WrapPanel />
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Button Content="{Binding Name}"
                                                                Style="{StaticResource SettingsGestureTemplateButtonStyle}"
                                                                Command="{Binding DataContext.ApplyWorkstationTemplateCommand, RelativeSource={RelativeSource AncestorType=ItemsControl}}"
                                                                CommandParameter="{Binding}" />
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </Grid>
                                    </Border>


                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="月薪" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal">
                                                <TextBox Width="150"
                                                         Text="{Binding WorkstationMonthlySalary, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <TextBlock Text="元，用来估算今日已赚和摸鱼价值"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="工作时间" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <WrapPanel Grid.Column="1"
                                                       VerticalAlignment="Center">
                                                <TextBlock Text="上班" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBox Width="100"
                                                         Text="{Binding WorkstationWorkStartTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <TextBlock Text="下班" VerticalAlignment="Center" Margin="18,0,8,0" />
                                                <TextBox Width="100"
                                                         Text="{Binding WorkstationWorkEndTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="午休时间" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <WrapPanel Grid.Column="1"
                                                       VerticalAlignment="Center">
                                                <TextBlock Text="开始" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                <TextBox Width="100"
                                                         Text="{Binding WorkstationLunchStartTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <TextBlock Text="结束" VerticalAlignment="Center" Margin="18,0,8,0" />
                                                <TextBox Width="100"
                                                         Text="{Binding WorkstationLunchEndTime, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                            </WrapPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="工作日" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal">
                                                <TextBox Width="180"
                                                         Text="{Binding WorkstationWorkdays, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <TextBlock Text="1=周一，5=周五，默认 1,2,3,4,5"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="发薪日" FontWeight="SemiBold" VerticalAlignment="Center" />
                                            <StackPanel Grid.Column="1"
                                                        Orientation="Horizontal">
                                                <TextBox Width="90"
                                                         Text="{Binding WorkstationPayday, Mode=TwoWay, UpdateSourceTrigger=LostFocus}" />
                                                <TextBlock Text="每月几号，范围 1-28"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           VerticalAlignment="Center"
                                                           Margin="12,0,0,0" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Style="{StaticResource SettingsFormRowStyle}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="150" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="显示内容" FontWeight="SemiBold" VerticalAlignment="Top" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="基础显示" FontWeight="SemiBold" Margin="0,0,0,6" />
                                                <WrapPanel>
                                                    <CheckBox Content="显示下班倒计时" Margin="0,0,20,8" IsChecked="{Binding WorkstationShowOffWorkCountdown, Mode=TwoWay}" />
                                                    <CheckBox Content="显示今日工资" Margin="0,0,20,8" IsChecked="{Binding WorkstationEnabled, Mode=TwoWay}" />
                                                    <CheckBox Content="显示当前状态" Margin="0,0,20,8" IsChecked="{Binding WorkstationEnabled, Mode=TwoWay}" />
                                                </WrapPanel>
                                                <TextBlock Text="趣味显示" FontWeight="SemiBold" Margin="0,8,0,6" />
                                                <WrapPanel>
                                                    <CheckBox Content="显示摸鱼价值" Margin="0,0,20,8" IsChecked="{Binding WorkstationShowFishingValue, Mode=TwoWay}" />
                                                    <CheckBox Content="老板警戒" Margin="0,0,20,8" IsChecked="{Binding HudStatusLevelEnabled, Mode=TwoWay}" />
                                                    <CheckBox Content="心情状态" Margin="0,0,20,8" IsChecked="{Binding HudFunTextEnabled, Mode=TwoWay}" />
                                                </WrapPanel>
                                                <TextBlock Text="统计显示" FontWeight="SemiBold" Margin="0,8,0,6" />
                                                <WrapPanel>
                                                    <CheckBox Content="每日存活报告" Margin="0,0,20,8" IsChecked="{Binding WorkstationDailyReportEnabled, Mode=TwoWay}" />
                                                    <CheckBox Content="下班后自动弹出报告" Margin="0,0,20,8" IsChecked="{Binding AutoShowDailyWorkReport, Mode=TwoWay}" />
                                                    <CheckBox Content="摸鱼模式" Margin="0,0,20,8" IsChecked="{Binding EnableFishMode, Mode=TwoWay}" />
                                                    <CheckBox Content="下班冲刺" Margin="0,0,20,8" IsChecked="{Binding EnableWorkSprintMode, Mode=TwoWay}" />
                                                    <CheckBox Content="PNG 分享卡" Margin="0,0,20,8" IsChecked="{Binding EnableWorkBearShareCard, Mode=TwoWay}" />
                                                    <CheckBox Content="等级 / XP" Margin="0,0,20,8" IsChecked="{Binding WorkerLevelShowLevelInHud, Mode=TwoWay}" />
                                                </WrapPanel>
                                                <TextBlock Text="HUD 联动" FontWeight="SemiBold" Margin="0,8,0,6" />
                                                <WrapPanel>
                                                    <CheckBox Content="HUD 显示工位状态短文案" Margin="0,0,20,8" IsChecked="{Binding EnableWorkBearHudStatusText, Mode=TwoWay}" />
                                                    <CheckBox Content="HUD 颜色跟随工作阶段" Margin="0,0,20,8" IsChecked="{Binding EnableWorkBearHudThemeColor, Mode=TwoWay}" />
                                                </WrapPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                                                    <TextBlock Text="文案风格" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,12,0" />
