<Window x:Class="GestureClip.App.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GestureClip 设置"
        Width="720"
        Height="620"
        MinWidth="640"
        MinHeight="560">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel>
            <TextBlock Text="GestureClip"
                       FontSize="28"
                       FontWeight="SemiBold" />
            <TextBlock Text="第一阶段：启动、托盘、数据库、设置和权限检测"
                       Margin="0,6,0,18"
                       Foreground="#666666" />
        </StackPanel>

        <Border Grid.Row="1"
                BorderBrush="#DDDDDD"
                BorderThickness="1"
                CornerRadius="6"
                Padding="18">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="150" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <TextBlock Text="权限状态" FontWeight="SemiBold" />
                <TextBlock Grid.Column="1" Text="{Binding PermissionStatusText}" />

                <TextBlock Grid.Row="1" Text="数据库路径" FontWeight="SemiBold" Margin="0,14,0,0" />
                <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding DatabasePath, Mode=OneWay}" IsReadOnly="True" Margin="0,10,0,0" />

                <TextBlock Grid.Row="2" Text="日志目录" FontWeight="SemiBold" Margin="0,14,0,0" />
                <TextBox Grid.Row="2" Grid.Column="1" Text="{Binding LogDirectory, Mode=OneWay}" IsReadOnly="True" Margin="0,10,0,0" />

                <TextBlock Grid.Row="3" Text="运行状态" FontWeight="SemiBold" Margin="0,14,0,0" />
                <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,14,0,0">
                    <TextBlock Text="{Binding StartupStatus}" />
                    <TextBlock Text="{Binding HotkeyStatusText}" Foreground="#666666" Margin="0,4,0,0" />
                </StackPanel>

                <TextBlock Grid.Row="4" Text="鼠标手势" FontWeight="SemiBold" Margin="0,20,0,0" />
                <StackPanel Grid.Row="4" Grid.Column="1" Margin="0,16,0,0">
                    <CheckBox Content="启用剪贴板记录"
                              IsChecked="{Binding ClipboardCaptureEnabled, Mode=TwoWay}" />
                    <CheckBox Content="启用鼠标手势"
                              Margin="0,8,0,0"
                              IsChecked="{Binding GestureEnabled, Mode=TwoWay}" />
                    <CheckBox Content="显示手势提示"
                              Margin="0,8,0,0"
                              IsChecked="{Binding GestureShowOverlay, Mode=TwoWay}" />
                    <CheckBox Content="启用手势调试日志"
                              Margin="0,8,0,0"
                              IsChecked="{Binding GestureDebugEnabled, Mode=TwoWay}" />
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="手势预设" VerticalAlignment="Center" />
                        <ComboBox Width="160"
                                  Margin="12,0,0,0"
                                  ItemsSource="{Binding GesturePresetOptions}"
                                  SelectedItem="{Binding SelectedGesturePresetOption, Mode=TwoWay}"
                                  DisplayMemberPath="DisplayName" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="触发阈值" VerticalAlignment="Center" />
                        <TextBox Width="60"
                                 Margin="12,0,0,0"
                                 Text="{Binding GestureTriggerThreshold, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="px" Margin="6,0,0,0" VerticalAlignment="Center" />
                    </StackPanel>
                    <CheckBox Content="启用 UD 关闭窗口手势"
                              Margin="0,8,0,0"
                              IsChecked="{Binding GestureCloseWindowEnabled, Mode=TwoWay}" />
                    <TextBlock Margin="0,12,0,0"
                               Foreground="#666666"
                               TextWrapping="Wrap"
                               Text="编辑增强：U 复制，D 粘贴，UD 回车，DU 取消，L 后退，R 前进，LR 全选，RL 撤销。剪贴板增强：U 打开剪贴板历史，D 粘贴最近一条。" />
                    <Border Margin="0,14,0,0"
                            BorderBrush="#DDDDDD"
                            BorderThickness="1"
                            CornerRadius="6"
                            Padding="12">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="110" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Text="手势测试" FontWeight="SemiBold" Grid.ColumnSpan="2" />
                            <TextBlock Grid.Row="1" Text="Hook 状态" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding GestureHookStatus}" Margin="0,8,0,0" />
                            <TextBlock Grid.Row="2" Text="当前状态" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding GestureRuntimeStateText}" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="3" Text="最近 Pattern" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="3" Grid.Column="1" Text="{Binding LastGesturePattern}" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="4" Text="最近 Action" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="4" Grid.Column="1" Text="{Binding LastGestureAction}" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="5" Text="最近错误" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="5" Grid.Column="1" Text="{Binding LastGestureError}" TextWrapping="Wrap" Margin="0,6,0,0" />
                            <TextBlock Grid.Row="6" Text="最近事件" Margin="0,6,0,0" />
                            <StackPanel Grid.Row="6" Grid.Column="1" Margin="0,6,0,0">
                                <TextBlock Text="{Binding LastGestureEventTime}" />
                                <TextBlock Text="{Binding GestureEnvironmentStatus}" Foreground="#666666" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>
                    </Border>
                </StackPanel>

                <TextBlock Grid.Row="5"
                           Text="隐私黑名单"
                           FontWeight="SemiBold"
                           Margin="0,22,0,0" />
                <StackPanel Grid.Row="5" Grid.Column="1" Margin="0,18,0,0">
                    <StackPanel Orientation="Horizontal">
                        <TextBox Width="220"
                                 Text="{Binding NewBlacklistProcessName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <Button Content="添加"
                                Width="72"
                                Margin="8,0,0,0"
                                Command="{Binding AddBlacklistItemCommand}" />
                    </StackPanel>
                    <TextBlock Text="添加进程名后，会按进程阻止剪贴板记录和鼠标手势。"
                               Foreground="#666666"
                               TextWrapping="Wrap"
                               Margin="0,6,0,8" />
                    <ItemsControl ItemsSource="{Binding AppBlacklistItems}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,4,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="170" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="110" />
                                        <ColumnDefinition Width="70" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding ProcessName}"
                                               VerticalAlignment="Center" />
                                    <CheckBox Grid.Column="1"
                                              Content="剪贴板"
                                              IsChecked="{Binding BlockClipboard, Mode=TwoWay}" />
                                    <CheckBox Grid.Column="2"
                                              Content="手势"
                                              IsChecked="{Binding BlockGesture, Mode=TwoWay}" />
                                    <Button Grid.Column="3"
                                            Content="删除"
                                            Command="{Binding DeleteCommand}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </StackPanel>

                <TextBlock Grid.Row="6"
                           Text="开机自启"
                           FontWeight="SemiBold"
                           Margin="0,22,0,0" />
                <StackPanel Grid.Row="6" Grid.Column="1" Margin="0,18,0,0">
                    <CheckBox Content="开机自动启动 GestureClip"
                              IsChecked="{Binding StartWithWindows, Mode=TwoWay}" />
                    <TextBlock Text="{Binding StartupModeWarning}"
                               Foreground="#996600"
                               TextWrapping="Wrap"
                               Margin="0,6,0,0" />
                </StackPanel>

                <TextBlock Grid.Row="7"
                           Text="诊断信息"
                           FontWeight="SemiBold"
                           Margin="0,22,0,0" />
                <StackPanel Grid.Row="7" Grid.Column="1" Margin="0,18,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button Content="打开日志目录"
                                Command="{Binding OpenLogDirectoryCommand}" />
                        <Button Content="打开数据目录"
                                Margin="8,0,0,0"
                                Command="{Binding OpenDataDirectoryCommand}" />
                        <Button Content="复制诊断信息"
                                Margin="8,0,0,0"
                                Command="{Binding CopyDiagnosticsCommand}" />
                        <Button Content="刷新"
                                Margin="8,0,0,0"
                                Command="{Binding RefreshDiagnosticsCommand}" />
                    </StackPanel>
                    <TextBox Text="{Binding DiagnosticsText, Mode=OneWay}"
                             IsReadOnly="True"
                             TextWrapping="Wrap"
                             AcceptsReturn="True"
                             MinHeight="150"
                             Margin="0,10,0,0" />
                </StackPanel>

                <TextBlock Grid.Row="8"
                           Grid.ColumnSpan="2"
                           Margin="0,28,0,0"
                           Foreground="#666666"
                           TextWrapping="Wrap"
                           Text="MVP 不保证控制管理员权限窗口。如需控制管理员窗口，请以管理员身份运行 GestureClip。第三阶段仅包含右键鼠标手势，不包含屏幕边缘触发、圆形菜单和应用级手势规则。" />
            </Grid>
            </ScrollViewer>
        </Border>
    </Grid>
</Window>

