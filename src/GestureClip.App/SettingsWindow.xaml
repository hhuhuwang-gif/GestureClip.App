                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="猝死提醒" FontWeight="SemiBold" VerticalAlignment="Top" />
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="工位小熊健康提醒：根据工作时间和连续使用时长，提醒你喝水、活动和及时下班。只做本地提醒，不做医学判断。"
                                                           Style="{StaticResource MutedTextStyle}"
                                                           TextWrapping="Wrap" />
                                                <WrapPanel Margin="0,10,0,0">
                                                    <CheckBox Content="开启过劳提醒"
                                                              Margin="0,0,20,8"
                                                              IsChecked="{Binding WorkstationEnableOverworkReminder, Mode=TwoWay}" />
                                                    <CheckBox Content="HUD 跟随工作时间变色"
                                                              Margin="0,0,20,8"
                                                              IsChecked="{Binding WorkstationEnableHudTimeColor, Mode=TwoWay}" />
                                                    <CheckBox Content="允许稍后提醒"
                                                              Margin="0,0,20,8"
                                                              IsChecked="{Binding WorkstationOverworkReminderCanSnooze, Mode=TwoWay}" />
                                                    <CheckBox Content="更强提醒文案"
                                                              Margin="0,0,0,8"
                                                              IsChecked="{Binding WorkstationEnableStrongOverworkWarning, Mode=TwoWay}" />
                                                </WrapPanel>
