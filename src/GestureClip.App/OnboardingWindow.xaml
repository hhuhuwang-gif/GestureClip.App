<Window x:Class="GestureClip.App.OnboardingWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="欢迎使用 GestureClip"
        Icon="Assets/GestureClip.ico"
        Width="760"
        Height="560"
        MinWidth="720"
        MinHeight="520"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="{DynamicResource BrushAppBackground}"
        Foreground="{DynamicResource BrushTextPrimary}">
    <Border Margin="22" Style="{StaticResource GlassPanelStyle}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel>
                <TextBlock Text="欢迎使用 GestureClip"
                           FontSize="30"
                           FontWeight="SemiBold" />
                <TextBlock Text="三步开启本地优先的剪贴板历史、鼠标手势和可选工位小熊。"
                           Margin="0,8,0,0"
                           Style="{StaticResource MutedTextStyle}"
                           FontSize="15" />
            </StackPanel>

            <Grid Grid.Row="1" Margin="0,26,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0"
                        Style="{StaticResource GlassCardStyle}"
                        Padding="18"
                        Margin="0,0,10,0"
                        Cursor="Hand"
                        Tag="clipboard"
                        MouseLeftButtonUp="FeatureCard_MouseLeftButtonUp"
                        ToolTip="点击打开剪贴板设置">
                    <StackPanel>
                        <TextBlock Text="1" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource BrushPrimary}" />
                        <TextBlock Text="剪贴板历史" Margin="0,12,0,0" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="复制过的文字、图片和截图可以找回来；默认数据只保存在本机。"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource MutedTextStyle}" />
                        <TextBlock Text="点击开始设置 →"
                                   Margin="0,14,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushPrimaryBright}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="1"
                        Style="{StaticResource GlassCardStyle}"
                        Padding="18"
                        Margin="5,0,5,0"
                        Cursor="Hand"
                        Tag="bindings"
                        MouseLeftButtonUp="FeatureCard_MouseLeftButtonUp"
                        ToolTip="点击打开动作绑定 / 设计手势">
                    <StackPanel>
                        <TextBlock Text="2" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource BrushPrimary}" />
                        <TextBlock Text="鼠标手势" Margin="0,12,0,0" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="按住右键划一下即可复制、粘贴、后退、前进；可在动作绑定里更换动作。"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource MutedTextStyle}" />
                        <TextBlock Text="点击去设计动作 →"
                                   Margin="0,14,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushPrimaryBright}" />
                    </StackPanel>
                </Border>

                <Border Grid.Column="2"
                        Style="{StaticResource GlassCardStyle}"
                        Padding="18"
                        Margin="10,0,0,0"
                        Cursor="Hand"
                        Tag="workbear"
                        MouseLeftButtonUp="FeatureCard_MouseLeftButtonUp"
                        ToolTip="点击打开工位小熊设置">
                    <StackPanel>
                        <TextBlock Text="3" FontSize="26" FontWeight="Bold" Foreground="{DynamicResource BrushPrimary}" />
                        <TextBlock Text="工位小熊" Margin="0,12,0,0" FontSize="18" FontWeight="SemiBold" />
                        <TextBlock Text="可选趣味模块：今日收益、下班倒计时、休息提醒和工作报告。"
                                   Margin="0,10,0,0"
                                   TextWrapping="Wrap"
                                   Style="{StaticResource MutedTextStyle}" />
                        <TextBlock Text="点击打开小熊 →"
                                   Margin="0,14,0,0"
                                   FontWeight="SemiBold"
                                   Foreground="{DynamicResource BrushPrimaryBright}" />
                    </StackPanel>
                </Border>
            </Grid>

            <Border Grid.Row="2" CornerRadius="18" Background="#10FFFFFF" BorderBrush="#22FFFFFF" BorderThickness="1" Padding="16">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="默认快捷键：Ctrl + `"
                                   FontWeight="SemiBold" />
                        <TextBlock Text="你可以随时在设置页暂停剪贴板记录、暂停鼠标手势或调整隐私黑名单。"
                                   Margin="0,6,0,0"
                                   Style="{StaticResource MutedTextStyle}" />
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="18,0,0,0">
                        <Button Content="稍后再说"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Click="SkipButton_Click" />
                        <Button Content="打开设置首页"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Margin="10,0,0,0"
                                Click="StartButton_Click" />
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
