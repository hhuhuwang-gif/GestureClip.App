<Application x:Class="GestureClip.App.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:converters="clr-namespace:GestureClip.App.Converters">
    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="Themes/Colors.xaml" />
                <ResourceDictionary Source="Themes/Brushes.xaml" />
                <ResourceDictionary Source="Themes/GlassStyles.xaml" />
                <ResourceDictionary Source="Themes/Controls.xaml" />
            </ResourceDictionary.MergedDictionaries>
            <converters:ShortcutNumberConverter x:Key="ShortcutNumberConverter" />
            <converters:ImageBase64ToSourceConverter x:Key="ImageBase64ToSourceConverter" />
            <converters:RelativeTimeConverter x:Key="RelativeTimeConverter" />
            <converters:GestureActionOptionConverter x:Key="GestureActionOptionConverter" />
            <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        </ResourceDictionary>
    </Application.Resources>
</Application>
