root = true

[*]
charset = utf-8
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

[*.{cs,xaml,csproj,sln,props,targets,resx,ps1,cmd,bat}]
end_of_line = crlf

[*.{md,yml,yaml,json,editorconfig,gitattributes}]
end_of_line = lf

[*.md]
trim_trailing_whitespace = false
